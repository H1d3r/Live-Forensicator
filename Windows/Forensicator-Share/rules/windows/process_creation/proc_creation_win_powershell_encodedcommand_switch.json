{
  "title": "PowerShell EncodedCommand Switch Usage",
  "rule_id": "forensicator-ps-encodedcommand-switch",
  "description": "Detects PowerShell process creation where encoded command switches are used (-e/-en/-enc/-encodedcommand).",
  "level": "high",
  "status": "stable",
  "tags": [
    "attack.execution",
    "attack.t1059.001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_powershell_encodedcommand_switch.json",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\powershell.exe",
            "\\pwsh.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "OriginalFileName",
          "operator": "exact",
          "values": [
            "PowerShell.EXE",
            "pwsh.dll"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_encoded_switch": {
      "type": "field",
      "field": "CommandLine",
      "operator": "re",
      "values": [
        "(?:^|[\\s\"'])[-/](?:e|en|enc|encodedcommand)(?:[\\s:=]|$)"
      ],
      "match": "any",
      "windash": false,
      "ignore_case": true
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection_img"
      },
      {
        "type": "item_ref",
        "name": "selection_encoded_switch"
      }
    ]
  }
}
