{
  "title": "DLL Loaded From Suspicious Location Via Cmspt.EXE",
  "rule_id": "75e508f7-932d-4ebc-af77-269237a84ce1",
  "description": "Detects cmstp loading \"dll\" or \"ocx\" files from suspicious locations",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1218.003"
  ],
  "category": "image_load",
  "rule_file": "rules/windows/image_load/image_load_cmstp_load_dll_from_susp_location.yml",
  "sources": [
    "sysmon_image_load"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\cmstp.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "ImageLoaded",
          "operator": "contains",
          "values": [
            "\\PerfLogs\\",
            "\\ProgramData\\",
            "\\Users\\",
            "\\Windows\\Temp\\",
            "C:\\Temp\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "ImageLoaded",
          "operator": "endswith",
          "values": [
            ".dll",
            ".ocx"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}