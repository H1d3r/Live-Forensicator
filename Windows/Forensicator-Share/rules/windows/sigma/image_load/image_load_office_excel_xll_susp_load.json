{
  "title": "Microsoft Excel Add-In Loaded From Uncommon Location",
  "rule_id": "af4c4609-5755-42fe-8075-4effb49f5d44",
  "description": "Detects Microsoft Excel loading an Add-In (.xll) file from an uncommon location",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1204.002"
  ],
  "category": "image_load",
  "rule_file": "rules/windows/image_load/image_load_office_excel_xll_susp_load.yml",
  "sources": [
    "sysmon_image_load"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\excel.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "ImageLoaded",
          "operator": "contains",
          "values": [
            "\\Desktop\\",
            "\\Downloads\\",
            "\\Perflogs\\",
            "\\Temp\\",
            "\\Users\\Public\\",
            "\\Windows\\Tasks\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "ImageLoaded",
          "operator": "endswith",
          "values": [
            ".xll"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}