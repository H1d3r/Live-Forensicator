{
  "title": "PowerShell Core DLL Loaded Via Office Application",
  "rule_id": "bb2ba6fb-95d4-4a25-89fc-30bb736c021a",
  "description": "Detects PowerShell core DLL being loaded by an Office Product",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion"
  ],
  "category": "image_load",
  "rule_file": "rules/windows/image_load/image_load_office_powershell_dll_load.yml",
  "sources": [
    "sysmon_image_load"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\excel.exe",
            "\\mspub.exe",
            "\\outlook.exe",
            "\\onenote.exe",
            "\\onenoteim.exe",
            "\\powerpnt.exe",
            "\\winword.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "ImageLoaded",
          "operator": "contains",
          "values": [
            "\\System.Management.Automation.Dll",
            "\\System.Management.Automation.ni.Dll"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}