{
  "title": "VBA DLL Loaded Via Office Application",
  "rule_id": "e6ce8457-68b1-485b-9bdd-3c2b5d679aa9",
  "description": "Detects VB DLL's loaded by an office application. Which could indicate the presence of VBA Macros.",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1204.002"
  ],
  "category": "image_load",
  "rule_file": "rules/windows/image_load/image_load_office_vbadll_load.yml",
  "sources": [
    "sysmon_image_load"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\excel.exe",
            "\\mspub.exe",
            "\\onenote.exe",
            "\\onenoteim.exe",
            "\\outlook.exe",
            "\\powerpnt.exe",
            "\\winword.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "ImageLoaded",
          "operator": "endswith",
          "values": [
            "\\VBE7.DLL",
            "\\VBEUI.DLL",
            "\\VBE7INTL.DLL"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}