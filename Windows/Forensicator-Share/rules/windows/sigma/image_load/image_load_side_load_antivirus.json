  },
  "condition": {
    "type": "any",
    "children": [
      {
        "type": "all",
        "children": [
          {
            "type": "item_ref",
            "name": "selection_bitdefender"
          },
          {
            "type": "not",
            "child": {
              "type": "wildcard_ref",
              "mode": "any",
              "pattern": "filter_log_dll_*"
            }
          }
        ]
      },
      {
        "type": "all",
        "children": [
          {
            "type": "item_ref",
            "name": "selection_fsecure"
          },
          {
            "type": "not",
            "child": {
              "type": "item_ref",
              "name": "filter_fsecure"
            }
          }
        ]
      },
      {
        "type": "all",
        "children": [
          {
            "type": "item_ref",
            "name": "selection_mcafee"
          },
          {
            "type": "not",
            "child": {
              "type": "item_ref",
              "name": "filter_mcafee"
            }
          }
