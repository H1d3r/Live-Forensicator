{
  "title": "Potential Antivirus Software DLL Sideloading",
  "rule_id": "552b6b65-df37-4d3e-a258-f2fc4771ae54",
  "description": "Detects potential DLL sideloading of DLLs that are part of antivirus software suchas McAfee, Symantec...etc",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.persistence",
    "attack.privilege-escalation",
    "attack.t1574.001"
  ],
  "category": "image_load",
  "rule_file": "rules/windows/image_load/image_load_side_load_antivirus.yml",
  "sources": [
    "sysmon_image_load"
  ],
  "items": {
    "selection_bitdefender": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ImageLoaded",
          "operator": "endswith",
          "values": [
            "\\log.dll"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_log_dll_bitdefender": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ImageLoaded",
          "operator": "startswith",
          "values": [
            "C:\\Program Files\\Bitdefender Antivirus Free\\",
            "C:\\Program Files (x86)\\Bitdefender Antivirus Free\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_log_dll_dell_sar": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "exact",
          "values": [
            "C:\\Program Files\\Dell\\SARemediation\\audit\\TelemetryUtility.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "ImageLoaded",
          "operator": "exact",
          "values": [
            "C:\\Program Files\\Dell\\SARemediation\\plugin\\log.dll",
            "C:\\Program Files\\Dell\\SARemediation\\audit\\log.dll"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_log_dll_canon": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ImageLoaded",
          "operator": "startswith",
          "values": [
            "C:\\Program Files\\Canon\\MyPrinter\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_log_dll_avast": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ImageLoaded",
          "operator": "exact",
          "values": [
            "C:\\Program Files\\AVAST Software\\Avast\\log.dll",
            "C:\\Program Files (x86)\\AVAST Software\\Avast\\log.dll"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
