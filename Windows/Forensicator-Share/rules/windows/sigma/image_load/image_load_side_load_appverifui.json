{
  "title": "Potential appverifUI.DLL Sideloading",
  "rule_id": "ee6cea48-c5b6-4304-a332-10fc6446f484",
  "description": "Detects potential DLL sideloading of \"appverifUI.dll\"",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.persistence",
    "attack.defense-evasion",
    "attack.privilege-escalation",
    "attack.t1574.001"
  ],
  "category": "image_load",
  "rule_file": "rules/windows/image_load/image_load_side_load_appverifui.yml",
  "sources": [
    "sysmon_image_load"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ImageLoaded",
          "operator": "endswith",
          "values": [
            "\\appverifUI.dll"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_legit_path": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "exact",
          "values": [
            "C:\\Windows\\SysWOW64\\appverif.exe",
            "C:\\Windows\\System32\\appverif.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "ImageLoaded",
          "operator": "startswith",
          "values": [
            "C:\\Windows\\System32\\",
            "C:\\Windows\\SysWOW64\\",
            "C:\\Windows\\WinSxS\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_main_*"
        }
      }
    ]
  }
}