{
  "title": "Potential DLL Sideloading Of MsCorSvc.DLL",
  "rule_id": "cdb15e19-c2d0-432a-928e-e49c8c60dcf2",
  "description": "Detects potential DLL sideloading of \"mscorsvc.dll\".",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.privilege-escalation",
    "attack.persistence",
    "attack.defense-evasion",
    "attack.t1574.001"
  ],
  "category": "image_load",
  "rule_file": "rules/windows/image_load/image_load_side_load_mscorsvc.yml",
  "sources": [
    "sysmon_image_load"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ImageLoaded",
          "operator": "endswith",
          "values": [
            "\\mscorsvc.dll"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_generic": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ImageLoaded",
          "operator": "startswith",
          "values": [
            "C:\\Windows\\Microsoft.NET\\Framework\\",
            "C:\\Windows\\Microsoft.NET\\Framework64\\",
            "C:\\Windows\\Microsoft.NET\\FrameworkArm\\",
            "C:\\Windows\\Microsoft.NET\\FrameworkArm64\\",
            "C:\\Windows\\WinSxS\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_main_*"
        }
      }
    ]
  }
}