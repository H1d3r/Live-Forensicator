{
  "title": "Microsoft Office DLL Sideload",
  "rule_id": "829a3bdf-34da-4051-9cf4-8ed221a8ae4f",
  "description": "Detects DLL sideloading of DLLs that are part of Microsoft Office from non standard location",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.persistence",
    "attack.privilege-escalation",
    "attack.t1574.001"
  ],
  "category": "image_load",
  "rule_file": "rules/windows/image_load/image_load_side_load_office_dlls.yml",
  "sources": [
    "sysmon_image_load"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ImageLoaded",
          "operator": "endswith",
          "values": [
            "\\outllib.dll"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ImageLoaded",
          "operator": "startswith",
          "values": [
            "C:\\Program Files\\Microsoft Office\\OFFICE",
            "C:\\Program Files (x86)\\Microsoft Office\\OFFICE",
            "C:\\Program Files\\Microsoft Office\\Root\\OFFICE",
            "C:\\Program Files (x86)\\Microsoft Office\\Root\\OFFICE"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "item_ref",
          "name": "filter"
        }
      }
    ]
  }
}