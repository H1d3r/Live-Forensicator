{
  "title": "Potential ShellDispatch.DLL Sideloading",
  "rule_id": "844f8eb2-610b-42c8-89a4-47596e089663",
  "description": "Detects potential DLL sideloading of \"ShellDispatch.dll\"",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.persistence",
    "attack.defense-evasion",
    "attack.privilege-escalation",
    "attack.t1574.001"
  ],
  "category": "image_load",
  "rule_file": "rules/windows/image_load/image_load_side_load_shelldispatch.yml",
  "sources": [
    "sysmon_image_load"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ImageLoaded",
          "operator": "endswith",
          "values": [
            "\\ShellDispatch.dll"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_legit_path": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "ImageLoaded",
              "operator": "contains",
              "values": [
                ":\\Users\\",
                "\\AppData\\Local\\Temp\\"
              ],
              "match": "all",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "ImageLoaded",
              "operator": "contains",
              "values": [
                ":\\Windows\\Temp\\"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_main_*"
        }
      }
    ]
  }
}