{
  "title": "Potential SolidPDFCreator.DLL Sideloading",
  "rule_id": "a2edbce1-95c8-4291-8676-0d45146862b3",
  "description": "Detects potential DLL sideloading of \"SolidPDFCreator.dll\"",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.persistence",
    "attack.defense-evasion",
    "attack.privilege-escalation",
    "attack.t1574.001"
  ],
  "category": "image_load",
  "rule_file": "rules/windows/image_load/image_load_side_load_solidpdfcreator.yml",
  "sources": [
    "sysmon_image_load"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ImageLoaded",
          "operator": "endswith",
          "values": [
            "\\SolidPDFCreator.dll"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_path": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\SolidPDFCreator.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "ImageLoaded",
          "operator": "startswith",
          "values": [
            "C:\\Program Files (x86)\\SolidDocuments\\SolidPDFCreator\\",
            "C:\\Program Files\\SolidDocuments\\SolidPDFCreator\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_main_*"
        }
      }
    ]
  }
}