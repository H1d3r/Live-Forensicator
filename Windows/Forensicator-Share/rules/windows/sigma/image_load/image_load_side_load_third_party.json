{
  "title": "Third Party Software DLL Sideloading",
  "rule_id": "f9df325d-d7bc-4a32-8a1a-2cc61dcefc63",
  "description": "Detects DLL sideloading of DLLs that are part of third party software (zoom, discord....etc)",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.persistence",
    "attack.privilege-escalation",
    "attack.t1574.001"
  ],
  "category": "image_load",
  "rule_file": "rules/windows/image_load/image_load_side_load_third_party.yml",
  "sources": [
    "sysmon_image_load"
  ],
  "items": {
    "selection_lenovo": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ImageLoaded",
          "operator": "endswith",
          "values": [
            "\\commfunc.dll"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_lenovo": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "ImageLoaded",
              "operator": "contains",
              "values": [
                "\\AppData\\local\\Google\\Chrome\\Application\\"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "ImageLoaded",
              "operator": "startswith",
              "values": [
                "C:\\Program Files\\Lenovo\\Communications Utility\\",
                "C:\\Program Files (x86)\\Lenovo\\Communications Utility\\"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_toshiba": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ImageLoaded",
          "operator": "endswith",
          "values": [
            "\\tosbtkbd.dll"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_toshiba": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ImageLoaded",
          "operator": "startswith",
          "values": [
            "C:\\Program Files\\Toshiba\\Bluetooth Toshiba Stack\\",
            "C:\\Program Files (x86)\\Toshiba\\Bluetooth Toshiba Stack\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "any",
    "children": [
      {
        "type": "all",
        "children": [
          {
            "type": "item_ref",
            "name": "selection_lenovo"
          },
          {
            "type": "not",
            "child": {
              "type": "item_ref",
              "name": "filter_lenovo"
            }
          }
        ]
      },
      {
        "type": "all",
        "children": [
          {
            "type": "item_ref",
            "name": "selection_toshiba"
          },
          {
            "type": "not",
            "child": {
              "type": "item_ref",
              "name": "filter_toshiba"
            }
          }
        ]
      }
    ]
  }
}