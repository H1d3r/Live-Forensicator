{
  "title": "Potential Wazuh Security Platform DLL Sideloading",
  "rule_id": "db77ce78-7e28-4188-9337-cf30e2b3ba9f",
  "description": "Detects potential DLL side loading of DLLs that are part of the Wazuh security platform",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.persistence",
    "attack.privilege-escalation",
    "attack.t1574.001"
  ],
  "category": "image_load",
  "rule_file": "rules/windows/image_load/image_load_side_load_wazuh.yml",
  "sources": [
    "sysmon_image_load"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ImageLoaded",
          "operator": "endswith",
          "values": [
            "\\libwazuhshared.dll",
            "\\libwinpthread-1.dll"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_generic": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ImageLoaded",
          "operator": "startswith",
          "values": [
            "C:\\Program Files\\",
            "C:\\Program Files (x86)\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_optional_mingw64": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ImageLoaded",
          "operator": "contains",
          "values": [
            "\\AppData\\Local\\",
            "\\ProgramData\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "ImageLoaded",
          "operator": "endswith",
          "values": [
            "\\mingw64\\bin\\libwinpthread-1.dll"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_main_*"
        }
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_optional_*"
        }
      }
    ]
  }
}