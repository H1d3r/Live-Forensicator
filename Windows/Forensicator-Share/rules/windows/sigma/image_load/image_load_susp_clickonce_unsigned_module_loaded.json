{
  "title": "Unsigned Module Loaded by ClickOnce Application",
  "rule_id": "060d5ad4-3153-47bb-8382-43e5e29eda92",
  "description": "Detects unsigned module load by ClickOnce application.",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.privilege-escalation",
    "attack.defense-evasion",
    "attack.persistence",
    "attack.t1574.001"
  ],
  "category": "image_load",
  "rule_file": "rules/windows/image_load/image_load_susp_clickonce_unsigned_module_loaded.yml",
  "sources": [
    "sysmon_image_load"
  ],
  "items": {
    "selection_path": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "contains",
          "values": [
            "\\AppData\\Local\\Apps\\2.0\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_sig_status": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Signed",
              "operator": "exact",
              "values": [
                "false"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "SignatureStatus",
              "operator": "exact",
              "values": [
                "Expired"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}