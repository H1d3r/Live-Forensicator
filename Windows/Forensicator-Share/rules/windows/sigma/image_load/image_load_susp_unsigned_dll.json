{
  "title": "Unsigned DLL Loaded by Windows Utility",
  "rule_id": "b5de0c9a-6f19-43e0-af4e-55ad01f550af",
  "description": "Detects windows utilities loading an unsigned or untrusted DLL.\nAdversaries often abuse those programs to proxy execution of malicious code.\n",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.t1218.011",
    "attack.t1218.010",
    "attack.defense-evasion"
  ],
  "category": "image_load",
  "rule_file": "rules/windows/image_load/image_load_susp_unsigned_dll.yml",
  "sources": [
    "sysmon_image_load"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\InstallUtil.exe",
            "\\RegAsm.exe",
            "\\RegSvcs.exe",
            "\\regsvr32.exe",
            "\\rundll32.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_signed": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Signed",
          "operator": "exact",
          "values": [
            "true"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_sig_status": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "SignatureStatus",
          "operator": "exact",
          "values": [
            "errorChaining",
            "errorCode_endpoint",
            "errorExpired",
            "trusted",
            "Valid"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_signed_null": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Signed",
          "operator": "is_null",
          "values": [],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_signed_empty": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Signed",
          "operator": "exact",
          "values": [
            "",
            "-"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_sig_status_null": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "SignatureStatus",
          "operator": "is_null",
          "values": [],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_sig_status_empty": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "SignatureStatus",
          "operator": "exact",
          "values": [
            "",
            "-"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_windows_installer": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "exact",
          "values": [
            "C:\\Windows\\SysWOW64\\rundll32.exe",
            "C:\\Windows\\System32\\rundll32.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "ImageLoaded",
          "operator": "startswith",
          "values": [
            "C:\\Windows\\Installer\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "ImageLoaded",
          "operator": "endswith",
          "values": [
            ".tmp-\\Microsoft.Deployment.WindowsInstaller.dll",
            ".tmp-\\Avira.OE.Setup.CustomActions.dll"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_assembly": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "startswith",
          "values": [
            "C:\\Windows\\SysWOW64\\",
            "C:\\Windows\\System32\\",
            "C:\\Windows\\Microsoft.NET\\Framework64"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\RegAsm.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "ImageLoaded",
          "operator": "endswith",
          "values": [
            ".dll"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "ImageLoaded",
          "operator": "startswith",
          "values": [
            "C:\\Windows\\assembly\\NativeImages"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_optional_klite_codec": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "exact",
          "values": [
            "C:\\Windows\\SysWOW64\\regsvr32.exe",
            "C:\\Windows\\System32\\regsvr32.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "ImageLoaded",
          "operator": "startswith",
          "values": [
            "C:\\Program Files (x86)\\K-Lite Codec Pack\\",
            "C:\\Program Files\\K-Lite Codec Pack\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_main_*"
        }
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_optional_*"
        }
      }
    ]
  }
}