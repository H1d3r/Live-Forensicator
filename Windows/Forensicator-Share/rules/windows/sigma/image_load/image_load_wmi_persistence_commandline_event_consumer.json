{
  "title": "WMI Persistence - Command Line Event Consumer",
  "rule_id": "05936ce2-ee05-4dae-9d03-9a391cf2d2c6",
  "description": "Detects WMI command line event consumers",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.privilege-escalation",
    "attack.t1546.003",
    "attack.persistence"
  ],
  "category": "image_load",
  "rule_file": "rules/windows/image_load/image_load_wmi_persistence_commandline_event_consumer.yml",
  "sources": [
    "sysmon_image_load"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "exact",
          "values": [
            "C:\\Windows\\System32\\wbem\\WmiPrvSE.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "ImageLoaded",
          "operator": "endswith",
          "values": [
            "\\wbemcons.dll"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}