{
  "title": "Network Connection Initiated By AddinUtil.EXE",
  "rule_id": "5205613d-2a63-4412-a895-3a2458b587b3",
  "description": "Detects a network connection initiated by the Add-In deployment cache updating utility \"AddInutil.exe\".\nThis could indicate a potential command and control communication as this tool doesn't usually initiate network activity.\n",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1218"
  ],
  "category": "network_connection",
  "rule_file": "rules/windows/network_connection/net_connection_win_addinutil_initiated.yml",
  "sources": [
    "sysmon_network_connection"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Initiated",
          "operator": "exact",
          "values": [
            "true"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\addinutil.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}