{
  "title": "Network Connection Initiated To AzureWebsites.NET By Non-Browser Process",
  "rule_id": "5c80b618-0dbb-46e6-acbb-03d90bcb6d83",
  "description": "Detects an initiated network connection by a non browser process on the system to \"azurewebsites.net\". The latter was often used by threat actors as a malware hosting and exfiltration site.\n",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.command-and-control",
    "attack.t1102",
    "attack.t1102.001"
  ],
  "category": "network_connection",
  "rule_file": "rules/windows/network_connection/net_connection_win_domain_azurewebsites.yml",
  "sources": [
    "sysmon_network_connection"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Initiated",
          "operator": "exact",
          "values": [
            "true"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "DestinationHostname",
          "operator": "endswith",
          "values": [
            "azurewebsites.net"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_chrome": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
