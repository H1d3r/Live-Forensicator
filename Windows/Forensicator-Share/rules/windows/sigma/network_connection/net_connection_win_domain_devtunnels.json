{
  "title": "Network Connection Initiated To DevTunnels Domain",
  "rule_id": "9501f8e6-8e3d-48fc-a8a6-1089dd5d7ef4",
  "description": "Detects network connections to Devtunnels domains initiated by a process on a system. Attackers can abuse that feature to establish a reverse shell or persistence on a machine.\n",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.exfiltration",
    "attack.command-and-control",
    "attack.t1567.001",
    "attack.t1572"
  ],
  "category": "network_connection",
  "rule_file": "rules/windows/network_connection/net_connection_win_domain_devtunnels.yml",
  "sources": [
    "sysmon_network_connection"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Initiated",
          "operator": "exact",
          "values": [
            "true"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "DestinationHostname",
          "operator": "endswith",
          "values": [
            ".devtunnels.ms"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}