{
  "title": "Suspicious Dropbox API Usage",
  "rule_id": "25eabf56-22f0-4915-a1ed-056b8dae0a68",
  "description": "Detects an executable that isn't dropbox but communicates with the Dropbox API",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.command-and-control",
    "attack.exfiltration",
    "attack.t1105",
    "attack.t1567.002"
  ],
  "category": "network_connection",
  "rule_file": "rules/windows/network_connection/net_connection_win_domain_dropbox_api.yml",
  "sources": [
    "sysmon_network_connection"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Initiated",
          "operator": "exact",
          "values": [
            "true"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "DestinationHostname",
          "operator": "endswith",
          "values": [
            "api.dropboxapi.com",
            "content.dropboxapi.com"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_legit_dropbox": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "contains",
          "values": [
            "\\Dropbox"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_main_*"
        }
      }
    ]
  }
}