{
  "title": "Suspicious Network Connection to IP Lookup Service APIs",
  "rule_id": "edf3485d-dac4-4d50-90e4-b0e5813f7e60",
  "description": "Detects external IP address lookups by non-browser processes via services such as \"api.ipify.org\". This could be indicative of potential post compromise internet test activity.",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.discovery",
    "attack.t1016"
  ],
  "category": "network_connection",
  "rule_file": "rules/windows/network_connection/net_connection_win_domain_external_ip_lookup.yml",
  "sources": [
    "sysmon_network_connection"
  ],
  "items": {
    "selection": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "DestinationHostname",
              "operator": "exact",
              "values": [
                "www.ip.cn",
                "l2.io"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "DestinationHostname",
              "operator": "contains",
              "values": [
                "api.2ip.ua",
                "api.bigdatacloud.net",
                "api.ipify.org",
                "bot.whatismyipaddress.com",
                "canireachthe.net",
                "checkip.amazonaws.com",
                "checkip.dyndns.org",
                "curlmyip.com",
                "db-ip.com",
                "edns.ip-api.com",
                "eth0.me",
                "freegeoip.app",
                "geoipy.com",
                "getip.pro",
                "icanhazip.com",
                "ident.me",
                "ifconfig.io",
                "ifconfig.me",
                "ip-api.com",
                "ip.360.cn",
                "ip.anysrc.net",
                "ip.taobao.com",
                "ip.tyk.nu",
                "ipaddressworld.com",
                "ipapi.co",
                "ipconfig.io",
                "ipecho.net",
                "ipinfo.io",
                "ipip.net",
                "ipof.in",
                "ipv4.icanhazip.com",
                "ipv4bot.whatismyipaddress.com",
                "ipv6-test.com",
                "ipwho.is",
                "jsonip.com",
                "myexternalip.com",
                "seeip.org",
                "wgetip.com",
                "whatismyip.akamai.com",
                "whois.pconline.com.cn",
                "wtfismyip.com"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "filter_optional_brave": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\brave.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_optional_chrome": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "exact",
          "values": [
            "C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe",
            "C:\\Program Files (x86)\\Google\\Chrome\\Application\\chrome.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_optional_firefox": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "exact",
          "values": [
            "C:\\Program Files\\Mozilla Firefox\\firefox.exe",
            "C:\\Program Files (x86)\\Mozilla Firefox\\firefox.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_optional_ie": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "exact",
          "values": [
            "C:\\Program Files (x86)\\Internet Explorer\\iexplore.exe",
            "C:\\Program Files\\Internet Explorer\\iexplore.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_optional_maxthon": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\maxthon.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_optional_edge_1": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "startswith",
              "values": [
                "C:\\Program Files (x86)\\Microsoft\\EdgeWebView\\Application\\"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\WindowsApps\\MicrosoftEdge.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "exact",
              "values": [
                "C:\\Program Files (x86)\\Microsoft\\Edge\\Application\\msedge.exe",
                "C:\\Program Files\\Microsoft\\Edge\\Application\\msedge.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "filter_optional_edge_2": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "startswith",
          "values": [
            "C:\\Program Files (x86)\\Microsoft\\EdgeCore\\",
            "C:\\Program Files\\Microsoft\\EdgeCore\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\msedge.exe",
            "\\msedgewebview2.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_optional_opera": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\opera.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_optional_safari": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\safari.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_optional_seamonkey": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\seamonkey.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_optional_vivaldi": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\vivaldi.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_optional_whale": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\whale.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_optional_*"
        }
      }
    ]
  }
}