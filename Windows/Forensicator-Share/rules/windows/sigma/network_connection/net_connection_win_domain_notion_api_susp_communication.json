        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\safari.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_seamonkey": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\seamonkey.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
