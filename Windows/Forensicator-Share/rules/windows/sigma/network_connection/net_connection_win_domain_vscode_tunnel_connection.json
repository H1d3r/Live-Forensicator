{
  "title": "Network Connection Initiated To Visual Studio Code Tunnels Domain",
  "rule_id": "4b657234-038e-4ad5-997c-4be42340bce4",
  "description": "Detects network connections to Visual Studio Code tunnel domains initiated by a process on a system. Attackers can abuse that feature to establish a reverse shell or persistence on a machine.\n",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.exfiltration",
    "attack.command-and-control",
    "attack.t1567",
    "attack.t1572"
  ],
  "category": "network_connection",
  "rule_file": "rules/windows/network_connection/net_connection_win_domain_vscode_tunnel_connection.yml",
  "sources": [
    "sysmon_network_connection"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Initiated",
          "operator": "exact",
          "values": [
            "true"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "DestinationHostname",
          "operator": "endswith",
          "values": [
            ".tunnels.api.visualstudio.com"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}