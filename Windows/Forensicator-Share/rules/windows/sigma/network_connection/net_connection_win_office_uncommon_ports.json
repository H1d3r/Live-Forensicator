{
  "title": "Office Application Initiated Network Connection Over Uncommon Ports",
  "rule_id": "3b5ba899-9842-4bc2-acc2-12308498bf42",
  "description": "Detects an office suit application (Word, Excel, PowerPoint, Outlook) communicating to target systems over uncommon ports.",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.command-and-control"
  ],
  "category": "network_connection",
  "rule_file": "rules/windows/network_connection/net_connection_win_office_uncommon_ports.yml",
  "sources": [
    "sysmon_network_connection"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Initiated",
          "operator": "exact",
          "values": [
            "true"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\excel.exe",
            "\\outlook.exe",
            "\\powerpnt.exe",
            "\\winword.exe",
            "\\wordview.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_common_ports": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "DestinationPort",
          "operator": "exact",
          "values": [
            "53",
            "80",
            "139",
            "389",
            "443",
            "445",
            "3268"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_outlook_ports": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "contains",
          "values": [
            ":\\Program Files\\Microsoft Office\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\OUTLOOK.EXE"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "DestinationPort",
          "operator": "exact",
          "values": [
            "143",
            "465",
            "587",
            "993",
            "995"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_main_*"
        }
      }
    ]
  }
}