{
  "title": "RDP Over Reverse SSH Tunnel",
  "rule_id": "5f699bc5-5446-4a4a-a0b7-5ef2885a3eb4",
  "description": "Detects svchost hosting RDP termsvcs communicating with the loopback address and on TCP port 3389",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.command-and-control",
    "attack.t1572",
    "attack.lateral-movement",
    "attack.t1021.001",
    "car.2013-07-002"
  ],
  "category": "network_connection",
  "rule_file": "rules/windows/network_connection/net_connection_win_rdp_reverse_tunnel.yml",
  "sources": [
    "sysmon_network_connection"
  ],
  "items": {
    "selection_img": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\svchost.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Initiated",
          "operator": "exact",
          "values": [
            "true"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "SourcePort",
          "operator": "exact",
          "values": [
            "3389"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_destination": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "DestinationIp",
          "operator": "cidr",
          "values": [
            "127.0.0.0/8",
            "::1/128"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}