{
  "title": "Network Connection Initiated By Regsvr32.EXE",
  "rule_id": "c7e91a02-d771-4a6d-a700-42587e0b1095",
  "description": "Detects a network connection initiated by \"Regsvr32.exe\"",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1559.001",
    "attack.defense-evasion",
    "attack.t1218.010"
  ],
  "category": "network_connection",
  "rule_file": "rules/windows/network_connection/net_connection_win_regsvr32_network_activity.yml",
  "sources": [
    "sysmon_network_connection"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Initiated",
          "operator": "exact",
          "values": [
            "true"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\regsvr32.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}