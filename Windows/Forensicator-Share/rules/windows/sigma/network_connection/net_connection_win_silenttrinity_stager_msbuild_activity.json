{
  "title": "Silenttrinity Stager Msbuild Activity",
  "rule_id": "50e54b8d-ad73-43f8-96a1-5191685b17a4",
  "description": "Detects a possible remote connections to Silenttrinity c2",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.defense-evasion",
    "attack.t1127.001"
  ],
  "category": "network_connection",
  "rule_file": "rules/windows/network_connection/net_connection_win_silenttrinity_stager_msbuild_activity.yml",
  "sources": [
    "sysmon_network_connection"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\msbuild.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "DestinationPort",
          "operator": "exact",
          "values": [
            "80",
            "443"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Initiated",
          "operator": "exact",
          "values": [
            "true"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "item_ref",
        "name": "filter"
      }
    ]
  }
}