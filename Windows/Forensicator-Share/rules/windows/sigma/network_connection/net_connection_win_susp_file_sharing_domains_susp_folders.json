{
  "title": "Network Communication Initiated To File Sharing Domains From Process Located In Suspicious Folder",
  "rule_id": "e0f8ab85-0ac9-423b-a73a-81b3c7b1aa97",
  "description": "Detects executables located in potentially suspicious directories initiating network connections towards file sharing domains.",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.command-and-control",
    "attack.t1105"
  ],
  "category": "network_connection",
  "rule_file": "rules/windows/network_connection/net_connection_win_susp_file_sharing_domains_susp_folders.yml",
  "sources": [
    "sysmon_network_connection"
  ],
  "items": {
    "selection_paths": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "contains",
          "values": [
            ":\\$Recycle.bin",
            ":\\Perflogs\\",
            ":\\Temp\\",
            ":\\Users\\Default\\",
            ":\\Users\\Public\\",
            ":\\Windows\\Fonts\\",
            ":\\Windows\\IME\\",
            ":\\Windows\\System32\\Tasks\\",
            ":\\Windows\\Tasks\\",
            ":\\Windows\\Temp\\",
            "\\AppData\\Temp\\",
            "\\config\\systemprofile\\",
            "\\Windows\\addins\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_domains": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Initiated",
          "operator": "exact",
          "values": [
            "true"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "DestinationHostname",
          "operator": "endswith",
          "values": [
            ".githubusercontent.com",
            "anonfiles.com",
            "cdn.discordapp.com",
            "ddns.net",
            "dl.dropboxusercontent.com",
            "ghostbin.co",
            "github.com",
            "glitch.me",
            "gofile.io",
            "hastebin.com",
            "mediafire.com",
            "mega.co.nz",
            "mega.nz",
            "onrender.com",
            "pages.dev",
            "paste.ee",
            "pastebin.com",
            "pastebin.pl",
            "pastetext.net",
            "pixeldrain.com",
            "privatlab.com",
            "privatlab.net",
            "send.exploit.in",
            "sendspace.com",
            "storage.googleapis.com",
            "storjshare.io",
            "supabase.co",
            "temp.sh",
            "transfer.sh",
            "trycloudflare.com",
            "ufile.io",
            "w3spaces.com",
            "workers.dev"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}