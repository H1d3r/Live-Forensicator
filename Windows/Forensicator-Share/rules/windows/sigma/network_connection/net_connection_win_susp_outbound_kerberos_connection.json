{
  "title": "Uncommon Outbound Kerberos Connection",
  "rule_id": "e54979bd-c5f9-4d6c-967b-a04b19ac4c74",
  "description": "Detects uncommon outbound network activity via Kerberos default port indicating possible lateral movement or first stage PrivEsc via delegation.\n",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.credential-access",
    "attack.t1558",
    "attack.lateral-movement",
    "attack.t1550.003"
  ],
  "category": "network_connection",
  "rule_file": "rules/windows/network_connection/net_connection_win_susp_outbound_kerberos_connection.yml",
  "sources": [
    "sysmon_network_connection"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "DestinationPort",
          "operator": "exact",
          "values": [
            "88"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Initiated",
          "operator": "exact",
          "values": [
            "true"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_lsass": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "exact",
          "values": [
            "C:\\Windows\\System32\\lsass.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_optional_chrome": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "exact",
          "values": [
            "C:\\Program Files (x86)\\Google\\Chrome\\Application\\chrome.exe",
            "C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_optional_firefox": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "exact",
          "values": [
            "C:\\Program Files (x86)\\Mozilla Firefox\\firefox.exe",
            "C:\\Program Files\\Mozilla Firefox\\firefox.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_optional_tomcat": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\tomcat\\bin\\tomcat8.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_main_*"
        }
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_optional_*"
        }
      }
    ]
  }
}