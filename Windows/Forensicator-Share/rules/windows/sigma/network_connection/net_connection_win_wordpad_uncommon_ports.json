{
  "title": "Suspicious Wordpad Outbound Connections",
  "rule_id": "786cdae8-fefb-4eb2-9227-04e34060db01",
  "description": "Detects a network connection initiated by \"wordpad.exe\" over uncommon destination ports.\nThis might indicate potential process injection activity from a beacon or similar mechanisms.\n",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.command-and-control"
  ],
  "category": "network_connection",
  "rule_file": "rules/windows/network_connection/net_connection_win_wordpad_uncommon_ports.yml",
  "sources": [
    "sysmon_network_connection"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Initiated",
          "operator": "exact",
          "values": [
            "true"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\wordpad.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_ports": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "DestinationPort",
          "operator": "exact",
          "values": [
            "80",
            "139",
            "443",
            "445",
            "465",
            "587",
            "993",
            "995"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_main_*"
        }
      }
    ]
  }
}