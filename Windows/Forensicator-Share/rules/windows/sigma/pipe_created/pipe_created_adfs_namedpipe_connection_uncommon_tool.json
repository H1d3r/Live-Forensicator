{
  "title": "ADFS Database Named Pipe Connection By Uncommon Tool",
  "rule_id": "1ea13e8c-03ea-409b-877d-ce5c3d2c1cb3",
  "description": "Detects suspicious local connections via a named pipe to the AD FS configuration database (Windows Internal Database).\nUsed to access information such as the AD FS configuration settings which contains sensitive information used to sign SAML tokens.\n",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.collection",
    "attack.t1005"
  ],
  "category": "pipe_created",
  "rule_file": "rules/windows/pipe_created/pipe_created_adfs_namedpipe_connection_uncommon_tool.yml",
  "sources": [
    "sysmon_pipe_created"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "PipeName",
          "operator": "exact",
          "values": [
            "\\MICROSOFT##WID\\tsql\\query"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_generic": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            ":\\Windows\\System32\\mmc.exe",
            ":\\Windows\\system32\\svchost.exe",
            ":\\Windows\\System32\\wsmprovhost.exe",
            ":\\Windows\\SysWOW64\\mmc.exe",
            ":\\Windows\\SysWOW64\\wsmprovhost.exe",
            ":\\Windows\\WID\\Binn\\sqlwriter.exe",
            "\\AzureADConnect.exe",
            "\\Microsoft.Identity.Health.Adfs.PshSurrogate.exe",
            "\\Microsoft.IdentityServer.ServiceHost.exe",
            "\\Microsoft.Tri.Sensor.exe",
            "\\sqlservr.exe",
            "\\tssdis.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_main_*"
        }
      }
    ]
  }
}