{
  "title": "CobaltStrike Named Pipe",
  "rule_id": "d5601f8c-b26f-4ab0-9035-69e11a8d4ad2",
  "description": "Detects the creation of a named pipe as used by CobaltStrike",
  "level": "critical",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.privilege-escalation",
    "attack.t1055"
  ],
  "category": "pipe_created",
  "rule_file": "rules/windows/pipe_created/pipe_created_hktl_cobaltstrike.yml",
  "sources": [
    "sysmon_pipe_created"
  ],
  "items": {
    "selection_MSSE": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "PipeName",
          "operator": "contains",
          "values": [
            "\\MSSE-",
            "-server"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_postex": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "PipeName",
          "operator": "startswith",
          "values": [
            "\\postex_"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_status": {
