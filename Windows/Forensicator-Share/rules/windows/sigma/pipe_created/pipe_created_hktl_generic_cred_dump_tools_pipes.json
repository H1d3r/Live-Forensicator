{
  "title": "HackTool - Credential Dumping Tools Named Pipe Created",
  "rule_id": "961d0ba2-3eea-4303-a930-2cf78bbfcc5e",
  "description": "Detects well-known credential dumping tools execution via specific named pipe creation",
  "level": "critical",
  "status": "test",
  "tags": [
    "attack.credential-access",
    "attack.t1003.001",
    "attack.t1003.002",
    "attack.t1003.004",
    "attack.t1003.005"
  ],
  "category": "pipe_created",
  "rule_file": "rules/windows/pipe_created/pipe_created_hktl_generic_cred_dump_tools_pipes.yml",
  "sources": [
    "sysmon_pipe_created"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "PipeName",
          "operator": "contains",
          "values": [
            "\\cachedump",
            "\\lsadump",
            "\\wceservicepipe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}