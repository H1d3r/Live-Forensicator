{
  "title": "HackTool - Koh Default Named Pipe",
  "rule_id": "0adc67e0-a68f-4ffd-9c43-28905aad5d6a",
  "description": "Detects creation of default named pipes used by the Koh tool",
  "level": "critical",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.privilege-escalation",
    "attack.credential-access",
    "attack.t1528",
    "attack.t1134.001"
  ],
  "category": "pipe_created",
  "rule_file": "rules/windows/pipe_created/pipe_created_hktl_koh_default_pipe.yml",
  "sources": [
    "sysmon_pipe_created"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "PipeName",
          "operator": "contains",
          "values": [
            "\\imposecost",
            "\\imposingcost"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}