{
  "title": "PUA - PAExec Default Named Pipe",
  "rule_id": "f6451de4-df0a-41fa-8d72-b39f54a08db5",
  "description": "Detects PAExec default named pipe",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1569.002"
  ],
  "category": "pipe_created",
  "rule_file": "rules/windows/pipe_created/pipe_created_pua_paexec_default_pipe.yml",
  "sources": [
    "sysmon_pipe_created"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "PipeName",
          "operator": "startswith",
          "values": [
            "\\PAExec"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}