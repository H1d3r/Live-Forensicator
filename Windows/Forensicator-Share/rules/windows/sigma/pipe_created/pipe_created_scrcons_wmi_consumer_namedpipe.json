{
  "title": "WMI Event Consumer Created Named Pipe",
  "rule_id": "493fb4ab-cdcc-4c4f-818c-0e363bd1e4bb",
  "description": "Detects the WMI Event Consumer service scrcons.exe creating a named pipe",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.t1047",
    "attack.execution"
  ],
  "category": "pipe_created",
  "rule_file": "rules/windows/pipe_created/pipe_created_scrcons_wmi_consumer_namedpipe.yml",
  "sources": [
    "sysmon_pipe_created"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\scrcons.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}