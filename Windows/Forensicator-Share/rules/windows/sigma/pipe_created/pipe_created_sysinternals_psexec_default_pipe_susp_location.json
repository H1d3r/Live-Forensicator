{
  "title": "PsExec Tool Execution From Suspicious Locations - PipeName",
  "rule_id": "41504465-5e3a-4a5b-a5b4-2a0baadd4463",
  "description": "Detects PsExec default pipe creation where the image executed is located in a suspicious location. Which could indicate that the tool is being used in an attack",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1569.002",
    "attack.s0029"
  ],
  "category": "pipe_created",
  "rule_file": "rules/windows/pipe_created/pipe_created_sysinternals_psexec_default_pipe_susp_location.yml",
  "sources": [
    "sysmon_pipe_created"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "PipeName",
          "operator": "exact",
          "values": [
            "\\PSEXESVC"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Image",
          "operator": "contains",
          "values": [
            ":\\Users\\Public\\",
            ":\\Windows\\Temp\\",
            "\\AppData\\Local\\Temp\\",
            "\\Desktop\\",
            "\\Downloads\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}