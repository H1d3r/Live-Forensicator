{
  "title": "Clear PowerShell History - PowerShell Module",
  "rule_id": "f99276ad-d122-4989-a09a-d00904a5f9d2",
  "description": "Detects keywords that could indicate clearing PowerShell history",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1070.003"
  ],
  "category": "ps_module",
  "rule_file": "rules/windows/powershell/powershell_module/posh_pm_clear_powershell_history.yml",
  "sources": [
    "powershell_module_logging"
  ],
  "items": {
    "selection_1a_payload": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Payload",
          "operator": "contains",
          "values": [
            "del",
            "Remove-Item",
            "rm"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_1b_payload": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Payload",
          "operator": "contains",
          "values": [
            "(Get-PSReadlineOption).HistorySavePath"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_payload_2": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Payload",
          "operator": "contains",
          "values": [
            "Set-PSReadlineOption",
            "\u2013HistorySaveStyle",
            "SaveNothing"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_payload_3": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Payload",
          "operator": "contains",
          "values": [
            "Set-PSReadlineOption",
            "-HistorySaveStyle",
            "SaveNothing"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "any",
    "children": [
      {
        "type": "wildcard_ref",
        "mode": "any",
        "pattern": "selection_payload_*"
      },
      {
        "type": "wildcard_ref",
        "mode": "all",
        "pattern": "selection_1*"
      }
    ]
  }
}