{
  "title": "Invoke-Obfuscation CLIP+ Launcher - PowerShell Module",
  "rule_id": "a136cde0-61ad-4a61-9b82-8dc490e60dd2",
  "description": "Detects Obfuscated use of Clip.exe to execute PowerShell",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1027",
    "attack.execution",
    "attack.t1059.001"
  ],
  "category": "ps_module",
  "rule_file": "rules/windows/powershell/powershell_module/posh_pm_invoke_obfuscation_clip.yml",
  "sources": [
    "powershell_module_logging"
  ],
  "items": {
    "selection_4103": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Payload",
          "operator": "re",
          "values": [
            "cmd.{0,5}(?:/c|/r).+clip(?:\\.exe)?.{0,4}&&.+clipboard]::\\(\\s\\\\\"\\{\\d\\}.+-f.+\""
          ],
          "match": "any",
          "windash": false,
          "ignore_case": false
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection_4103"
  }
}