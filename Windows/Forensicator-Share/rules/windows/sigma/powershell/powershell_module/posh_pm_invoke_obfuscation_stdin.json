  "rule_id": "9ac8b09b-45de-4a07-9da1-0de8c09304a3",
  "description": "Detects Obfuscated use of stdin to execute PowerShell",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1027",
    "attack.execution",
    "attack.t1059.001"
  ],
  "category": "ps_module",
  "rule_file": "rules/windows/powershell/powershell_module/posh_pm_invoke_obfuscation_stdin.yml",
  "sources": [
