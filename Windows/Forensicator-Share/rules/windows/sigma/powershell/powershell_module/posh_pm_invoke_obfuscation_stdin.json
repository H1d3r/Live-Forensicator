  ],
  "items": {
    "selection_4103": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Payload",
          "operator": "re",
          "values": [
            "cmd.{0,5}(?:/c|/r).+powershell.+(?:\\$\\{?input\\}?|noexit).+\""
