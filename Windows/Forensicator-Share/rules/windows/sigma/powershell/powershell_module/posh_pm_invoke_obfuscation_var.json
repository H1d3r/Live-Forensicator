  "items": {
    "selection_4103": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Payload",
          "operator": "re",
          "values": [
            "cmd.{0,5}(?:/c|/r)(?:\\s|)\"set\\s[a-zA-Z]{3,6}.*(?:\\{\\d\\}){1,}\\\\\"\\s+?-f(?:.*\\)){1,}.*\""
          ],
          "match": "any",
          "windash": false,
          "ignore_case": false
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection_4103"
