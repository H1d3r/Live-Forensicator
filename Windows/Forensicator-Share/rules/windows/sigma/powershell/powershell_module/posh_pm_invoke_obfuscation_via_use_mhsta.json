{
  "title": "Invoke-Obfuscation Via Use MSHTA - PowerShell Module",
  "rule_id": "07ad2ea8-6a55-4ac6-bf3e-91b8e59676eb",
  "description": "Detects Obfuscated Powershell via use MSHTA in Scripts",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1027",
    "attack.execution",
    "attack.t1059.001"
  ],
  "category": "ps_module",
  "rule_file": "rules/windows/powershell/powershell_module/posh_pm_invoke_obfuscation_via_use_mhsta.yml",
  "sources": [
    "powershell_module_logging"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Payload",
          "operator": "contains",
          "values": [
            "set",
            "&&",
            "mshta",
            "vbscript:createobject",
            ".run",
            "(window.close)"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}