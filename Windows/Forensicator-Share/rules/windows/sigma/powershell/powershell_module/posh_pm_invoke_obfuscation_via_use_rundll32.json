        {
          "type": "field",
          "field": "Payload",
          "operator": "contains",
          "values": [
            "value",
            "invoke",
            "comspec",
            "iex"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
