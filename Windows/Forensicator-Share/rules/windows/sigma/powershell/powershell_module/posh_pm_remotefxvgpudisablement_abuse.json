{
  "title": "Potential RemoteFXvGPUDisablement.EXE Abuse - PowerShell Module",
  "rule_id": "38a7625e-b2cb-485d-b83d-aff137d859f4",
  "description": "Detects PowerShell module creation where the module Contents are set to \"function Get-VMRemoteFXPhysicalVideoAdapter\". This could be a sign of potential abuse of the \"RemoteFXvGPUDisablement.exe\" binary which is known to be vulnerable to module load-order hijacking.",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1218"
  ],
  "category": "ps_module",
  "rule_file": "rules/windows/powershell/powershell_module/posh_pm_remotefxvgpudisablement_abuse.yml",
  "sources": [
    "powershell_module_logging"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Payload",
          "operator": "contains",
          "values": [
            "ModuleContents=function Get-VMRemoteFXPhysicalVideoAdapter {"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}