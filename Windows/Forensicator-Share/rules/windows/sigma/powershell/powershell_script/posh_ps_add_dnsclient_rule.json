{
  "title": "Powershell Add Name Resolution Policy Table Rule",
  "rule_id": "4368354e-1797-463c-bc39-a309effbe8d7",
  "description": "Detects powershell scripts that adds a Name Resolution Policy Table (NRPT) rule for the specified namespace.\nThis will bypass the default DNS server and uses a specified server for answering the query.\n",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.impact",
    "attack.t1565"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_add_dnsclient_rule.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Add-DnsClientNrptRule",
            "-Namesp",
            "-NameSe"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}