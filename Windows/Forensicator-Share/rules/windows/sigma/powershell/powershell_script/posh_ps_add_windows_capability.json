{
  "title": "Add Windows Capability Via PowerShell Script",
  "rule_id": "155c7fd5-47b4-49b2-bbeb-eb4fab335429",
  "description": "Detects usage of the \"Add-WindowsCapability\" cmdlet to add Windows capabilities. Notable capabilities could be \"OpenSSH\" and others.",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.execution"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_add_windows_capability.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection_cmdlet": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Add-WindowsCapability "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_capa": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "-Name OpenSSH."
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}