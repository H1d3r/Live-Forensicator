{
  "title": "Potential AMSI Bypass Script Using NULL Bits",
  "rule_id": "fa2559c8-1197-471d-9cdd-05a0273d4522",
  "description": "Detects usage of special strings/null bits in order to potentially bypass AMSI functionalities",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1562.001"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_amsi_null_bits_bypass.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "if(0){{{0}}}' -f $(0 -as [char]) +",
            "#<NULL>"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}