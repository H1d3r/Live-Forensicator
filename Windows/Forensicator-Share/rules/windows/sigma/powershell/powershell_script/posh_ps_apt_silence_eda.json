{
  "title": "Silence.EDA Detection",
  "rule_id": "3ceb2083-a27f-449a-be33-14ec1b7cc973",
  "description": "Detects Silence EmpireDNSAgent as described in the Group-IP report",
  "level": "critical",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1059.001",
    "attack.command-and-control",
    "attack.t1071.004",
    "attack.t1572",
    "attack.impact",
    "attack.t1529",
    "attack.g0091",
    "attack.s0363"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_apt_silence_eda.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "empire": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "System.Diagnostics.Process",
            "Stop-Computer",
            "Restart-Computer",
            "Exception in execution",
            "$cmdargs",
            "Close-Dnscat2Tunnel"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "dnscat": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "set type=$LookupType`nserver",
            "$Command | nslookup 2>&1 | Out-String",
            "New-RandomDNSField",
            "[Convert]::ToString($SYNOptions, 16)",
            "$Session.Dead = $True",
            "$Session[\"Driver\"] -eq"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "empire"
      },
      {
        "type": "item_ref",
        "name": "dnscat"
      }
    ]
  }
}