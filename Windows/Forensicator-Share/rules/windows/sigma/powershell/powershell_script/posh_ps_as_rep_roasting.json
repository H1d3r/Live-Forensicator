{
  "title": "Get-ADUser Enumeration Using UserAccountControl Flags",
  "rule_id": "96c982fe-3d08-4df4-bed2-eb14e02f21c8",
  "description": "Detects AS-REP roasting is an attack that is often-overlooked. It is not very common as you have to explicitly set accounts that do not require pre-authentication.",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.discovery",
    "attack.t1033"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_as_rep_roasting.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Get-ADUser",
            "-Filter",
            "useraccountcontrol",
            "-band",
            "4194304"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}