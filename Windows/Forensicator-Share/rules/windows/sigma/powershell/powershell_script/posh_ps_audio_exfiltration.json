{
  "title": "Potential Data Exfiltration Via Audio File",
  "rule_id": "e4f93c99-396f-47c8-bb0f-201b1fa69034",
  "description": "Detects potential exfiltration attempt via audio file using PowerShell",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.exfiltration"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_audio_exfiltration.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection_main": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "[System.Math]::",
            "[IO.FileMode]::",
            "BinaryWriter"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_header_wav": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "0x52",
            "0x49",
            "0x46",
            "0x57",
            "0x41",
            "0x56",
            "0x45",
            "0xAC"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection_main"
      },
      {
        "type": "wildcard_ref",
        "mode": "any",
        "pattern": "selection_header_*"
      }
    ]
  }
}