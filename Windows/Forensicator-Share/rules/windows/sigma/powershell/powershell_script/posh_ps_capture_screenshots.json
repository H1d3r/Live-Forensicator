{
  "title": "Windows Screen Capture with CopyFromScreen",
  "rule_id": "d4a11f63-2390-411c-9adf-d791fd152830",
  "description": "Adversaries may attempt to take screen captures of the desktop to gather information over the course of an operation.\nScreen capturing functionality may be included as a feature of a remote access tool used in post-compromise operations\n",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.collection",
    "attack.t1113"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_capture_screenshots.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            ".CopyFromScreen"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}