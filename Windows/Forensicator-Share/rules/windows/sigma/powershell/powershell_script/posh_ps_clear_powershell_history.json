{
  "title": "Clear PowerShell History - PowerShell",
  "rule_id": "26b692dc-1722-49b2-b496-a8258aa6371d",
  "description": "Detects keywords that could indicate clearing PowerShell history",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1070.003"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_clear_powershell_history.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection1a": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "del",
            "Remove-Item",
            "rm"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection1b": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "(Get-PSReadlineOption).HistorySavePath"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_2": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Set-PSReadlineOption",
            "\u2013HistorySaveStyle",
            "SaveNothing"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_3": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Set-PSReadlineOption",
            "-HistorySaveStyle",
            "SaveNothing"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "any",
    "children": [
      {
        "type": "wildcard_ref",
        "mode": "any",
        "pattern": "selection_*"
      },
      {
        "type": "wildcard_ref",
        "mode": "all",
        "pattern": "selection1*"
      }
    ]
  }
}