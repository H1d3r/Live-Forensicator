{
  "title": "Clearing Windows Console History",
  "rule_id": "bde47d4b-9987-405c-94c7-b080410e8ea7",
  "description": "Identifies when a user attempts to clear console history. An adversary may clear the command history of a compromised account to conceal the actions undertaken during an intrusion.",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1070",
    "attack.t1070.003"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_clearing_windows_console_history.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection1": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Clear-History"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection2a": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Remove-Item",
            "rm"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection2b": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "ConsoleHost_history.txt",
            "(Get-PSReadlineOption).HistorySavePath"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "any",
    "children": [
      {
        "type": "item_ref",
        "name": "selection1"
      },
      {
        "type": "all",
        "children": [
          {
            "type": "item_ref",
            "name": "selection2a"
          },
          {
            "type": "item_ref",
            "name": "selection2b"
          }
        ]
      }
    ]
  }
}