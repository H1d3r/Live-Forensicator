{
  "title": "Create Volume Shadow Copy with Powershell",
  "rule_id": "afd12fed-b0ec-45c9-a13d-aa86625dac81",
  "description": "Adversaries may attempt to access or create a copy of the Active Directory domain database in order to steal credential information",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.credential-access",
    "attack.t1003.003",
    "attack.ds0005"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_create_volume_shadow_copy.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Win32_ShadowCopy",
            ").Create(",
            "ClientAccessible"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}