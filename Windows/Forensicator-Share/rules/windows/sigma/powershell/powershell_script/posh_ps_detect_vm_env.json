{
  "title": "Powershell Detect Virtualization Environment",
  "rule_id": "d93129cd-1ee0-479f-bc03-ca6f129882e3",
  "description": "Adversaries may employ various system checks to detect and avoid virtualization and analysis environments.\nThis may include changing behaviors based on the results of checks for the presence of artifacts indicative of a virtual machine environment (VME) or sandbox\n",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.discovery",
    "attack.defense-evasion",
    "attack.t1497.001"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_detect_vm_env.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection_action": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Get-WmiObject",
            "gwmi"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_module": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "MSAcpi_ThermalZoneTemperature",
            "Win32_ComputerSystem"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection*"
  }
}