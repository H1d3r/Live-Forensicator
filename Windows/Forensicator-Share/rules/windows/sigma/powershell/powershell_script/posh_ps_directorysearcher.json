{
  "title": "DirectorySearcher Powershell Exploitation",
  "rule_id": "1f6399cf-2c80-4924-ace1-6fcff3393480",
  "description": "Enumerates Active Directory to determine computers that are joined to the domain",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.discovery",
    "attack.t1018"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_directorysearcher.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "New-Object ",
            "System.DirectoryServices.DirectorySearcher",
            ".PropertiesToLoad.Add",
            ".findall()",
            "Properties.name"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}