{
  "title": "Disable-WindowsOptionalFeature Command PowerShell",
  "rule_id": "99c4658d-2c5e-4d87-828d-7c066ca537c3",
  "description": "Detect built in PowerShell cmdlet Disable-WindowsOptionalFeature, Deployment Image Servicing and Management tool.\nSimilar to DISM.exe, this cmdlet is used to enumerate, install, uninstall, configure, and update features and packages in Windows images\n",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1562.001"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_disable_windows_optional_feature.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection_cmd": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Disable-WindowsOptionalFeature",
            "-Online",
            "-FeatureName"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_feature": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Windows-Defender-Gui",
            "Windows-Defender-Features",
            "Windows-Defender",
            "Windows-Defender-ApplicationGuard"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection*"
  }
}