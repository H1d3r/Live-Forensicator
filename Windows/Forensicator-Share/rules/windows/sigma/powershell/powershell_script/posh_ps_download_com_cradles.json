{
  "title": "Potential COM Objects Download Cradles Usage - PS Script",
  "rule_id": "3c7d1587-3b13-439f-9941-7d14313dbdfe",
  "description": "Detects usage of COM objects that can be abused to download files in PowerShell by CLSID",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.command-and-control",
    "attack.t1105"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_download_com_cradles.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection_1": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "[Type]::GetTypeFromCLSID("
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_2": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "0002DF01-0000-0000-C000-000000000046",
            "F6D90F16-9C73-11D3-B32E-00C04F990BB4",
            "F5078F35-C551-11D3-89B9-0000F81FE221",
            "88d96a0a-f192-11d4-a65f-0040963251e5",
            "AFBA6B42-5692-48EA-8141-DC517DCF0EF1",
            "AFB40FFD-B609-40A3-9828-F88BBE11E4E3",
            "88d96a0b-f192-11d4-a65f-0040963251e5",
            "2087c2f4-2cef-4953-a8ab-66779b670495",
            "000209FF-0000-0000-C000-000000000046",
            "00024500-0000-0000-C000-000000000046"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}