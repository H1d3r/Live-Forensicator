{
  "title": "Dump Credentials from Windows Credential Manager With PowerShell",
  "rule_id": "99c49d9c-34ea-45f7-84a7-4751ae6b2cbc",
  "description": "Adversaries may search for common password storage locations to obtain user credentials.\nPasswords are stored in several places on a system, depending on the operating system or application holding the credentials.\n",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.credential-access",
    "attack.t1555"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_dump_password_windows_credential_manager.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection_kiddie": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Get-PasswordVaultCredentials",
            "Get-CredManCreds"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_rename_Password": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "New-Object",
            "Windows.Security.Credentials.PasswordVault"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_rename_credman": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "New-Object",
            "Microsoft.CSharp.CSharpCodeProvider",
            "[System.Runtime.InteropServices.RuntimeEnvironment]::GetRuntimeDirectory())",
            "Collections.ArrayList",
            "System.CodeDom.Compiler.CompilerParameters"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "any",
    "pattern": "selection_*"
  }
}