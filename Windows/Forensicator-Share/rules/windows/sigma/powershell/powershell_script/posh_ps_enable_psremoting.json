{
  "title": "Enable Windows Remote Management",
  "rule_id": "991a9744-f2f0-44f2-bd33-9092eba17dc3",
  "description": "Adversaries may use Valid Accounts to interact with remote systems using Windows Remote Management (WinRM). The adversary may then perform actions as the logged-on user.",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.lateral-movement",
    "attack.t1021.006"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_enable_psremoting.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection_cmdlet": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Enable-PSRemoting "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection_cmdlet"
  }
}