{
  "title": "Potential Suspicious Windows Feature Enabled",
  "rule_id": "55c925c1-7195-426b-a136-a9396800e29b",
  "description": "Detects usage of the built-in PowerShell cmdlet \"Enable-WindowsOptionalFeature\" used as a Deployment Image Servicing and Management tool.\nSimilar to DISM.exe, this cmdlet is used to enumerate, install, uninstall, configure, and update features and packages in Windows images\n",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_enable_susp_windows_optional_feature.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection_cmd": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Enable-WindowsOptionalFeature",
            "-Online",
            "-FeatureName"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_feature": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "TelnetServer",
            "Internet-Explorer-Optional-amd64",
            "TFTP",
            "SMB1Protocol",
            "Client-ProjFS",
            "Microsoft-Windows-Subsystem-Linux"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}