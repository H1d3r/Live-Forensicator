{
  "title": "Enumerate Credentials from Windows Credential Manager With PowerShell",
  "rule_id": "603c6630-5225-49c1-8047-26c964553e0e",
  "description": "Adversaries may search for common password storage locations to obtain user credentials.\nPasswords are stored in several places on a system, depending on the operating system or application holding the credentials.\n",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.credential-access",
    "attack.t1555"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_enumerate_password_windows_credential_manager.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection_cmd": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "vaultcmd",
            "/listcreds:"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_option": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Windows Credentials",
            "Web Credentials"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}