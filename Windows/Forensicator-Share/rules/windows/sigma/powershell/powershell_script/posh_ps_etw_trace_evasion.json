{
  "title": "Disable of ETW Trace - Powershell",
  "rule_id": "115fdba9-f017-42e6-84cf-d5573bf2ddf8",
  "description": "Detects usage of powershell cmdlets to disable or remove ETW trace sessions",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1070",
    "attack.t1562.006",
    "car.2016-04-002"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_etw_trace_evasion.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection_pwsh_remove": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Remove-EtwTraceProvider "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_pwsh_set": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Set-EtwTraceProvider ",
            "0x11"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "any",
    "pattern": "selection*"
  }
}