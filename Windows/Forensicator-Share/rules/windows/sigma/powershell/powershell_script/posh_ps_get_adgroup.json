{
  "title": "Active Directory Group Enumeration With Get-AdGroup",
  "rule_id": "8c3a6607-b7dc-4f0d-a646-ef38c00b76ee",
  "description": "Detects usage of the \"Get-AdGroup\" cmdlet to enumerate Groups within Active Directory",
  "level": "low",
  "status": "test",
  "tags": [
    "attack.discovery",
    "attack.t1069.002"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_get_adgroup.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Get-AdGroup ",
            "-Filter"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}