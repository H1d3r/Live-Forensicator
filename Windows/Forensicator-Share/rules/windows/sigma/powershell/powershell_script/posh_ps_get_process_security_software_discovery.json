{
  "title": "Security Software Discovery Via Powershell Script",
  "rule_id": "904e8e61-8edf-4350-b59c-b905fc8e810c",
  "description": "Detects calls to \"get-process\" where the output is piped to a \"where-object\" filter to search for security solution processes.\nAdversaries may attempt to get a listing of security software, configurations, defensive tools, and sensors that are installed on a system or in a cloud environment. This may include things such as firewall rules and anti-virus\n",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.discovery",
    "attack.t1518.001"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_get_process_security_software_discovery.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection_cmdlet": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "get-process | \\?",
            "get-process | where",
            "gps | \\?",
            "gps | where"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_field": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Company -like",
            "Description -like",
            "Name -like",
            "Path -like",
            "Product -like"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_keywords": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "\\*avira\\*",
            "\\*carbonblack\\*",
            "\\*cylance\\*",
            "\\*defender\\*",
            "\\*kaspersky\\*",
            "\\*malware\\*",
            "\\*sentinel\\*",
            "\\*symantec\\*",
            "\\*virus\\*"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}