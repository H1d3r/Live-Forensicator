{
  "title": "HackTool - WinPwn Execution - ScriptBlock",
  "rule_id": "851fd622-b675-4d26-b803-14bc7baa517a",
  "description": "Detects scriptblock text keywords indicative of potential usge of the tool WinPwn. A tool for Windows and Active Directory reconnaissance and exploitation.\n",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.credential-access",
    "attack.defense-evasion",
    "attack.discovery",
    "attack.execution",
    "attack.privilege-escalation",
    "attack.t1046",
    "attack.t1082",
    "attack.t1106",
    "attack.t1518",
    "attack.t1548.002",
    "attack.t1552.001",
    "attack.t1555",
    "attack.t1555.003"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_hktl_winpwn.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Offline_Winpwn",
            "WinPwn ",
            "WinPwn.exe",
            "WinPwn.ps1"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}