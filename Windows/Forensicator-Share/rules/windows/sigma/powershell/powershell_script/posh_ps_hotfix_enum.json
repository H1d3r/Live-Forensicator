{
  "title": "PowerShell Hotfix Enumeration",
  "rule_id": "f5d1def8-1de0-4a0e-9794-1f6f27dd605c",
  "description": "Detects call to \"Win32_QuickFixEngineering\" in order to enumerate installed hotfixes often used in \"enum\" scripts by attackers",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.discovery"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_hotfix_enum.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Win32_QuickFixEngineering",
            "HotFixID"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}