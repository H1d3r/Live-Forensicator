{
  "title": "Invoke-Obfuscation Obfuscated IEX Invocation - PowerShell",
  "rule_id": "1b9dc62e-6e9e-42a3-8990-94d7a10007f7",
  "description": "Detects all variations of obfuscated powershell IEX invocation code generated by Invoke-Obfuscation framework from the following code block \\u2014",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1027",
    "attack.execution",
    "attack.t1059.001"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_invoke_obfuscation_obfuscated_iex.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection_iex": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "ScriptBlockText",
              "operator": "re",
              "values": [
                "\\$PSHome\\[\\s*\\d{1,3}\\s*\\]\\s*\\+\\s*\\$PSHome\\["
              ],
              "match": "any",
              "windash": false,
              "ignore_case": false
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "ScriptBlockText",
              "operator": "re",
              "values": [
                "\\$ShellId\\[\\s*\\d{1,3}\\s*\\]\\s*\\+\\s*\\$ShellId\\["
              ],
              "match": "any",
              "windash": false,
              "ignore_case": false
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "ScriptBlockText",
              "operator": "re",
              "values": [
                "\\$env:Public\\[\\s*\\d{1,3}\\s*\\]\\s*\\+\\s*\\$env:Public\\["
              ],
              "match": "any",
              "windash": false,
              "ignore_case": false
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "ScriptBlockText",
              "operator": "re",
              "values": [
                "\\$env:ComSpec\\[(\\s*\\d{1,3}\\s*,){2}"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": false
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "ScriptBlockText",
              "operator": "re",
              "values": [
                "\\*mdr\\*\\W\\s*\\)\\.Name"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": false
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "ScriptBlockText",
              "operator": "re",
              "values": [
                "\\$VerbosePreference\\.ToString\\("
              ],
              "match": "any",
              "windash": false,
              "ignore_case": false
            }
          ]
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection_iex"
  }
}