{
  "title": "Invoke-Obfuscation STDIN+ Launcher - Powershell",
  "rule_id": "779c8c12-0eb1-11eb-adc1-0242ac120002",
  "description": "Detects Obfuscated use of stdin to execute PowerShell",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1027",
    "attack.execution",
    "attack.t1059.001"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_invoke_obfuscation_stdin.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection_4104": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "re",
          "values": [
            "cmd.{0,5}(?:/c|/r).+powershell.+(?:\\$?\\{?input\\}?|noexit).+\""
