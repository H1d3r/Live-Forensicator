{
  "title": "Invoke-Obfuscation COMPRESS OBFUSCATION - PowerShell",
  "rule_id": "20e5497e-331c-4cd5-8d36-935f6e2a9a07",
  "description": "Detects Obfuscated Powershell via COMPRESS OBFUSCATION",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1027",
    "attack.execution",
    "attack.t1059.001"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_invoke_obfuscation_via_compress.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection_4104": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "new-object",
            "text.encoding]::ascii"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "system.io.compression.deflatestream",
            "system.io.streamreader"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "endswith",
          "values": [
            "readtoend"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection_4104"
  }
}