{
  "title": "Invoke-Obfuscation Via Use Clip - Powershell",
  "rule_id": "db92dd33-a3ad-49cf-8c2c-608c3e30ace0",
  "description": "Detects Obfuscated Powershell via use Clip.exe in Scripts",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1027",
    "attack.execution",
    "attack.t1059.001"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_invoke_obfuscation_via_use_clip.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection_4104": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "re",
          "values": [
            "(?i)echo.*clip.*&&.*(Clipboard|i`?n`?v`?o`?k`?e`?)"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": false
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection_4104"
  }
}