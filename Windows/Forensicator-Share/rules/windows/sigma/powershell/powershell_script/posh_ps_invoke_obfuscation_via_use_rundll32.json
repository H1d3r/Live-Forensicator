{
  "title": "Invoke-Obfuscation Via Use Rundll32 - PowerShell",
  "rule_id": "a5a30a6e-75ca-4233-8b8c-42e0f2037d3b",
  "description": "Detects Obfuscated Powershell via use Rundll32 in Scripts",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1027",
    "attack.execution",
    "attack.t1059.001"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_invoke_obfuscation_via_use_rundll32.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection_4104": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "&&",
            "rundll32",
            "shell32.dll",
            "shellexec_rundll"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "value",
            "invoke",
            "comspec",
            "iex"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection_4104"
  }
}