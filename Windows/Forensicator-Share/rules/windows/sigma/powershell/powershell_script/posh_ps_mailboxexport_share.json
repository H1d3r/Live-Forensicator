{
  "title": "Suspicious PowerShell Mailbox Export to Share - PS",
  "rule_id": "4a241dea-235b-4a7e-8d76-50d817b146c4",
  "description": "Detects usage of the powerShell New-MailboxExportRequest Cmdlet to exports a mailbox to a remote or local share, as used in ProxyShell exploitations",
  "level": "critical",
  "status": "test",
  "tags": [
    "attack.exfiltration"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_mailboxexport_share.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "New-MailboxExportRequest",
            " -Mailbox ",
            " -FilePath \\\\\\\\"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}