{
  "title": "PowerShell Credential Prompt",
  "rule_id": "ca8b77a9-d499-4095-b793-5d5f330d450e",
  "description": "Detects PowerShell calling a credential prompt",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.credential-access",
    "attack.execution",
    "attack.t1059.001"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_prompt_credentials.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "PromptForCredential"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}