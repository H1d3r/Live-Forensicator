{
  "title": "Powershell Sensitive File Discovery",
  "rule_id": "7d416556-6502-45b2-9bad-9d2f05f38997",
  "description": "Detect adversaries enumerate sensitive files",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.discovery",
    "attack.t1083"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_sensitive_file_discovery.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection_action": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "ls",
            "get-childitem",
            "gci"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_recurse": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "-recurse"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_file": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            ".pass",
            ".kdbx",
            ".kdb"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}