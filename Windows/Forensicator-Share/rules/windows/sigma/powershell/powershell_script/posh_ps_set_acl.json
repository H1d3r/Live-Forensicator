{
  "title": "PowerShell Script Change Permission Via Set-Acl - PsScript",
  "rule_id": "cae80281-ef23-44c5-873b-fd48d2666f49",
  "description": "Detects PowerShell scripts set ACL to of a file or a folder",
  "level": "low",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1222"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_set_acl.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Set-Acl ",
            "-AclObject ",
            "-Path "
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}