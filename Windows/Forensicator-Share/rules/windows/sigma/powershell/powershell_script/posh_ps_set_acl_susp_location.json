{
  "title": "PowerShell Set-Acl On Windows Folder - PsScript",
  "rule_id": "3bf1d859-3a7e-44cb-8809-a99e066d3478",
  "description": "Detects PowerShell scripts to set the ACL to a file in the Windows folder",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1222"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_set_acl_susp_location.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection_cmdlet": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Set-Acl ",
            "-AclObject "
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_paths": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "-Path \"C:\\Windows",
            "-Path \"C:/Windows",
            "-Path 'C:\\Windows",
            "-Path 'C:/Windows",
            "-Path C:\\\\Windows",
            "-Path C:/Windows",
            "-Path $env:windir",
            "-Path \"$env:windir",
            "-Path '$env:windir"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_permissions": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "FullControl",
            "Allow"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}