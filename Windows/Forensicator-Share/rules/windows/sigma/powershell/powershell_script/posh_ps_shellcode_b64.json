{
  "title": "PowerShell ShellCode",
  "rule_id": "16b37b70-6fcf-4814-a092-c36bd3aafcbd",
  "description": "Detects Base64 encoded Shellcode",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.privilege-escalation",
    "attack.t1055",
    "attack.execution",
    "attack.t1059.001"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_shellcode_b64.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "OiCAAAAYInlM",
            "OiJAAAAYInlM"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}