{
  "title": "Detected Windows Software Discovery - PowerShell",
  "rule_id": "2650dd1a-eb2a-412d-ac36-83f06c4f2282",
  "description": "Adversaries may attempt to enumerate software for a variety of reasons, such as figuring out what security measures are present or if the compromised system has a version of software that is vulnerable.",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.discovery",
    "attack.t1518"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_software_discovery.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "get-itemProperty",
            "\\software\\",
            "select-object",
            "format-table"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}