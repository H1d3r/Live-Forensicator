{
  "title": "Powershell Store File In Alternate Data Stream",
  "rule_id": "a699b30e-d010-46c8-bbd1-ee2e26765fe9",
  "description": "Storing files in Alternate Data Stream (ADS) similar to Astaroth malware.",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1564.004"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_store_file_in_alternate_data_stream.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection_compspec": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Start-Process",
            "-FilePath \"$env:comspec\" ",
            "-ArgumentList ",
            ">"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection_compspec"
  }
}