{
  "title": "Suspicious Eventlog Clear",
  "rule_id": "0f017df3-8f5a-414f-ad6b-24aff1128278",
  "description": "Detects usage of known powershell cmdlets such as \"Clear-EventLog\" to clear the Windows event logs",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1070.001"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_susp_clear_eventlog.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "ScriptBlockText",
              "operator": "contains",
              "values": [
                "Clear-EventLog ",
                "Remove-EventLog ",
                "Limit-EventLog ",
                "Clear-WinEvent "
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "ScriptBlockText",
              "operator": "contains",
              "values": [
                "Eventing.Reader.EventLogSession",
                "ClearLog"
              ],
              "match": "all",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "ScriptBlockText",
              "operator": "contains",
              "values": [
                "Diagnostics.EventLog",
                "Clear"
              ],
              "match": "all",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}