{
  "title": "Password Policy Discovery With Get-AdDefaultDomainPasswordPolicy",
  "rule_id": "bbb9495b-58fc-4016-b9df-9a3a1b67ca82",
  "description": "Detetcts PowerShell activity in which Get-Addefaultdomainpasswordpolicy is used to get the default password policy for an Active Directory domain.",
  "level": "low",
  "status": "test",
  "tags": [
    "attack.discovery",
    "attack.t1201"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_susp_get_addefaultdomainpasswordpolicy.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Get-AdDefaultDomainPasswordPolicy"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}