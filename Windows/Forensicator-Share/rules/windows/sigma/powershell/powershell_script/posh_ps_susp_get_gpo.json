{
  "title": "Suspicious GPO Discovery With Get-GPO",
  "rule_id": "eb2fd349-ec67-4caa-9143-d79c7fb34441",
  "description": "Detect use of Get-GPO to get one GPO or all the GPOs in a domain.",
  "level": "low",
  "status": "test",
  "tags": [
    "attack.discovery",
    "attack.t1615"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_susp_get_gpo.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Get-GPO"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}