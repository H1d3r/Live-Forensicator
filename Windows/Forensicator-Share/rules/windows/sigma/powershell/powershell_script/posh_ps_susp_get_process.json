{
  "title": "Suspicious Process Discovery With Get-Process",
  "rule_id": "af4c87ce-bdda-4215-b998-15220772e993",
  "description": "Get the processes that are running on the local computer.",
  "level": "low",
  "status": "test",
  "tags": [
    "attack.discovery",
    "attack.t1057"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_susp_get_process.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Get-Process"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}