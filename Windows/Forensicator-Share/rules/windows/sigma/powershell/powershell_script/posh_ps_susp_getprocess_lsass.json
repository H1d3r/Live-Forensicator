{
  "title": "PowerShell Get-Process LSASS in ScriptBlock",
  "rule_id": "84c174ab-d3ef-481f-9c86-a50d0b8e3edb",
  "description": "Detects a Get-Process command on lsass process, which is in almost all cases a sign of malicious activity",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.credential-access",
    "attack.t1003.001"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_susp_getprocess_lsass.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Get-Process lsass"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}