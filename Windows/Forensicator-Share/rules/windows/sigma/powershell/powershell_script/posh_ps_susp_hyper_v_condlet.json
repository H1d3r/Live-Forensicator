{
  "title": "Suspicious Hyper-V Cmdlets",
  "rule_id": "42d36aa1-3240-4db0-8257-e0118dcdd9cd",
  "description": "Adversaries may carry out malicious operations using a virtual instance to avoid detection",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1564.006"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_susp_hyper_v_condlet.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "New-VM",
            "Set-VMFirmware",
            "Start-VM"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}