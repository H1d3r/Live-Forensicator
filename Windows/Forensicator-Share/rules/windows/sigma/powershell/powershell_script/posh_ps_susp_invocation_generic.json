{
  "title": "Suspicious PowerShell Invocations - Generic",
  "rule_id": "ed965133-513f-41d9-a441-e38076a0798f",
  "description": "Detects suspicious PowerShell invocation command parameters",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1059.001"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_susp_invocation_generic.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection_encoded": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            " -enc ",
            " -EncodedCommand ",
            " -ec "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_hidden": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            " -w hidden ",
            " -window hidden ",
            " -windowstyle hidden ",
            " -w 1 "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_noninteractive": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            " -noni ",
            " -noninteractive "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection*"
  }
}