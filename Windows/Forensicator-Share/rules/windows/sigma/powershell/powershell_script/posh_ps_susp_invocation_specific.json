{
  "title": "Suspicious PowerShell Invocations - Specific",
  "rule_id": "ae7fbf8e-f3cb-49fd-8db4-5f3bed522c71",
  "description": "Detects suspicious PowerShell invocation command parameters",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1059.001"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_susp_invocation_specific.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection_convert_b64": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "-nop",
            " -w ",
            "hidden",
            " -c ",
            "[Convert]::FromBase64String"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_iex_selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            " -w ",
            "hidden",
            "-noni",
            "-nop",
            " -c ",
            "iex",
            "New-Object"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_enc_selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            " -w ",
            "hidden",
            "-ep",
            "bypass",
            "-Enc"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_reg_selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "powershell",
            "reg",
            "add"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "\\software\\microsoft\\windows\\currentversion\\run",
            "\\software\\wow6432node\\microsoft\\windows\\currentversion\\run",
            "\\software\\microsoft\\windows\\currentversion\\policies\\explorer\\run"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_webclient_selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "bypass",
            "-noprofile",
            "-windowstyle",
            "hidden",
            "new-object",
            "system.net.webclient",
            ".download"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_iex_webclient": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "iex",
            "New-Object",
            "Net.WebClient",
            ".Download"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_chocolatey": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "(New-Object System.Net.WebClient).DownloadString('https://community.chocolatey.org/install.ps1",
            "(New-Object System.Net.WebClient).DownloadString('https://chocolatey.org/install.ps1')",
            "Write-ChocolateyWarning"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "wildcard_ref",
        "mode": "any",
        "pattern": "selection_*"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_*"
        }
      }
    ]
  }
}