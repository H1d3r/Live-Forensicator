{
  "title": "Potential Keylogger Activity",
  "rule_id": "965e2db9-eddb-4cf6-a986-7a967df651e4",
  "description": "Detects PowerShell scripts that contains reference to keystroke capturing functions",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.collection",
    "attack.credential-access",
    "attack.t1056.001"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_susp_keylogger_activity.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "[Windows.Input.Keyboard]::IsKeyDown([System.Windows.Input.Key]::"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}