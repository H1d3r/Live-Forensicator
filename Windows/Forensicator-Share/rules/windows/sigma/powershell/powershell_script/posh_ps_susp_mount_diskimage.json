{
  "title": "Suspicious Mount-DiskImage",
  "rule_id": "29e1c216-6408-489d-8a06-ee9d151ef819",
  "description": "Adversaries may abuse container files such as disk image (.iso, .vhd) file formats to deliver malicious payloads that may not be tagged with MOTW.",
  "level": "low",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1553.005"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_susp_mount_diskimage.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Mount-DiskImage ",
            "-ImagePath "
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}