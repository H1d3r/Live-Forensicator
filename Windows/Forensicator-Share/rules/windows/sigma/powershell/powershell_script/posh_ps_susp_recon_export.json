{
  "title": "Recon Information for Export with PowerShell",
  "rule_id": "a9723fcc-881c-424c-8709-fd61442ab3c3",
  "description": "Once established within a system or network, an adversary may use automated techniques for collecting internal data",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.collection",
    "attack.t1119"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_susp_recon_export.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection_action": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Get-Service ",
            "Get-ChildItem ",
            "Get-Process "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_redirect": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "> $env:TEMP\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection*"
  }
}