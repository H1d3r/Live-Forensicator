{
  "title": "Suspicious SSL Connection",
  "rule_id": "195626f3-5f1b-4403-93b7-e6cfd4d6a078",
  "description": "Adversaries may employ a known encryption algorithm to conceal command and control traffic rather than relying on any inherent protections provided by a communication protocol.",
  "level": "low",
  "status": "test",
  "tags": [
    "attack.command-and-control",
    "attack.t1573"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_susp_ssl_keyword.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "System.Net.Security.SslStream",
            "Net.Security.RemoteCertificateValidationCallback",
            ".AuthenticateAsClient"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}