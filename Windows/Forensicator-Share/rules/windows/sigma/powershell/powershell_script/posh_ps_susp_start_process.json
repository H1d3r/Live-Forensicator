{
  "title": "Suspicious Start-Process PassThru",
  "rule_id": "0718cd72-f316-4aa2-988f-838ea8533277",
  "description": "Powershell use PassThru option to start in background",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1036.003"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_susp_start_process.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Start-Process",
            "-PassThru ",
            "-FilePath "
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}