{
  "title": "Powershell Suspicious Win32_PnPEntity",
  "rule_id": "b26647de-4feb-4283-af6b-6117661283c5",
  "description": "Adversaries may attempt to gather information about attached peripheral devices and components connected to a computer system.",
  "level": "low",
  "status": "test",
  "tags": [
    "attack.discovery",
    "attack.t1120"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_susp_win32_pnpentity.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Win32_PnPEntity"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}