{
  "title": "Tamper Windows Defender Remove-MpPreference - ScriptBlockLogging",
  "rule_id": "ae2bdd58-0681-48ac-be7f-58ab4e593458",
  "description": "Detects attempts to remove Windows Defender configuration using the 'MpPreference' cmdlet",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1562.001"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_tamper_windows_defender_rem_mp.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection_remove": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Remove-MpPreference"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_tamper": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "-ControlledFolderAccessProtectedFolders ",
            "-AttackSurfaceReductionRules_Ids ",
            "-AttackSurfaceReductionRules_Actions ",
            "-CheckForSignaturesBeforeRunningScan "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}