{
  "title": "Veeam Backup Servers Credential Dumping Script Execution",
  "rule_id": "976d6e6f-a04b-4900-9713-0134a353e38b",
  "description": "Detects execution of a PowerShell script that contains calls to the \"Veeam.Backup\" class, in order to dump stored credentials.",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.credential-access"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_veeam_credential_dumping_script.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "[Credentials]",
            "[Veeam.Backup.Common.ProtectedStorage]::GetLocalString",
            "Invoke-Sqlcmd",
            "Veeam Backup and Replication"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}