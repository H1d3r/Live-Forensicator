{
  "title": "PowerShell WMI Win32_Product Install MSI",
  "rule_id": "91109523-17f0-4248-a800-f81d9e7c081d",
  "description": "Detects the execution of an MSI file using PowerShell and the WMI Win32_Product class",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1218.007"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_win32_product_install_msi.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Invoke-CimMethod ",
            "-ClassName ",
            "Win32_Product ",
            "-MethodName ",
            ".msi"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}