{
  "title": "Potential WinAPI Calls Via PowerShell Scripts",
  "rule_id": "03d83090-8cba-44a0-b02f-0b756a050306",
  "description": "Detects use of WinAPI functions in PowerShell scripts",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1059.001",
    "attack.t1106"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_win_api_susp_access.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection_injection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "VirtualAlloc",
            "OpenProcess",
            "WriteProcessMemory",
            "CreateRemoteThread"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_token_steal": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "OpenProcessToken",
            "LookupPrivilegeValue",
            "AdjustTokenPrivileges"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_duplicate_token": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "OpenProcessToken",
            "DuplicateTokenEx",
            "CloseHandle"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_process_write_read": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "WriteProcessMemory",
            "VirtualAlloc",
            "ReadProcessMemory",
            "VirtualFree"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "any",
    "pattern": "selection_*"
  }
}