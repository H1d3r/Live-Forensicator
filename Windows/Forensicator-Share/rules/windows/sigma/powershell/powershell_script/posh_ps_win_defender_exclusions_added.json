{
  "title": "Windows Defender Exclusions Added - PowerShell",
  "rule_id": "c1344fa2-323b-4d2e-9176-84b4d4821c88",
  "description": "Detects modifications to the Windows Defender configuration settings using PowerShell to add exclusions",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1562",
    "attack.execution",
    "attack.t1059"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_win_defender_exclusions_added.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection_args_exc": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            " -ExclusionPath ",
            " -ExclusionExtension ",
            " -ExclusionProcess ",
            " -ExclusionIpAddress "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_args_pref": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Add-MpPreference ",
            "Set-MpPreference "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection*"
  }
}