{
  "title": "Windows Firewall Profile Disabled",
  "rule_id": "488b44e7-3781-4a71-888d-c95abfacf44d",
  "description": "Detects when a user disables the Windows Firewall via a Profile to help evade defense.",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1562.004"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_windows_firewall_profile_disabled.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection_args": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "Set-NetFirewallProfile ",
            " -Enabled ",
            " False"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_opt": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            " -All ",
            "Public",
            "Domain",
            "Private"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection*"
  }
}