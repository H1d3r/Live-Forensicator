{
  "title": "WMImplant Hack Tool",
  "rule_id": "8028c2c3-e25a-46e3-827f-bbb5abf181d7",
  "description": "Detects parameters used by WMImplant",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1047",
    "attack.t1059.001"
  ],
  "category": "ps_script",
  "rule_file": "rules/windows/powershell/powershell_script/posh_ps_wmimplant.yml",
  "sources": [
    "powershell_script_block"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ScriptBlockText",
          "operator": "contains",
          "values": [
            "WMImplant",
            " change_user ",
            " gen_cli ",
            " command_exec ",
            " disable_wdigest ",
            " disable_winrm ",
            " enable_wdigest ",
            " enable_winrm ",
            " registry_mod ",
            " remote_posh ",
            " sched_job ",
            " service_mod ",
            " process_kill ",
            " active_users ",
            " basic_info ",
            " power_off ",
            " vacant_system ",
            " logon_events "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}