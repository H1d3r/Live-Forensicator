{
  "title": "Suspicious Child Process of AspNetCompiler",
  "rule_id": "9ccba514-7cb6-4c5c-b377-700758f2f120",
  "description": "Detects potentially suspicious child processes of \"aspnet_compiler.exe\".",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1127"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_aspnet_compiler_susp_child_process.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection_parent": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\aspnet_compiler.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_child": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\calc.exe",
                "\\notepad.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "contains",
              "values": [
                "\\Users\\Public\\",
                "\\AppData\\Local\\Temp\\",
                "\\AppData\\Local\\Roaming\\",
                ":\\Temp\\",
                ":\\Windows\\Temp\\",
                ":\\Windows\\System32\\Tasks\\",
                ":\\Windows\\Tasks\\"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}