{
  "title": "Potentially Suspicious ASP.NET Compilation Via AspNetCompiler",
  "rule_id": "9f50fe98-fe5c-4a2d-86c7-fad7f63ed622",
  "description": "Detects execution of \"aspnet_compiler.exe\" with potentially suspicious paths for compilation.",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1127"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_aspnet_compiler_susp_paths.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "contains",
          "values": [
            ":\\Windows\\Microsoft.NET\\Framework\\",
            ":\\Windows\\Microsoft.NET\\Framework64\\",
            ":\\Windows\\Microsoft.NET\\FrameworkArm\\",
            ":\\Windows\\Microsoft.NET\\FrameworkArm64\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\aspnet_compiler.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "\\Users\\Public\\",
            "\\AppData\\Local\\Temp\\",
            "\\AppData\\Local\\Roaming\\",
            ":\\Temp\\",
            ":\\Windows\\Temp\\",
            ":\\Windows\\System32\\Tasks\\",
            ":\\Windows\\Tasks\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}