{
  "title": "Interactive AT Job",
  "rule_id": "60fc936d-2eb0-4543-8a13-911c750a1dfc",
  "description": "Detects an interactive AT job, which may be used as a form of privilege escalation.",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.persistence",
    "attack.execution",
    "attack.privilege-escalation",
    "attack.t1053.002"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_at_interactive_execution.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\at.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "interactive"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}