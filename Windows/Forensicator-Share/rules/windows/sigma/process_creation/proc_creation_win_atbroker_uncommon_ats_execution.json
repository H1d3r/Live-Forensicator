{
  "title": "Uncommon  Assistive Technology Applications Execution Via AtBroker.EXE",
  "rule_id": "f24bcaea-0cd1-11eb-adc1-0242ac120002",
  "description": "Detects the start of a non built-in assistive technology applications via \"Atbroker.EXE\".",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1218"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_atbroker_uncommon_ats_execution.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\AtBroker.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "AtBroker.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "start"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_builtin": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "animations",
            "audiodescription",
            "caretbrowsing",
            "caretwidth",
            "colorfiltering",
            "cursorindicator",
            "cursorscheme",
            "filterkeys",
            "focusborderheight",
            "focusborderwidth",
            "highcontrast",
            "keyboardcues",
            "keyboardpref",
            "livecaptions",
            "magnifierpane",
            "messageduration",
            "minimumhitradius",
            "mousekeys",
            "Narrator",
            "osk",
            "overlappedcontent",
            "showsounds",
            "soundsentry",
            "speechreco",
            "stickykeys",
            "togglekeys",
            "voiceaccess",
            "windowarranging",
            "windowtracking",
            "windowtrackingtimeout",
            "windowtrackingzorder"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_optional_java": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "Oracle_JavaAccessBridge"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "wildcard_ref",
        "mode": "all",
        "pattern": "selection_*"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_main_*"
        }
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_optional_*"
        }
      }
    ]
  }
}