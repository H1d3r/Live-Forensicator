{
  "title": "Hiding Files with Attrib.exe",
  "rule_id": "4281cb20-2994-4580-aa63-c8b86d019934",
  "description": "Detects usage of attrib.exe to hide files from users.",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1564.001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_attrib_hiding_files.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\attrib.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "ATTRIB.EXE"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " +h "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_msiexec": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "\\desktop.ini "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_optional_intel": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\cmd.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "exact",
          "values": [
            "+R +H +S +A \\\\\\*.cui"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "ParentCommandLine",
          "operator": "exact",
          "values": [
            "C:\\\\WINDOWS\\\\system32\\\\\\*.bat"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "wildcard_ref",
        "mode": "all",
        "pattern": "selection_*"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_main_*"
        }
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_optional_*"
        }
      }
    ]
  }
}