{
  "title": "Suspicious Child Process Of BgInfo.EXE",
  "rule_id": "811f459f-9231-45d4-959a-0266c6311987",
  "description": "Detects suspicious child processes of \"BgInfo.exe\" which could be a sign of potential abuse of the binary to proxy execution via external VBScript",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1059.005",
    "attack.defense-evasion",
    "attack.t1218",
    "attack.t1202"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_bginfo_suspicious_child_process.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection_parent": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\bginfo.exe",
            "\\bginfo64.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_child": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\calc.exe",
                "\\cmd.exe",
                "\\cscript.exe",
                "\\mshta.exe",
                "\\notepad.exe",
                "\\powershell.exe",
                "\\pwsh.exe",
                "\\wscript.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "contains",
              "values": [
                "\\AppData\\Local\\",
                "\\AppData\\Roaming\\",
                ":\\Users\\Public\\",
                ":\\Temp\\",
                ":\\Windows\\Temp\\",
                ":\\PerfLogs\\"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}