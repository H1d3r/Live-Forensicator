{
  "title": "File With Suspicious Extension Downloaded Via Bitsadmin",
  "rule_id": "5b80a791-ad9b-4b75-bcc1-ad4e1e89c200",
  "description": "Detects usage of bitsadmin downloading a file with a suspicious extension",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.persistence",
    "attack.t1197",
    "attack.s0190",
    "attack.t1036.003",
    "attack.command-and-control",
    "attack.t1105"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_bitsadmin_download_susp_extensions.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\bitsadmin.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "bitsadmin.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_flags": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " /transfer ",
            " /create ",
            " /addfile "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_extension": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            ".7z",
            ".asax",
            ".ashx",
            ".asmx",
            ".asp",
            ".aspx",
            ".bat",
            ".cfm",
            ".cgi",
            ".chm",
            ".cmd",
            ".dll",
            ".gif",
            ".jpeg",
            ".jpg",
            ".jsp",
            ".jspx",
            ".log",
            ".png",
            ".ps1",
            ".psm1",
            ".rar",
            ".scf",
            ".sct",
            ".txt",
            ".vbe",
            ".vbs",
            ".war",
            ".wsf",
            ".wsh",
            ".xll",
            ".zip"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}