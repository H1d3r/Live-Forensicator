{
  "title": "File Download Via Bitsadmin To A Suspicious Target Folder",
  "rule_id": "2ddef153-167b-4e89-86b6-757a9e65dcac",
  "description": "Detects usage of bitsadmin downloading a file to a suspicious target folder",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.persistence",
    "attack.t1197",
    "attack.s0190",
    "attack.t1036.003",
    "attack.command-and-control",
    "attack.t1105"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_bitsadmin_download_susp_targetfolder.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\bitsadmin.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "bitsadmin.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_flags": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " /transfer ",
            " /create ",
            " /addfile "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_folder": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            ":\\Perflogs",
            ":\\ProgramData\\",
            ":\\Temp\\",
            ":\\Users\\Public\\",
            ":\\Windows\\",
            "\\$Recycle.Bin\\",
            "\\AppData\\Local\\",
            "\\AppData\\Roaming\\",
            "\\Contacts\\",
            "\\Desktop\\",
            "\\Favorites\\",
            "\\Favourites\\",
            "\\inetpub\\wwwroot\\",
            "\\Music\\",
            "\\Pictures\\",
            "\\Start Menu\\Programs\\Startup\\",
            "\\Users\\Default\\",
            "\\Videos\\",
            "%ProgramData%",
            "%public%",
            "%temp%",
            "%tmp%"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}