{
  "title": "Potential Data Stealing Via Chromium Headless Debugging",
  "rule_id": "3e8207c5-fcd2-4ea6-9418-15d45b4890e4",
  "description": "Detects chromium based browsers starting in headless and debugging mode and pointing to a user profile. This could be a sign of data stealing or remote control",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.credential-access",
    "attack.collection",
    "attack.t1185",
    "attack.t1564.003"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_browsers_chromium_headless_debugging.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "--remote-debugging-",
            "--user-data-dir",
            "--headless"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}