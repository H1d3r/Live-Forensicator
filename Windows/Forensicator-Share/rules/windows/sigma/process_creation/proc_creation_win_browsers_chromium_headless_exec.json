{
  "title": "Browser Execution In Headless Mode",
  "rule_id": "ef9dcfed-690c-4c5d-a9d1-482cd422225c",
  "description": "Detects execution of Chromium based browser in headless mode",
  "level": "low",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.command-and-control",
    "attack.t1105",
    "attack.t1564.003"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_browsers_chromium_headless_exec.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\brave.exe",
            "\\chrome.exe",
            "\\msedge.exe",
            "\\opera.exe",
            "\\vivaldi.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "--headless"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}