{
  "title": "File Download with Headless Browser",
  "rule_id": "0e8cfe08-02c9-4815-a2f8-0d157b7ed33e",
  "description": "Detects execution of chromium based browser in headless mode using the \"dump-dom\" command line to download files",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.command-and-control",
    "attack.t1105",
    "attack.t1564.003"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_browsers_chromium_headless_file_download.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\brave.exe",
            "\\chrome.exe",
            "\\msedge.exe",
            "\\opera.exe",
            "\\vivaldi.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "--headless",
            "dump-dom",
            "http"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_optional_edge_1": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "startswith",
          "values": [
            "C:\\Program Files (x86)\\Microsoft\\Edge\\Application\\",
            "C:\\Program Files (x86)\\Microsoft\\EdgeCore\\",
            "C:\\Program Files (x86)\\Microsoft\\EdgeWebView\\",
            "C:\\Program Files\\Microsoft\\Edge\\Application\\",
            "C:\\Program Files\\Microsoft\\EdgeCore\\",
            "C:\\Program Files\\Microsoft\\EdgeWebView\\",
            "C:\\Program Files\\WindowsApps\\Microsoft.MicrosoftEdge"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\msedge.exe",
            "\\msedgewebview2.exe",
            "\\MicrosoftEdge.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "--headless --disable-gpu --disable-extensions --disable-plugins --mute-audio --no-first-run --incognito --aggressive-cache-discard --dump-dom"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_optional_edge_2": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "contains",
          "values": [
            "\\AppData\\Local\\Microsoft\\WindowsApps\\",
            "\\Windows\\SystemApps\\Microsoft.MicrosoftEdge"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\msedge.exe",
            "\\MicrosoftEdge.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "--headless --disable-gpu --disable-extensions --disable-plugins --mute-audio --no-first-run --incognito --aggressive-cache-discard --dump-dom"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_optional_*"
        }
      }
    ]
  }
}