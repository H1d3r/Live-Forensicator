{
  "title": "Suspicious Chromium Browser Instance Executed With Custom Extension",
  "rule_id": "27ba3207-dd30-4812-abbf-5d20c57d474e",
  "description": "Detects a suspicious process spawning a Chromium based browser process with the 'load-extension' flag to start an instance with a custom extension",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.persistence",
    "attack.t1176.001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_browsers_chromium_susp_load_extension.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\cmd.exe",
            "\\cscript.exe",
            "\\mshta.exe",
            "\\powershell.exe",
            "\\pwsh.exe",
            "\\regsvr32.exe",
            "\\rundll32.exe",
            "\\wscript.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\brave.exe",
            "\\chrome.exe",
            "\\msedge.exe",
            "\\opera.exe",
            "\\vivaldi.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "--load-extension="
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}