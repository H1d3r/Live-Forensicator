{
  "title": "Browser Started with Remote Debugging",
  "rule_id": "b3d34dc5-2efd-4ae3-845f-8ec14921f449",
  "description": "Detects browsers starting with the remote debugging flags. Which is a technique often used to perform browser injection attacks",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.credential-access",
    "attack.collection",
    "attack.t1185"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_browsers_remote_debugging.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection_chromium_based": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " --remote-debugging-"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_firefox": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\firefox.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " -start-debugger-server"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "any",
    "pattern": "selection_*"
  }
}