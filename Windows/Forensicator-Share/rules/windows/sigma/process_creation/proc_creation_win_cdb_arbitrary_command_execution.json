{
  "title": "Potential Binary Proxy Execution Via Cdb.EXE",
  "rule_id": "b5c7395f-e501-4a08-94d4-57fe7a9da9d2",
  "description": "Detects usage of \"cdb.exe\" to launch arbitrary processes or commands from a debugger script file",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1106",
    "attack.defense-evasion",
    "attack.t1218",
    "attack.t1127"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_cdb_arbitrary_command_execution.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\cdb.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "CDB.Exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " -c ",
            " -cf "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection*"
  }
}