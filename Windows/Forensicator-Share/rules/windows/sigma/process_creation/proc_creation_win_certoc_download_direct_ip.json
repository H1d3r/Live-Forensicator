{
  "title": "File Download From IP Based URL Via CertOC.EXE",
  "rule_id": "b86f6dea-0b2f-41f5-bdcc-a057bd19cd6a",
  "description": "Detects when a user downloads a file from an IP based URL using CertOC.exe",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.command-and-control",
    "attack.execution",
    "attack.t1105"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_certoc_download_direct_ip.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\certoc.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "CertOC.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_ip": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "re",
          "values": [
            "://[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": false
        }
      ]
    },
    "selection_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "-GetCACAPS"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection*"
  }
}