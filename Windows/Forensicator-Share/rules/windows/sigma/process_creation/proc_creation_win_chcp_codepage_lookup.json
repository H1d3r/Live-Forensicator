{
  "title": "Console CodePage Lookup Via CHCP",
  "rule_id": "7090adee-82e2-4269-bd59-80691e7c6338",
  "description": "Detects use of chcp to look up the system locale value as part of host discovery",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.discovery",
    "attack.t1614.001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_chcp_codepage_lookup.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\cmd.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "ParentCommandLine",
          "operator": "contains",
          "values": [
            " -c ",
            " -r ",
            " -k "
          ],
          "match": "any",
          "windash": true,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\chcp.com"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "endswith",
          "values": [
            "chcp",
            "chcp ",
            "chcp  "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}