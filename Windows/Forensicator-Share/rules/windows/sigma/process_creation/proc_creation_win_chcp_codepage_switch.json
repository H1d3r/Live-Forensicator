{
  "title": "Suspicious CodePage Switch Via CHCP",
  "rule_id": "c7942406-33dd-4377-a564-0f62db0593a3",
  "description": "Detects a code page switch in command line or batch scripts to a rare language",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.t1036",
    "attack.defense-evasion"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_chcp_codepage_switch.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\chcp.com"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "endswith",
          "values": [
            " 936",
            " 1258"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}