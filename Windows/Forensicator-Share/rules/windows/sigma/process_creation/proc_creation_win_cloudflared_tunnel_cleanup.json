{
  "title": "Cloudflared Tunnel Connections Cleanup",
  "rule_id": "7050bba1-1aed-454e-8f73-3f46f09ce56a",
  "description": "Detects execution of the \"cloudflared\" tool with the tunnel \"cleanup\" flag in order to cleanup tunnel connections.",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.command-and-control",
    "attack.t1102",
    "attack.t1090",
    "attack.t1572"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_cloudflared_tunnel_cleanup.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " tunnel ",
            "cleanup "
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "-config ",
            "-connector-id "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}