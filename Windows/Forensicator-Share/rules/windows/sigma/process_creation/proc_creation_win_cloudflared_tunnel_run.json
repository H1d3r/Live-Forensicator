{
  "title": "Cloudflared Tunnel Execution",
  "rule_id": "9a019ffc-3580-4c9d-8d87-079f7e8d3fd4",
  "description": "Detects execution of the \"cloudflared\" tool to connect back to a tunnel. This was seen used by threat actors to maintain persistence and remote access to compromised networks.",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.command-and-control",
    "attack.t1102",
    "attack.t1090",
    "attack.t1572"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_cloudflared_tunnel_run.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " tunnel ",
            " run "
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "-config ",
            "-credentials-contents ",
            "-credentials-file ",
            "-token "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}