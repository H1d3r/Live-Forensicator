{
  "title": "Cmd.EXE Missing Space Characters Execution Anomaly",
  "rule_id": "a16980c2-0c56-4de0-9a79-17971979efdd",
  "description": "Detects Windows command lines that miss a space before or after the /c flag when running a command using the cmd.exe.\nThis could be a sign of obfuscation of a fat finger problem (typo by the developer).\n",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1059.001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_cmd_no_space_execution.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection1": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "cmd.exe/c",
            "\\cmd/c",
            "\"cmd/c",
            "cmd.exe/k",
            "\\cmd/k",
            "\"cmd/k",
            "cmd.exe/r",
            "\\cmd/r",
            "\"cmd/r"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection2": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "/cwhoami",
            "/cpowershell",
            "/cschtasks",
            "/cbitsadmin",
            "/ccertutil",
            "/kwhoami",
            "/kpowershell",
            "/kschtasks",
            "/kbitsadmin",
            "/kcertutil"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection3": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "cmd.exe /c",
            "cmd /c",
            "cmd.exe /k",
            "cmd /k",
            "cmd.exe /r",
            "cmd /r"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_generic": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "cmd.exe /c ",
            "cmd /c ",
            "cmd.exe /k ",
            "cmd /k ",
            "cmd.exe /r ",
            "cmd /r "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_fp": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "contains",
              "values": [
                "AppData\\Local\\Programs\\Microsoft VS Code\\resources\\app\\node_modules"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "endswith",
              "values": [
                "cmd.exe/c ."
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "exact",
              "values": [
                "cmd.exe /c"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "wildcard_ref",
        "mode": "any",
        "pattern": "selection*"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_*"
        }
      }
    ]
  }
}