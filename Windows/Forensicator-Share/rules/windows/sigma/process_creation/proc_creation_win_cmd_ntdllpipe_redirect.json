{
  "title": "NtdllPipe Like Activity Execution",
  "rule_id": "bbc865e4-7fcd-45a6-8ff1-95ced28ec5b2",
  "description": "Detects command that type the content of ntdll.dll to a different file or a pipe in order to evade AV / EDR detection. As seen being used in the POC NtdllPipe",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_cmd_ntdllpipe_redirect.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "type %windir%\\system32\\ntdll.dll",
            "type %systemroot%\\system32\\ntdll.dll",
            "type c:\\windows\\system32\\ntdll.dll",
            "\\\\ntdll.dll > \\\\\\\\.\\\\pipe\\\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}