{
  "title": "Read Contents From Stdin Via Cmd.EXE",
  "rule_id": "241e802a-b65e-484f-88cd-c2dc10f9206d",
  "description": "Detect the use of \"<\" to read and potentially execute a file via cmd.exe",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1059.003"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_cmd_stdin_redirect.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_cmd": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "Cmd.Exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\cmd.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "<"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}