{
  "title": "Potential Download/Upload Activity Using Type Command",
  "rule_id": "aa0b3a82-eacc-4ec3-9150-b5a9a3e3f82f",
  "description": "Detects usage of the \"type\" command to download/upload data from WebDAV server",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.command-and-control",
    "attack.t1105"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_cmd_type_arbitrary_file_download.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection_upload": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "type ",
            " > \\\\\\\\"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_download": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "type \\\\\\\\",
            " > "
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "any",
    "pattern": "selection_*"
  }
}