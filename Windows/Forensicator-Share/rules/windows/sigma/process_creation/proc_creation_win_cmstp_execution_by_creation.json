{
  "title": "CMSTP Execution Process Creation",
  "rule_id": "7d4cdc5a-0076-40ca-aac8-f7e714570e47",
  "description": "Detects various indicators of Microsoft Connection Manager Profile Installer execution",
  "level": "high",
  "status": "stable",
  "tags": [
    "attack.defense-evasion",
    "attack.execution",
    "attack.t1218.003",
    "attack.g0069",
    "car.2019-04-001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_cmstp_execution_by_creation.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\cmstp.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}