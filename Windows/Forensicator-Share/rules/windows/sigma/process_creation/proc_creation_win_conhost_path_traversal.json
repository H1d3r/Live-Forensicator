{
  "title": "Conhost.exe CommandLine Path Traversal",
  "rule_id": "ee5e119b-1f75-4b34-add8-3be976961e39",
  "description": "detects the usage of path traversal in conhost.exe indicating possible command/argument confusion/hijacking",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1059.003"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_conhost_path_traversal.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentCommandLine",
          "operator": "contains",
          "values": [
            "conhost"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "/../../"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}