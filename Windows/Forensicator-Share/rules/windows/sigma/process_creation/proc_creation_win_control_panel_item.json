{
  "title": "Control Panel Items",
  "rule_id": "0ba863e6-def5-4e50-9cea-4dd8c7dc46a4",
  "description": "Detects the malicious use of a control panel item",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.privilege-escalation",
    "attack.execution",
    "attack.defense-evasion",
    "attack.t1218.002",
    "attack.persistence",
    "attack.t1546"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_control_panel_item.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_reg_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\reg.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "reg.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_reg_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "add",
            "CurrentVersion\\Control Panel\\CPLs"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_cpl": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "endswith",
          "values": [
            ".cpl"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_cpl_sys": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "\\System32\\",
            "%System%",
            "|C:\\Windows\\system32|"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_cpl_igfx": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "regsvr32 ",
            " /s ",
            "igfxCPL.cpl"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "any",
    "children": [
      {
        "type": "wildcard_ref",
        "mode": "all",
        "pattern": "selection_reg_*"
      },
      {
        "type": "all",
        "children": [
          {
            "type": "item_ref",
            "name": "selection_cpl"
          },
          {
            "type": "not",
            "child": {
              "type": "wildcard_ref",
              "mode": "any",
              "pattern": "filter_cpl_*"
            }
          }
        ]
      }
    ]
  }
}