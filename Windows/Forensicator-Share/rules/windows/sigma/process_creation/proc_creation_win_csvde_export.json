{
  "title": "Active Directory Structure Export Via Csvde.EXE",
  "rule_id": "e5d36acd-acb4-4c6f-a13f-9eb203d50099",
  "description": "Detects the execution of \"csvde.exe\" in order to export organizational Active Directory structure.",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.exfiltration",
    "attack.discovery",
    "attack.t1087.002"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_csvde_export.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\csvde.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "csvde.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_remote": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " -f"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_import": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " -i"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "wildcard_ref",
        "mode": "all",
        "pattern": "selection_*"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_*"
        }
      }
    ]
  }
}