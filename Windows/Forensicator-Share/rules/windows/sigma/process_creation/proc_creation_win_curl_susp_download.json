{
  "title": "Suspicious Curl.EXE Download",
  "rule_id": "e218595b-bbe7-4ee5-8a96-f32a24ad3468",
  "description": "Detects a suspicious curl process start on Windows and outputs the requested document to a local file",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.command-and-control",
    "attack.t1105"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_curl_susp_download.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_curl": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\curl.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Product",
              "operator": "exact",
              "values": [
                "The curl executable"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_susp_locations": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "%AppData%",
            "%Public%",
            "%Temp%",
            "%tmp%",
            "\\AppData\\",
            "\\Desktop\\",
            "\\Temp\\",
            "\\Users\\Public\\",
            "C:\\PerfLogs\\",
            "C:\\ProgramData\\",
            "C:\\Windows\\Temp\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_susp_extensions": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "endswith",
          "values": [
            ".dll",
            ".gif",
            ".jpeg",
            ".jpg",
            ".png",
            ".temp",
            ".tmp",
            ".txt",
            ".vbe",
            ".vbs"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_optional_git_windows": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "exact",
          "values": [
            "C:\\Program Files\\Git\\usr\\bin\\sh.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Image",
          "operator": "exact",
          "values": [
            "C:\\Program Files\\Git\\mingw64\\bin\\curl.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "--silent --show-error --output ",
            "gfw-httpget-",
            "AppData"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection_curl"
      },
      {
        "type": "wildcard_ref",
        "mode": "any",
        "pattern": "selection_susp_*"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_optional_*"
        }
      }
    ]
  }
}