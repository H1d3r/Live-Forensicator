{
  "title": "ManageEngine Endpoint Central Dctask64.EXE Potential Abuse",
  "rule_id": "6345b048-8441-43a7-9bed-541133633d7a",
  "description": "Detects the execution of \"dctask64.exe\", a signed binary by ZOHO Corporation part of ManageEngine Endpoint Central.\nThis binary can be abused for DLL injection, arbitrary command and process execution.\n",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.privilege-escalation",
    "attack.defense-evasion",
    "attack.t1055.001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_dctask64_arbitrary_command_and_dll_execution.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\dctask64.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Hashes",
              "operator": "contains",
              "values": [
                "IMPHASH=6834B1B94E49701D77CCB3C0895E1AFD",
                "IMPHASH=1BB6F93B129F398C7C4A76BB97450BBA",
                "IMPHASH=FAA2AC19875FADE461C8D89DCF2710A3",
                "IMPHASH=F1039CED4B91572AB7847D26032E6BBF"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " executecmd64 ",
            " invokeexe ",
            " injectDll "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}