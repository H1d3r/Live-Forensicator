{
  "title": "Uncommon Child Process Of Defaultpack.EXE",
  "rule_id": "b2309017-4235-44fe-b5af-b15363011957",
  "description": "Detects uncommon child processes of \"DefaultPack.EXE\" binary as a proxy to launch other programs",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.t1218",
    "attack.defense-evasion",
    "attack.execution"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_defaultpack_uncommon_child_process.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\DefaultPack.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}