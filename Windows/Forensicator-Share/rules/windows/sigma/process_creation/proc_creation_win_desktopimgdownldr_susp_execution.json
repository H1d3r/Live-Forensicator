{
  "title": "Suspicious Desktopimgdownldr Command",
  "rule_id": "bb58aa4a-b80b-415a-a2c0-2f65a4c81009",
  "description": "Detects a suspicious Microsoft desktopimgdownldr execution with parameters used to download files from the Internet",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.command-and-control",
    "attack.t1105"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_desktopimgdownldr_susp_execution.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection1": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " /lockscreenurl:"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection1_filter": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            ".jpg",
            ".jpeg",
            ".png"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_reg": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "reg delete",
            "\\PersonalizationCSP"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "any",
    "children": [
      {
        "type": "all",
        "children": [
          {
            "type": "item_ref",
            "name": "selection1"
          },
          {
            "type": "not",
            "child": {
              "type": "item_ref",
              "name": "selection1_filter"
            }
          }
        ]
      },
      {
        "type": "item_ref",
        "name": "selection_reg"
      }
    ]
  }
}