{
  "title": "DriverQuery.EXE Execution",
  "rule_id": "a20def93-0709-4eae-9bd2-31206e21e6b2",
  "description": "Detect usage of the \"driverquery\" utility. Which can be used to perform reconnaissance on installed drivers",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.discovery"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_driverquery_usage.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "driverquery.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "drvqry.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "filter_main_other": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "ParentImage",
              "operator": "endswith",
              "values": [
                "\\cscript.exe",
                "\\mshta.exe",
                "\\regsvr32.exe",
                "\\rundll32.exe",
                "\\wscript.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "ParentImage",
              "operator": "contains",
              "values": [
                "\\AppData\\Local\\",
                "\\Users\\Public\\",
                "\\Windows\\Temp\\"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_main_*"
        }
      }
    ]
  }
}