{
  "title": "DumpMinitool Execution",
  "rule_id": "dee0a7a3-f200-4112-a99b-952196d81e42",
  "description": "Detects the use of \"DumpMinitool.exe\" a tool that allows the dump of process memory via the use of the \"MiniDumpWriteDump\"",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1036",
    "attack.t1003.001",
    "attack.credential-access"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_dumpminitool_execution.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\DumpMinitool.exe",
                "\\DumpMinitool.x86.exe",
                "\\DumpMinitool.arm64.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "DumpMinitool.exe",
                "DumpMinitool.x86.exe",
                "DumpMinitool.arm64.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " Full",
            " Mini",
            " WithHeap"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}