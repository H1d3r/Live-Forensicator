{
  "title": "Suspicious DumpMinitool Execution",
  "rule_id": "eb1c4225-1c23-4241-8dd4-051389fde4ce",
  "description": "Detects suspicious ways to use the \"DumpMinitool.exe\" binary",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.credential-access",
    "attack.t1036",
    "attack.t1003.001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_dumpminitool_susp_execution.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\DumpMinitool.exe",
                "\\DumpMinitool.x86.exe",
                "\\DumpMinitool.arm64.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "DumpMinitool.exe",
                "DumpMinitool.x86.exe",
                "DumpMinitool.arm64.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "filter_folder": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "contains",
          "values": [
            "\\Microsoft Visual Studio\\",
            "\\Extensions\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "susp_flags": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            ".txt"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "cmd_has_flags": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " Full",
            " Mini",
            " WithHeap"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_cmd_misses_flags": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "--dumpType"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "any",
        "children": [
          {
            "type": "not",
            "child": {
              "type": "item_ref",
              "name": "filter_folder"
            }
          },
          {
            "type": "item_ref",
            "name": "susp_flags"
          },
          {
            "type": "all",
            "children": [
              {
                "type": "item_ref",
                "name": "cmd_has_flags"
              },
              {
                "type": "not",
                "child": {
                  "type": "item_ref",
                  "name": "filter_cmd_misses_flags"
                }
              }
            ]
          }
        ]
      }
    ]
  }
}