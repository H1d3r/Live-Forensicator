{
  "title": "Esentutl Gather Credentials",
  "rule_id": "7df1713a-1a5b-4a4b-a071-dc83b144a101",
  "description": "Conti recommendation to its affiliates to use esentutl to access NTDS dumped file. Trickbot also uses this utilities to get MSEdge info via its module pwgrab.",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.credential-access",
    "attack.t1003",
    "attack.t1003.003",
    "attack.s0404"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_esentutl_params.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "esentutl",
            " /p"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}