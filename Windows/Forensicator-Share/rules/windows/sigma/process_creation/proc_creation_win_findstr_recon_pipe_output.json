{
  "title": "Recon Command Output Piped To Findstr.EXE",
  "rule_id": "ccb5742c-c248-4982-8c5c-5571b9275ad3",
  "description": "Detects the execution of a potential recon command where the results are piped to \"findstr\". This is meant to trigger on inline calls of \"cmd.exe\" via the \"/c\" or \"/k\" for example.\nAttackers often time use this technique to extract specific information they require in their reconnaissance phase.\n",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.discovery",
    "attack.t1057"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_findstr_recon_pipe_output.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "ipconfig*|*find",
            "net*|*find",
            "netstat*|*find",
            "ping*|*find",
            "systeminfo*|*find",
            "tasklist*|*find",
            "whoami*|*find"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_optional_xampp": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "cmd.exe /c TASKLIST /V |",
            "FIND /I",
            "\\xampp\\",
            "\\catalina_start.bat"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_optional_*"
        }
      }
    ]
  }
}