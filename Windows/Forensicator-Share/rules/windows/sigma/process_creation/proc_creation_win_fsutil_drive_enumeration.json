{
  "title": "Fsutil Drive Enumeration",
  "rule_id": "63de06b9-a385-40b5-8b32-73f2b9ef84b6",
  "description": "Attackers may leverage fsutil to enumerated connected drives.",
  "level": "low",
  "status": "test",
  "tags": [
    "attack.discovery",
    "attack.t1120"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_fsutil_drive_enumeration.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\fsutil.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "fsutil.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "drives"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}