{
  "title": "Github Self-Hosted Runner Execution",
  "rule_id": "5bac7a56-da88-4c27-922e-c81e113b20cb",
  "description": "Detects GitHub self-hosted runners executing workflows on local infrastructure that could be abused for persistence and code execution.\nShai-Hulud is an npm supply chain worm targeting CI/CD environments.\nIt installs runners on compromised systems to maintain access after credential theft, leveraging their access to secrets and internal networks.\n",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.command-and-control",
    "attack.t1102.002",
    "attack.t1071"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_github_self_hosted_runner.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_worker_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\Runner.Worker.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "Runner.Worker.dll"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_worker_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "spawnclient"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_listener_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\Runner.Listener.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "Runner.Listener.dll"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_listener_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "run",
            "configure"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "any",
    "children": [
      {
        "type": "wildcard_ref",
        "mode": "all",
        "pattern": "selection_worker_*"
      },
      {
        "type": "wildcard_ref",
        "mode": "all",
        "pattern": "selection_listener_*"
      }
    ]
  }
}