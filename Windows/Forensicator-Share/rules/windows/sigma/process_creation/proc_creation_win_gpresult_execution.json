{
  "title": "Gpresult Display Group Policy Information",
  "rule_id": "e56d3073-83ff-4021-90fe-c658e0709e72",
  "description": "Detects cases in which a user uses the built-in Windows utility gpresult to display the Resultant Set of Policy (RSoP) information",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.discovery",
    "attack.t1615"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_gpresult_execution.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\gpresult.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "/z",
            "/v"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}