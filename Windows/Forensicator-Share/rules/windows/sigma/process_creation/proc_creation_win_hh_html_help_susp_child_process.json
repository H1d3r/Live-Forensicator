{
  "title": "HTML Help HH.EXE Suspicious Child Process",
  "rule_id": "52cad028-0ff0-4854-8f67-d25dfcbc78b4",
  "description": "Detects a suspicious child process of a Microsoft HTML Help (HH.exe)",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.execution",
    "attack.initial-access",
    "attack.t1047",
    "attack.t1059.001",
    "attack.t1059.003",
    "attack.t1059.005",
    "attack.t1059.007",
    "attack.t1218",
    "attack.t1218.001",
    "attack.t1218.010",
    "attack.t1218.011",
    "attack.t1566",
    "attack.t1566.001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hh_html_help_susp_child_process.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\hh.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\CertReq.exe",
            "\\CertUtil.exe",
            "\\cmd.exe",
            "\\cscript.exe",
            "\\installutil.exe",
            "\\MSbuild.exe",
            "\\MSHTA.EXE",
            "\\msiexec.exe",
            "\\powershell.exe",
            "\\pwsh.exe",
            "\\regsvr32.exe",
            "\\rundll32.exe",
            "\\schtasks.exe",
            "\\wmic.exe",
            "\\wscript.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}