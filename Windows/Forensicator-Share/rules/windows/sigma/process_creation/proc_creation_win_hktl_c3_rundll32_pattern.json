{
  "title": "HackTool - F-Secure C3 Load by Rundll32",
  "rule_id": "b18c9d4c-fac9-4708-bd06-dd5bfacf200f",
  "description": "F-Secure C3 produces DLLs with a default exported StartNodeRelay function.",
  "level": "critical",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1218.011"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hktl_c3_rundll32_pattern.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "rundll32.exe",
            ".dll",
            "StartNodeRelay"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}