{
  "title": "HackTool - Certipy Execution",
  "rule_id": "6938366d-8954-4ddc-baff-c830b3ba8fcd",
  "description": "Detects Certipy execution, a tool for Active Directory Certificate Services enumeration and abuse based on PE metadata characteristics and common command line arguments.\n",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.discovery",
    "attack.credential-access",
    "attack.t1649"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hktl_certipy.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\Certipy.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "Certipy.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Description",
              "operator": "contains",
              "values": [
                "Certipy"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_cli_commands": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " account ",
            " auth ",
            " cert ",
            " find ",
            " forge ",
            " ptt ",
            " relay ",
            " req ",
            " shadow ",
            " template "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_cli_flags": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " -bloodhound",
            " -ca-pfx ",
            " -dc-ip ",
            " -kirbi",
            " -old-bloodhound",
            " -pfx ",
            " -target",
            " -template",
            " -username ",
            " -vulnerable",
            "auth -pfx",
            "shadow auto",
            "shadow list"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "any",
    "children": [
      {
        "type": "item_ref",
        "name": "selection_img"
      },
      {
        "type": "wildcard_ref",
        "mode": "all",
        "pattern": "selection_cli_*"
      }
    ]
  }
}