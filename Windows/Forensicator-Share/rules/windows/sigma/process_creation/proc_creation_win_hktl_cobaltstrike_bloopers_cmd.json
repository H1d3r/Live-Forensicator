{
  "title": "Operator Bloopers Cobalt Strike Commands",
  "rule_id": "647c7b9e-d784-4fda-b9a0-45c565a7b729",
  "description": "Detects use of Cobalt Strike commands accidentally entered in the CMD shell",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1059.003",
    "stp.1u"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hktl_cobaltstrike_bloopers_cmd.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "Cmd.Exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\cmd.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "startswith",
          "values": [
            "cmd ",
            "cmd.exe",
            "c:\\windows\\system32\\cmd.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "psinject",
            "spawnas",
            "make_token",
            "remote-exec",
            "rev2self",
            "dcsync",
            "logonpasswords",
            "execute-assembly",
            "getsystem"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}