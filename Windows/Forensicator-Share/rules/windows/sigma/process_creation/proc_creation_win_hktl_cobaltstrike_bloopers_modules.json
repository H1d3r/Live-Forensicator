{
  "title": "Operator Bloopers Cobalt Strike Modules",
  "rule_id": "4f154fb6-27d1-4813-a759-78b93e0b9c48",
  "description": "Detects Cobalt Strike module/commands accidentally entered in CMD shell",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1059.003"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hktl_cobaltstrike_bloopers_modules.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "Cmd.Exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\cmd.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "Invoke-UserHunter",
            "Invoke-ShareFinder",
            "Invoke-Kerberoast",
            "Invoke-SMBAutoBrute",
            "Invoke-Nightmare",
            "zerologon",
            "av_query"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}