{
  "title": "Potential CobaltStrike Process Patterns",
  "rule_id": "f35c5d71-b489-4e22-a115-f003df287317",
  "description": "Detects potential process patterns related to Cobalt Strike beacon activity",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1059"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hktl_cobaltstrike_process_patterns.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection_generic_1": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "endswith",
          "values": [
            "cmd.exe /C whoami"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "startswith",
          "values": [
            "C:\\Temp\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_generic_2": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\runonce.exe",
            "\\dllhost.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "cmd.exe /c echo",
            "> \\\\\\\\.\\\\pipe"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_conhost_1": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentCommandLine",
          "operator": "contains",
          "values": [
            "cmd.exe /C echo",
            " > \\\\\\\\.\\\\pipe"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "endswith",
          "values": [
            "conhost.exe 0xffffffff -ForceV1"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_conhost_2": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentCommandLine",
          "operator": "endswith",
          "values": [
            "/C whoami"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "endswith",
          "values": [
            "conhost.exe 0xffffffff -ForceV1"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "any",
    "pattern": "selection_*"
  }
}