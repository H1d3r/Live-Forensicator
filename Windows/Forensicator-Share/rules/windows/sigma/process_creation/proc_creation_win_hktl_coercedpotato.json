{
  "title": "HackTool - CoercedPotato Execution",
  "rule_id": "e8d34729-86a4-4140-adfd-0a29c2106307",
  "description": "Detects the use of CoercedPotato, a tool for privilege escalation",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.privilege-escalation",
    "attack.t1055"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hktl_coercedpotato.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_loader_img": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\CoercedPotato.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_params": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " --exploitId "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_loader_imphash": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Hashes",
          "operator": "contains",
          "values": [
            "IMPHASH=A75D7669DB6B2E107A44C4057FF7F7D6",
            "IMPHASH=F91624350E2C678C5DCBE5E1F24E22C9",
            "IMPHASH=14C81850A079A87E83D50CA41C709A15"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "any",
    "pattern": "selection_*"
  }
}