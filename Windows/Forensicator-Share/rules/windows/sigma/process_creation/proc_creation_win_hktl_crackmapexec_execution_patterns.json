{
  "title": "HackTool - CrackMapExec Execution Patterns",
  "rule_id": "058f4380-962d-40a5-afce-50207d36d7e2",
  "description": "Detects various execution patterns of the CrackMapExec pentesting framework",
  "level": "high",
  "status": "stable",
  "tags": [
    "attack.privilege-escalation",
    "attack.persistence",
    "attack.execution",
    "attack.t1047",
    "attack.t1053",
    "attack.t1059.003",
    "attack.t1059.001",
    "attack.s0106"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hktl_crackmapexec_execution_patterns.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "cmd.exe /Q /c * 1> \\\\\\\\*\\\\*\\\\* 2>&1",
            "cmd.exe /C * > \\\\\\\\*\\\\*\\\\* 2>&1",
            "cmd.exe /C * > *\\\\Temp\\\\* 2>&1",
            "powershell.exe -exec bypass -noni -nop -w 1 -C \"",
            "powershell.exe -noni -nop -w 1 -enc "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}