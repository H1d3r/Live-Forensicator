{
  "title": "HackTool - GMER Rootkit Detector and Remover Execution",
  "rule_id": "9082ff1f-88ab-4678-a3cc-5bcff99fc74d",
  "description": "Detects the execution GMER tool based on image and hash fields.",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hktl_gmer.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\gmer.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_sysmon_hash": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Hashes",
          "operator": "contains",
          "values": [
            "MD5=E9DC058440D321AA17D0600B3CA0AB04",
            "SHA1=539C228B6B332F5AA523E5CE358C16647D8BBE57",
            "SHA256=E8A3E804A96C716A3E9B69195DB6FFB0D33E2433AF871E4D4E1EAB3097237173"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "any",
    "pattern": "selection_*"
  }
}