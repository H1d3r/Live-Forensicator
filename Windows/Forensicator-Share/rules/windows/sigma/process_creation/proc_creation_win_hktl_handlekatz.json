{
  "title": "HackTool - HandleKatz LSASS Dumper Execution",
  "rule_id": "ca621ba5-54ab-4035-9942-d378e6fcde3c",
  "description": "Detects the use of HandleKatz, a tool that demonstrates the usage of cloned handles to Lsass in order to create an obfuscated memory dump of the same",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.credential-access",
    "attack.t1003.001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hktl_handlekatz.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_loader_img": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\loader.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "--pid:"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_loader_imphash": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Hashes",
          "operator": "contains",
          "values": [
            "IMPHASH=38D9E015591BBFD4929E0D0F47FA0055",
            "IMPHASH=0E2216679CA6E1094D63322E3412D650"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_flags": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "--pid:",
            "--outfile:"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            ".dmp",
            "lsass",
            ".obf",
            "dump"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "any",
    "pattern": "selection_*"
  }
}