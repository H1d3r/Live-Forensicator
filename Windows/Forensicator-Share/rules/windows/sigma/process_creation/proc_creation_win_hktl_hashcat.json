{
  "title": "HackTool - Hashcat Password Cracker Execution",
  "rule_id": "39b31e81-5f5f-4898-9c0e-2160cfc0f9bf",
  "description": "Execute Hashcat.exe with provided SAM file from registry of Windows and Password list to crack against",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.credential-access",
    "attack.t1110.002"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hktl_hashcat.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\hashcat.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "-a ",
            "-m 1000 ",
            "-r "
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "any",
    "pattern": "selection_*"
  }
}