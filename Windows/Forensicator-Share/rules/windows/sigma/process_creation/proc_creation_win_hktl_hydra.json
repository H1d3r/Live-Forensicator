{
  "title": "HackTool - Hydra Password Bruteforce Execution",
  "rule_id": "aaafa146-074c-11eb-adc1-0242ac120002",
  "description": "Detects command line parameters used by Hydra password guessing hack tool",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.credential-access",
    "attack.t1110",
    "attack.t1110.001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hktl_hydra.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "-u ",
            "-p "
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "^USER^",
            "^PASS^"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}