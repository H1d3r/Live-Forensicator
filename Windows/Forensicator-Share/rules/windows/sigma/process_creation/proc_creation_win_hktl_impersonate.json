{
  "title": "HackTool - Impersonate Execution",
  "rule_id": "cf0c254b-22f1-4b2b-8221-e137b3c0af94",
  "description": "Detects execution of the Impersonate tool. Which can be used to manipulate tokens on a Windows computers remotely (PsExec/WmiExec) or interactively",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.privilege-escalation",
    "attack.defense-evasion",
    "attack.t1134.001",
    "attack.t1134.003"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hktl_impersonate.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_commandline_exe": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "impersonate.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_commandline_opt": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " list ",
            " exec ",
            " adduser "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_hash": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Hashes",
          "operator": "contains",
          "values": [
            "MD5=9520714AB576B0ED01D1513691377D01",
            "SHA256=E81CC96E2118DC4FBFE5BAD1604E0AC7681960143E2101E1A024D52264BB0A8A",
            "IMPHASH=0A358FFC1697B7A07D0E817AC740DF62"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "any",
    "children": [
      {
        "type": "wildcard_ref",
        "mode": "all",
        "pattern": "selection_commandline_*"
      },
      {
        "type": "item_ref",
        "name": "selection_hash"
      }
    ]
  }
}