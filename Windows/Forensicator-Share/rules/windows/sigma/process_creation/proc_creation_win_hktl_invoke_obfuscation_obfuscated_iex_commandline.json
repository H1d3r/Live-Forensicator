{
  "title": "Invoke-Obfuscation Obfuscated IEX Invocation",
  "rule_id": "4bf943c6-5146-4273-98dd-e958fd1e3abf",
  "description": "Detects all variations of obfuscated powershell IEX invocation code generated by Invoke-Obfuscation framework from the following code block",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1027",
    "attack.execution",
    "attack.t1059.001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hktl_invoke_obfuscation_obfuscated_iex_commandline.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "re",
              "values": [
                "\\$PSHome\\[\\s*\\d{1,3}\\s*\\]\\s*\\+\\s*\\$PSHome\\["
              ],
              "match": "any",
              "windash": false,
              "ignore_case": false
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "re",
              "values": [
                "\\$ShellId\\[\\s*\\d{1,3}\\s*\\]\\s*\\+\\s*\\$ShellId\\["
              ],
              "match": "any",
              "windash": false,
              "ignore_case": false
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "re",
              "values": [
                "\\$env:Public\\[\\s*\\d{1,3}\\s*\\]\\s*\\+\\s*\\$env:Public\\["
              ],
              "match": "any",
              "windash": false,
              "ignore_case": false
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "re",
              "values": [
                "\\$env:ComSpec\\[(\\s*\\d{1,3}\\s*,){2}"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": false
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "re",
              "values": [
                "\\*mdr\\*\\W\\s*\\)\\.Name"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": false
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "re",
              "values": [
                "\\$VerbosePreference\\.ToString\\("
              ],
              "match": "any",
              "windash": false,
              "ignore_case": false
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "re",
              "values": [
                "\\[String\\]\\s*\\$VerbosePreference"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": false
            }
          ]
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}