{
  "title": "Invoke-Obfuscation COMPRESS OBFUSCATION",
  "rule_id": "7eedcc9d-9fdb-4d94-9c54-474e8affc0c7",
  "description": "Detects Obfuscated Powershell via COMPRESS OBFUSCATION",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1027",
    "attack.execution",
    "attack.t1059.001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hktl_invoke_obfuscation_via_compress.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "new-object",
            "text.encoding]::ascii"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "system.io.compression.deflatestream",
            "system.io.streamreader",
            "readtoend("
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}