{
  "title": "Invoke-Obfuscation Via Stdin",
  "rule_id": "9c14c9fa-1a63-4a64-8e57-d19280559490",
  "description": "Detects Obfuscated Powershell via Stdin in Scripts",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1027",
    "attack.execution",
    "attack.t1059.001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hktl_invoke_obfuscation_via_stdin.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "re",
          "values": [
            "(?i)(set).*&&\\s?set.*(environment|invoke|\\$\\{?input).*&&.*\""
          ],
          "match": "any",
          "windash": false,
          "ignore_case": false
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}