{
  "title": "Invoke-Obfuscation Via Use Clip",
  "rule_id": "e1561947-b4e3-4a74-9bdd-83baed21bdb5",
  "description": "Detects Obfuscated Powershell via use Clip.exe in Scripts",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1027",
    "attack.execution",
    "attack.t1059.001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hktl_invoke_obfuscation_via_use_clip.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "re",
          "values": [
            "(?i)echo.*clip.*&&.*(Clipboard|i`?n`?v`?o`?k`?e`?)"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": false
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}