{
  "title": "Invoke-Obfuscation Via Use MSHTA",
  "rule_id": "ac20ae82-8758-4f38-958e-b44a3140ca88",
  "description": "Detects Obfuscated Powershell via use MSHTA in Scripts",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1027",
    "attack.execution",
    "attack.t1059.001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hktl_invoke_obfuscation_via_use_mhsta.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "set",
            "&&",
            "mshta",
            "vbscript:createobject",
            ".run",
            "(window.close)"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}