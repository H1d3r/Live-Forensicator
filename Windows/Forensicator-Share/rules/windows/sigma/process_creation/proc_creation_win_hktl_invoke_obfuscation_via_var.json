{
  "title": "Invoke-Obfuscation VAR++ LAUNCHER OBFUSCATION",
  "rule_id": "e9f55347-2928-4c06-88e5-1a7f8169942e",
  "description": "Detects Obfuscated Powershell via VAR++ LAUNCHER",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1027",
    "attack.execution",
    "attack.t1059.001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hktl_invoke_obfuscation_via_var.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "&&set",
            "cmd",
            "/c",
            "-f"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "{0}",
            "{1}",
            "{2}",
            "{3}",
            "{4}",
            "{5}"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}