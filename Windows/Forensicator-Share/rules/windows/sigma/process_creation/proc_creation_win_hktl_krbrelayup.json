{
  "title": "HackTool - KrbRelayUp Execution",
  "rule_id": "12827a56-61a4-476a-a9cb-f3068f191073",
  "description": "Detects KrbRelayUp used to perform a universal no-fix local privilege escalation in Windows domain environments where LDAP signing is not enforced",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.credential-access",
    "attack.t1558.003",
    "attack.lateral-movement",
    "attack.t1550.003"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hktl_krbrelayup.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\KrbRelayUp.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "KrbRelayUp.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_cli_1": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " relay ",
            " -Domain ",
            " -ComputerName "
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_cli_2": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " krbscm ",
            " -sc "
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_cli_3": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " spawn ",
            " -d ",
            " -cn ",
            " -cp "
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "any",
    "pattern": "selection_*"
  }
}