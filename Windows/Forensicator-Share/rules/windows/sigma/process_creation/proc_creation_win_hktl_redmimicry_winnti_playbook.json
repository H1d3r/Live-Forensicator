{
  "title": "HackTool - RedMimicry Winnti Playbook Execution",
  "rule_id": "95022b85-ff2a-49fa-939a-d7b8f56eeb9b",
  "description": "Detects actions caused by the RedMimicry Winnti playbook a automated breach emulations utility",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.defense-evasion",
    "attack.t1106",
    "attack.t1059.003",
    "attack.t1218.011"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hktl_redmimicry_winnti_playbook.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\rundll32.exe",
            "\\cmd.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "gthread-3.6.dll",
            "\\Windows\\Temp\\tmp.bat",
            "sigcmm-2.4.dll"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}