{
  "title": "HackTool - Rubeus Execution",
  "rule_id": "7ec2c172-dceb-4c10-92c9-87c1881b7e18",
  "description": "Detects the execution of the hacktool Rubeus via PE information of command line parameters",
  "level": "critical",
  "status": "stable",
  "tags": [
    "attack.defense-evasion",
    "attack.credential-access",
    "attack.t1003",
    "attack.t1558.003",
    "attack.lateral-movement",
    "attack.t1550.003"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hktl_rubeus.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\Rubeus.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "Rubeus.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Description",
              "operator": "exact",
              "values": [
                "Rubeus"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "contains",
              "values": [
                "asreproast ",
                "dump /service:krbtgt ",
                "dump /luid:0x",
                "kerberoast ",
                "createnetonly /program:",
                "ptt /ticket:",
                "/impersonateuser:",
                "renew /ticket:",
                "asktgt /user:",
                "harvest /interval:",
                "s4u /user:",
                "s4u /ticket:",
                "hash /password:",
                "golden /aes256:",
                "silver /user:"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}