{
  "title": "HackTool - SecurityXploded Execution",
  "rule_id": "7679d464-4f74-45e2-9e01-ac66c5eb041a",
  "description": "Detects the execution of SecurityXploded Tools",
  "level": "critical",
  "status": "stable",
  "tags": [
    "attack.credential-access",
    "attack.t1555"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hktl_secutyxploded.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Company",
              "operator": "exact",
              "values": [
                "SecurityXploded"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "PasswordDump.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "endswith",
              "values": [
                "PasswordDump.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}