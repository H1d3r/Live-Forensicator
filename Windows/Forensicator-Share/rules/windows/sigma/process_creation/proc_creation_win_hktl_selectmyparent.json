{
  "title": "HackTool - PPID Spoofing SelectMyParent Tool Execution",
  "rule_id": "52ff7941-8211-46f9-84f8-9903efb7077d",
  "description": "Detects the use of parent process ID spoofing tools like Didier Stevens tool SelectMyParent",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.privilege-escalation",
    "attack.defense-evasion",
    "attack.t1134.004"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hktl_selectmyparent.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\SelectMyParent.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "contains",
              "values": [
                "PPID-spoof",
                "ppid_spoof",
                "spoof-ppid",
                "spoof_ppid",
                "ppidspoof",
                "spoofppid",
                "spoofedppid",
                " -spawnto "
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "contains",
              "values": [
                "PPID-spoof",
                "ppid_spoof",
                "spoof-ppid",
                "spoof_ppid",
                "ppidspoof",
                "spoofppid",
                "spoofedppid"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Description",
              "operator": "exact",
              "values": [
                "SelectMyParent"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Hashes",
              "operator": "contains",
              "values": [
                "IMPHASH=04D974875BD225F00902B4CAD9AF3FBC",
                "IMPHASH=A782AF154C9E743DDF3F3EB2B8F3D16E",
                "IMPHASH=89059503D7FBF470E68F7E63313DA3AD",
                "IMPHASH=CA28337632625C8281AB8A130B3D6BAD"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}