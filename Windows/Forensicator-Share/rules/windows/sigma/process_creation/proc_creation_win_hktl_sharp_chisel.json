{
  "title": "HackTool - SharpChisel Execution",
  "rule_id": "cf93e05e-d798-4d9e-b522-b0248dc61eaf",
  "description": "Detects usage of the Sharp Chisel via the commandline arguments",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.command-and-control",
    "attack.t1090.001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hktl_sharp_chisel.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\SharpChisel.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Product",
              "operator": "exact",
              "values": [
                "SharpChisel"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}