{
  "title": "HackTool - SharpDPAPI Execution",
  "rule_id": "c7d33b50-f690-4b51-8cfb-0fb912a31e57",
  "description": "Detects the execution of the SharpDPAPI tool based on CommandLine flags and PE metadata.\nSharpDPAPI is a C# port of some DPAPI functionality from the Mimikatz project.\n",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.privilege-escalation",
    "attack.defense-evasion",
    "attack.t1134.001",
    "attack.t1134.003"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hktl_sharp_dpapi_execution.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\SharpDPAPI.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "SharpDPAPI.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_other_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " backupkey ",
            " blob ",
            " certificates ",
            " credentials ",
            " keepass ",
            " masterkeys ",
            " rdg ",
            " vaults "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_other_options_guid": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " {",
            "}:"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_other_options_flags": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " /file:",
            " /machine",
            " /mkfile:",
            " /password:",
            " /pvk:",
            " /server:",
            " /target:",
            " /unprotect"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "any",
    "children": [
      {
        "type": "item_ref",
        "name": "selection_img"
      },
      {
        "type": "all",
        "children": [
          {
            "type": "item_ref",
            "name": "selection_other_cli"
          },
          {
            "type": "wildcard_ref",
            "mode": "any",
            "pattern": "selection_other_options_*"
          }
        ]
      }
    ]
  }
}