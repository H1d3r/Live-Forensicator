{
  "title": "HackTool - SharpEvtMute Execution",
  "rule_id": "bedfc8ad-d1c7-4e37-a20e-e2b0dbee759c",
  "description": "Detects the use of SharpEvtHook, a tool that tampers with the Windows event logs",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1562.002"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hktl_sharpevtmute.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\SharpEvtMute.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Description",
              "operator": "exact",
              "values": [
                "SharpEvtMute"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "contains",
              "values": [
                "--Filter \"rule ",
                "--Encoded --Filter \\\""
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}