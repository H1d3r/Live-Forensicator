{
  "title": "HackTool - SharpLdapWhoami Execution",
  "rule_id": "d9367cbb-c2e0-47ce-bdc0-128cb6da898d",
  "description": "Detects SharpLdapWhoami, a whoami alternative that queries the LDAP service on a domain controller",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.discovery",
    "attack.t1033",
    "car.2016-03-001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hktl_sharpldapwhoami.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_name": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\SharpLdapWhoami.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_pe": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "contains",
              "values": [
                "SharpLdapWhoami"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Product",
              "operator": "exact",
              "values": [
                "SharpLdapWhoami"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_flags1": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "endswith",
          "values": [
            " /method:ntlm",
            " /method:kerb",
            " /method:nego",
            " /m:nego",
            " /m:ntlm",
            " /m:kerb"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "any",
    "pattern": "selection*"
  }
}