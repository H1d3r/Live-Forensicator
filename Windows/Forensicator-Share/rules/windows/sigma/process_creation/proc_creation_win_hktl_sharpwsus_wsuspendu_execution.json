{
  "title": "HackTool - SharpWSUS/WSUSpendu Execution",
  "rule_id": "b0ce780f-10bd-496d-9067-066d23dc3aa5",
  "description": "Detects the execution of SharpWSUS or WSUSpendu, utilities that allow for lateral movement through WSUS.\nWindows Server Update Services (WSUS) is a critical component of Windows systems and is frequently configured in a way that allows an attacker to circumvent internal networking limitations.\n",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.lateral-movement",
    "attack.t1210"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hktl_sharpwsus_wsuspendu_execution.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection_wsuspendu_inject": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " -Inject "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_wsuspendu_payload": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " -PayloadArgs ",
            " -PayloadFile "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_sharpwsus_commands": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " approve ",
            " create ",
            " check ",
            " delete "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_sharpwsus_flags": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " /payload:",
            " /payload=",
            " /updateid:",
            " /updateid="
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "any",
    "children": [
      {
        "type": "wildcard_ref",
        "mode": "all",
        "pattern": "selection_wsuspendu_*"
      },
      {
        "type": "wildcard_ref",
        "mode": "all",
        "pattern": "selection_sharpwsus_*"
      }
    ]
  }
}