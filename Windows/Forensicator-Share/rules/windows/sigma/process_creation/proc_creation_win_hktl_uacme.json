{
  "title": "HackTool - UACMe Akagi Execution",
  "rule_id": "d38d2fa4-98e6-4a24-aff1-410b0c9ad177",
  "description": "Detects the execution of UACMe, a tool used for UAC bypasses, via default PE metadata",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.privilege-escalation",
    "attack.t1548.002"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hktl_uacme.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_pe": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Product",
              "operator": "exact",
              "values": [
                "UACMe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Company",
              "operator": "exact",
              "values": [
                "REvol Corp",
                "APT 92",
                "UG North",
                "Hazardous Environments",
                "CD Project Rekt"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Description",
              "operator": "exact",
              "values": [
                "UACMe main module",
                "Pentesting utility"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "Akagi.exe",
                "Akagi64.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_img": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\Akagi64.exe",
            "\\Akagi.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_hashes_sysmon": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Hashes",
          "operator": "contains",
          "values": [
            "IMPHASH=767637C23BB42CD5D7397CF58B0BE688",
            "IMPHASH=14C4E4C72BA075E9069EE67F39188AD8",
            "IMPHASH=3C782813D4AFCE07BBFC5A9772ACDBDC",
            "IMPHASH=7D010C6BB6A3726F327F7E239166D127",
            "IMPHASH=89159BA4DD04E4CE5559F132A9964EB3",
            "IMPHASH=6F33F4A5FC42B8CEC7314947BD13F30F",
            "IMPHASH=5834ED4291BDEB928270428EBBAF7604",
            "IMPHASH=5A8A8A43F25485E7EE1B201EDCBC7A38",
            "IMPHASH=DC7D30B90B2D8ABF664FBED2B1B59894",
            "IMPHASH=41923EA1F824FE63EA5BEB84DB7A3E74",
            "IMPHASH=3DE09703C8E79ED2CA3F01074719906B"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "any",
    "pattern": "selection_*"
  }
}