{
  "title": "HackTool - winPEAS Execution",
  "rule_id": "98b53e78-ebaf-46f8-be06-421aafd176d9",
  "description": "WinPEAS is a script that search for possible paths to escalate privileges on Windows hosts. The checks are explained on book.hacktricks.xyz",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.privilege-escalation",
    "attack.discovery",
    "attack.t1082",
    "attack.t1087",
    "attack.t1046"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hktl_winpeas.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "winPEAS.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\winPEASany_ofs.exe",
                "\\winPEASany.exe",
                "\\winPEASx64_ofs.exe",
                "\\winPEASx64.exe",
                "\\winPEASx86_ofs.exe",
                "\\winPEASx86.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_cli_option": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " applicationsinfo",
            " browserinfo",
            " eventsinfo",
            " fileanalysis",
            " filesinfo",
            " processinfo",
            " servicesinfo",
            " windowscreds"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_cli_dl": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "https://github.com/carlospolop/PEASS-ng/releases/latest/download/"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_cli_specific": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "ParentCommandLine",
              "operator": "endswith",
              "values": [
                " -linpeas"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "endswith",
              "values": [
                " -linpeas"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "any",
    "pattern": "selection_*"
  }
}