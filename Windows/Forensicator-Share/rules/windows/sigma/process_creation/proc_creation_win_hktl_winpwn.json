{
  "title": "HackTool - WinPwn Execution",
  "rule_id": "d557dc06-62e8-4468-a8e8-7984124908ce",
  "description": "Detects commandline keywords indicative of potential usge of the tool WinPwn. A tool for Windows and Active Directory reconnaissance and exploitation.\n",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.credential-access",
    "attack.defense-evasion",
    "attack.discovery",
    "attack.execution",
    "attack.privilege-escalation",
    "attack.t1046",
    "attack.t1082",
    "attack.t1106",
    "attack.t1518",
    "attack.t1548.002",
    "attack.t1552.001",
    "attack.t1555",
    "attack.t1555.003"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hktl_winpwn.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "Offline_Winpwn",
            "WinPwn ",
            "WinPwn.exe",
            "WinPwn.ps1"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}