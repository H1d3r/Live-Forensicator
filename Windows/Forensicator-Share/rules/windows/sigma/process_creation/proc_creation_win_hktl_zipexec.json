{
  "title": "Suspicious ZipExec Execution",
  "rule_id": "90dcf730-1b71-4ae7-9ffc-6fcf62bd0132",
  "description": "ZipExec is a Proof-of-Concept (POC) tool to wrap binary-based tools into a password-protected zip file.",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.defense-evasion",
    "attack.t1218",
    "attack.t1202"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hktl_zipexec.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "run": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "/generic:Microsoft_Windows_Shell_ZipFolder:filename=",
            ".zip",
            "/pass:",
            "/user:"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "delete": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "/delete",
            "Microsoft_Windows_Shell_ZipFolder:filename=",
            ".zip"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "any",
    "children": [
      {
        "type": "item_ref",
        "name": "run"
      },
      {
        "type": "item_ref",
        "name": "delete"
      }
    ]
  }
}