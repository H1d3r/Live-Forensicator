{
  "title": "Suspicious Execution of Hostname",
  "rule_id": "7be5fb68-f9ef-476d-8b51-0256ebece19e",
  "description": "Use of hostname to get information",
  "level": "low",
  "status": "test",
  "tags": [
    "attack.discovery",
    "attack.t1082"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_hostname_execution.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\HOSTNAME.EXE"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}