{
  "title": "Microsoft IIS Service Account Password Dumped",
  "rule_id": "2d3cdeec-c0db-45b4-aa86-082f7eb75701",
  "description": "Detects the Internet Information Services (IIS) command-line tool, AppCmd, being used to list passwords",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.credential-access",
    "attack.t1003"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_iis_appcmd_service_account_password_dumped.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_base_name": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\appcmd.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "appcmd.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_base_list": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "list "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_standalone": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " /config",
            " /xml",
            " -config",
            " -xml"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_cmd_flags": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " /@t",
            " /text",
            " /show",
            " -@t",
            " -text",
            " -show"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_cmd_grep": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            ":\\*",
            "password"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "wildcard_ref",
        "mode": "all",
        "pattern": "selection_base_*"
      },
      {
        "type": "any",
        "children": [
          {
            "type": "item_ref",
            "name": "selection_standalone"
          },
          {
            "type": "wildcard_ref",
            "mode": "all",
            "pattern": "selection_cmd_*"
          }
        ]
      }
    ]
  }
}