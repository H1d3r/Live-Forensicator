{
  "title": "Suspicious IIS URL GlobalRules Rewrite Via AppCmd",
  "rule_id": "7c8af9b2-dcae-41a2-a9db-b28c288b5f08",
  "description": "Detects usage of \"appcmd\" to create new global URL rewrite rules. This behaviour has been observed being used by threat actors to add new rules so they can access their webshells.",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_iis_appcmd_susp_rewrite_rule.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\appcmd.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "appcmd.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "set",
            "config",
            "section:system.webServer/rewrite/globalRules",
            "commit:"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}