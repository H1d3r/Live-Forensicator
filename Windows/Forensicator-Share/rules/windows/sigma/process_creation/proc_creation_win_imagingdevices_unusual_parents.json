{
  "title": "ImagingDevices Unusual Parent/Child Processes",
  "rule_id": "f11f2808-adb4-46c0-802a-8660db50fa99",
  "description": "Detects unusual parent or children of the ImagingDevices.exe (Windows Contacts) process as seen being used with Bumblebee activity",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.execution"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_imagingdevices_unusual_parents.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection_parent": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\WmiPrvSE.exe",
            "\\svchost.exe",
            "\\dllhost.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\ImagingDevices.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_child": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\ImagingDevices.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "any",
    "pattern": "selection_*"
  }
}