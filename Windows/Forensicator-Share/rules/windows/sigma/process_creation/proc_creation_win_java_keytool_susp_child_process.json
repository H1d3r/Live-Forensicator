{
  "title": "Suspicious Shells Spawn by Java Utility Keytool",
  "rule_id": "90fb5e62-ca1f-4e22-b42e-cc521874c938",
  "description": "Detects suspicious shell spawn from Java utility keytool process (e.g. adselfservice plus exploitation)",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.initial-access",
    "attack.persistence",
    "attack.privilege-escalation"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_java_keytool_susp_child_process.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\keytool.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\cmd.exe",
            "\\sh.exe",
            "\\bash.exe",
            "\\powershell.exe",
            "\\pwsh.exe",
            "\\schtasks.exe",
            "\\certutil.exe",
            "\\whoami.exe",
            "\\bitsadmin.exe",
            "\\wscript.exe",
            "\\cscript.exe",
            "\\scrcons.exe",
            "\\regsvr32.exe",
            "\\hh.exe",
            "\\wmic.exe",
            "\\mshta.exe",
            "\\rundll32.exe",
            "\\forfiles.exe",
            "\\scriptrunner.exe",
            "\\mftrace.exe",
            "\\AppVLP.exe",
            "\\systeminfo.exe",
            "\\reg.exe",
            "\\query.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}