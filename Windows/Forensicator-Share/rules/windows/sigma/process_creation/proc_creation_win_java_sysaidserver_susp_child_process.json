{
  "title": "Suspicious SysAidServer Child",
  "rule_id": "60bfeac3-0d35-4302-8efb-1dd16f715bc6",
  "description": "Detects suspicious child processes of SysAidServer (as seen in MERCURY threat actor intrusions)",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.lateral-movement",
    "attack.t1210"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_java_sysaidserver_susp_child_process.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\java.exe",
            "\\javaw.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "ParentCommandLine",
          "operator": "contains",
          "values": [
            "SysAidServer"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}