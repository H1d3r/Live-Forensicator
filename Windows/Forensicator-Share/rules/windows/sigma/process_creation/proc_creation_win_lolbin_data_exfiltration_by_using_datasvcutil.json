{
  "title": "LOLBAS Data Exfiltration by DataSvcUtil.exe",
  "rule_id": "e290b10b-1023-4452-a4a9-eb31a9013b3a",
  "description": "Detects when a user performs data exfiltration by using DataSvcUtil.exe",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.exfiltration",
    "attack.t1567"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_lolbin_data_exfiltration_by_using_datasvcutil.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "/in:",
            "/out:",
            "/uri:"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\DataSvcUtil.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "DataSvcUtil.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection*"
  }
}