{
  "title": "Use of OpenConsole",
  "rule_id": "814c95cc-8192-4378-a70a-f1aafd877af1",
  "description": "Detects usage of OpenConsole binary as a LOLBIN to launch other binaries to bypass application Whitelisting",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1059"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_lolbin_openconsole.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "OpenConsole.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\OpenConsole.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "filter": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "startswith",
          "values": [
            "C:\\Program Files\\WindowsApps\\Microsoft.WindowsTerminal"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "item_ref",
          "name": "filter"
        }
      }
    ]
  }
}