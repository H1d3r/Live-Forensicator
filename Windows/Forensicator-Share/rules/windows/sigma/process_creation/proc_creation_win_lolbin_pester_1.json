{
  "title": "Execute Code with Pester.bat",
  "rule_id": "59e938ff-0d6d-4dc3-b13f-36cc28734d4e",
  "description": "Detects code execution via Pester.bat (Pester - Powershell Modulte for testing)",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1059.001",
    "attack.defense-evasion",
    "attack.t1216"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_lolbin_pester_1.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "powershell_module": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\powershell.exe",
            "\\pwsh.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "Pester",
            "Get-Help"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "cmd_execution": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\cmd.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "pester",
            ";"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "get_help": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "help",
            "\\?"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "any",
    "children": [
      {
        "type": "item_ref",
        "name": "powershell_module"
      },
      {
        "type": "all",
        "children": [
          {
            "type": "item_ref",
            "name": "cmd_execution"
          },
          {
            "type": "item_ref",
            "name": "get_help"
          }
        ]
      }
    ]
  }
}