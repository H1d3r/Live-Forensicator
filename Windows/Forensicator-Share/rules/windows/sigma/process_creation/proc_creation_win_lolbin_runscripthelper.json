{
  "title": "Suspicious Runscripthelper.exe",
  "rule_id": "eca49c87-8a75-4f13-9c73-a5a29e845f03",
  "description": "Detects execution of powershell scripts via Runscripthelper.exe",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1059",
    "attack.defense-evasion",
    "attack.t1202"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_lolbin_runscripthelper.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\Runscripthelper.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "surfacecheck"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}