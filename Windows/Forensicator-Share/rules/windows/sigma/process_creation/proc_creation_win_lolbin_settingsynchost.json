{
  "title": "Using SettingSyncHost.exe as LOLBin",
  "rule_id": "b2ddd389-f676-4ac4-845a-e00781a48e5f",
  "description": "Detects using SettingSyncHost.exe to run hijacked binary",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.privilege-escalation",
    "attack.persistence",
    "attack.execution",
    "attack.defense-evasion",
    "attack.t1574.008"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_lolbin_settingsynchost.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "system_utility": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "startswith",
          "values": [
            "C:\\Windows\\System32\\",
            "C:\\Windows\\SysWOW64\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "parent_is_settingsynchost": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentCommandLine",
          "operator": "contains",
          "values": [
            "cmd.exe /c",
            "RoamDiag.cmd",
            "-outputpath"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "not",
        "child": {
          "type": "item_ref",
          "name": "system_utility"
        }
      },
      {
        "type": "item_ref",
        "name": "parent_is_settingsynchost"
      }
    ]
  }
}