{
  "title": "Time Travel Debugging Utility Usage",
  "rule_id": "0b4ae027-2a2d-4b93-8c7e-962caaba5b2a",
  "description": "Detects usage of Time Travel Debugging Utility. Adversaries can execute malicious processes and dump processes, such as lsass.exe, via tttracer.exe.",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.credential-access",
    "attack.t1218",
    "attack.t1003.001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_lolbin_tttracer_mod_load.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\tttracer.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}