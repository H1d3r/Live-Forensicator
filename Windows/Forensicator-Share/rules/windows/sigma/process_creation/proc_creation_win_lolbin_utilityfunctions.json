{
  "title": "UtilityFunctions.ps1 Proxy Dll",
  "rule_id": "0403d67d-6227-4ea8-8145-4e72db7da120",
  "description": "Detects the use of a Microsoft signed script executing a managed DLL with PowerShell.",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1216"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_lolbin_utilityfunctions.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "UtilityFunctions.ps1",
            "RegSnapin "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}