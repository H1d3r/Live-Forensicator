{
  "title": "Suspicious MSHTA Child Process",
  "rule_id": "03cc0c25-389f-4bf8-b48d-11878079f1ca",
  "description": "Detects a suspicious process spawning from an \"mshta.exe\" process, which could be indicative of a malicious HTA script execution",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1218.005",
    "car.2013-02-003",
    "car.2013-03-001",
    "car.2014-04-003"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_mshta_susp_child_processes.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_parent": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\mshta.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_child": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\cmd.exe",
                "\\powershell.exe",
                "\\pwsh.exe",
                "\\wscript.exe",
                "\\cscript.exe",
                "\\sh.exe",
                "\\bash.exe",
                "\\reg.exe",
                "\\regsvr32.exe",
                "\\bitsadmin.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "Cmd.Exe",
                "PowerShell.EXE",
                "pwsh.dll",
                "wscript.exe",
                "cscript.exe",
                "Bash.exe",
                "reg.exe",
                "REGSVR32.EXE",
                "bitsadmin.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection*"
  }
}