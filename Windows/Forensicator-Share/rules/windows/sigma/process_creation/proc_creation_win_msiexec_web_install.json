{
  "title": "MsiExec Web Install",
  "rule_id": "f7b5f842-a6af-4da5-9e95-e32478f3cd2f",
  "description": "Detects suspicious msiexec process starts with web addresses as parameter",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1218.007",
    "attack.command-and-control",
    "attack.t1105"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_msiexec_web_install.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " msiexec",
            "://"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}