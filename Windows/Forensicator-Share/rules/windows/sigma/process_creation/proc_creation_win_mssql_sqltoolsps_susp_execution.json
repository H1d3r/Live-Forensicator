{
  "title": "SQL Client Tools PowerShell Session Detection",
  "rule_id": "a746c9b8-a2fb-4ee5-a428-92bee9e99060",
  "description": "This rule detects execution of a PowerShell code through the sqltoolsps.exe utility, which is included in the standard set of utilities supplied with the Microsoft SQL Server Management studio.\nScript blocks are not logged in this case, so this utility helps to bypass protection mechanisms based on the analysis of these logs.\n",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1059.001",
    "attack.defense-evasion",
    "attack.t1127"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_mssql_sqltoolsps_susp_execution.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\sqltoolsps.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "ParentImage",
              "operator": "endswith",
              "values": [
                "\\sqltoolsps.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "\\sqltoolsps.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "filter": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\smss.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "item_ref",
          "name": "filter"
        }
      }
    ]
  }
}