{
  "title": "Suspicious Mstsc.EXE Execution With Local RDP File",
  "rule_id": "6e22722b-dfb1-4508-a911-49ac840b40f8",
  "description": "Detects potential RDP connection via Mstsc using a local \".rdp\" file located in suspicious locations.",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.command-and-control",
    "attack.t1219.002"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_mstsc_run_local_rdp_file_susp_location.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\mstsc.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "mstsc.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_extension": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "endswith",
          "values": [
            ".rdp",
            ".rdp\""
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_paths": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            ":\\Users\\Public\\",
            ":\\Windows\\System32\\spool\\drivers\\color",
            ":\\Windows\\System32\\Tasks_Migrated ",
            ":\\Windows\\Tasks\\",
            ":\\Windows\\Temp\\",
            ":\\Windows\\Tracing\\",
            "\\AppData\\Local\\Temp\\",
            "\\Downloads\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}