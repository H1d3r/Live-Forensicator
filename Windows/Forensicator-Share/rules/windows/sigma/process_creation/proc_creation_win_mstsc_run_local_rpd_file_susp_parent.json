{
  "title": "Mstsc.EXE Execution From Uncommon Parent",
  "rule_id": "ff3b6b39-e765-42f9-bb2c-ea6761e0e0f6",
  "description": "Detects potential RDP connection via Mstsc using a local \".rdp\" file located in suspicious locations.",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.lateral-movement"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_mstsc_run_local_rpd_file_susp_parent.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_parent": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\brave.exe",
            "\\CCleanerBrowser.exe",
            "\\chrome.exe",
            "\\chromium.exe",
            "\\firefox.exe",
            "\\iexplore.exe",
            "\\microsoftedge.exe",
            "\\msedge.exe",
            "\\opera.exe",
            "\\vivaldi.exe",
            "\\whale.exe",
            "\\outlook.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\mstsc.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "mstsc.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}