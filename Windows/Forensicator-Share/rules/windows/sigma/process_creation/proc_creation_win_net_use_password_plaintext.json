{
  "title": "Password Provided In Command Line Of Net.EXE",
  "rule_id": "d4498716-1d52-438f-8084-4a603157d131",
  "description": "Detects a when net.exe is called with a password in the command line",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.initial-access",
    "attack.persistence",
    "attack.privilege-escalation",
    "attack.lateral-movement",
    "attack.t1021.002",
    "attack.t1078"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_net_use_password_plaintext.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\net.exe",
                "\\net1.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "net.exe",
                "net1.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " use ",
            ":*\\\\",
            "/USER:* *"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_empty": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "endswith",
          "values": [
            " "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "wildcard_ref",
        "mode": "all",
        "pattern": "selection_*"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_main_*"
        }
      }
    ]
  }
}