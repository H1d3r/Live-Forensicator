{
  "title": "Suspicious Program Location Whitelisted In Firewall Via Netsh.EXE",
  "rule_id": "a35f5a72-f347-4e36-8895-9869b0d5fc6d",
  "description": "Detects Netsh command execution that whitelists a program located in a suspicious location in the Windows Firewall",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1562.004"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_netsh_fw_allow_program_in_susp_location.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\netsh.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "netsh.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_cli": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "contains",
              "values": [
                "firewall",
                "add",
                "allowedprogram"
              ],
              "match": "all",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "contains",
              "values": [
                "advfirewall",
                "firewall",
                "add",
                "rule",
                "action=allow",
                "program="
              ],
              "match": "all",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_paths": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            ":\\$Recycle.bin\\",
            ":\\RECYCLER.BIN\\",
            ":\\RECYCLERS.BIN\\",
            ":\\SystemVolumeInformation\\",
            ":\\Temp\\",
            ":\\Users\\Default\\",
            ":\\Users\\Desktop\\",
            ":\\Users\\Public\\",
            ":\\Windows\\addins\\",
            ":\\Windows\\cursors\\",
            ":\\Windows\\debug\\",
            ":\\Windows\\drivers\\",
            ":\\Windows\\fonts\\",
            ":\\Windows\\help\\",
            ":\\Windows\\system32\\tasks\\",
            ":\\Windows\\Tasks\\",
            ":\\Windows\\Temp\\",
            "\\Downloads\\",
            "\\Local Settings\\Temporary Internet Files\\",
            "\\Temporary Internet Files\\Content.Outlook\\",
            "%Public%\\",
            "%TEMP%",
            "%TMP%"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}