{
  "title": "Firewall Configuration Discovery Via Netsh.EXE",
  "rule_id": "0e4164da-94bc-450d-a7be-a4b176179f1f",
  "description": "Adversaries may look for details about the network configuration and settings of systems they access or through information discovery of remote systems",
  "level": "low",
  "status": "test",
  "tags": [
    "attack.discovery",
    "attack.t1016"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_netsh_fw_rules_discovery.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\netsh.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "netsh.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "netsh",
            "show ",
            "firewall "
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "config ",
            "state ",
            "rule ",
            "name=all"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}