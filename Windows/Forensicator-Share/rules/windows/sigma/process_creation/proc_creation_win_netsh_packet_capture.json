{
  "title": "New Network Trace Capture Started Via Netsh.EXE",
  "rule_id": "d3c3861d-c504-4c77-ba55-224ba82d0118",
  "description": "Detects the execution of netsh with the \"trace\" flag in order to start a network capture",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.discovery",
    "attack.credential-access",
    "attack.t1040"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_netsh_packet_capture.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\netsh.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "netsh.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "trace",
            "start"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}