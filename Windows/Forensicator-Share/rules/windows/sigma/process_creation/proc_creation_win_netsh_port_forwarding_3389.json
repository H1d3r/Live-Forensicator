{
  "title": "RDP Port Forwarding Rule Added Via Netsh.EXE",
  "rule_id": "782d6f3e-4c5d-4b8c-92a3-1d05fed72e63",
  "description": "Detects the execution of netsh to configure a port forwarding of port 3389 (RDP) rule",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.lateral-movement",
    "attack.defense-evasion",
    "attack.command-and-control",
    "attack.t1090"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_netsh_port_forwarding_3389.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\netsh.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "netsh.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " i",
            " p",
            "=3389",
            " c"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}