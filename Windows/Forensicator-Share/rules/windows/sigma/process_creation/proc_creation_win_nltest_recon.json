{
  "title": "Potential Recon Activity Via Nltest.EXE",
  "rule_id": "5cc90652-4cbd-4241-aa3b-4b462fa5a248",
  "description": "Detects nltest commands that can be used for information discovery",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.discovery",
    "attack.t1016",
    "attack.t1482"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_nltest_recon.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_nltest": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\nltest.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "nltestrk.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_recon": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "contains",
              "values": [
                "server",
                "query"
              ],
              "match": "all",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "contains",
              "values": [
                "/user",
                "all_trusts",
                "dclist:",
                "dnsgetdc:",
                "domain_trusts",
                "dsgetdc:",
                "parentdomain",
                "trusted_domains"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}