{
  "title": "Node Process Executions",
  "rule_id": "df1f26d3-bea7-4700-9ea2-ad3e990cf90e",
  "description": "Detects the execution of other scripts using the Node executable packaged with Adobe Creative Cloud",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.execution",
    "attack.t1127",
    "attack.t1059.007"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_node_adobe_creative_cloud_abuse.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\Adobe Creative Cloud Experience\\libs\\node.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "Adobe Creative Cloud Experience\\js"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "item_ref",
          "name": "filter"
        }
      }
    ]
  }
}