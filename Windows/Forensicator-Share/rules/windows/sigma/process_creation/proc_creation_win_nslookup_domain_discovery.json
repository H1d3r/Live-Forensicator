{
  "title": "Network Reconnaissance Activity",
  "rule_id": "e6313acd-208c-44fc-a0ff-db85d572e90e",
  "description": "Detects a set of suspicious network related commands often used in recon stages",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.discovery",
    "attack.t1087",
    "attack.t1082",
    "car.2016-03-001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_nslookup_domain_discovery.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "nslookup",
            "_ldap._tcp.dc._msdcs."
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}