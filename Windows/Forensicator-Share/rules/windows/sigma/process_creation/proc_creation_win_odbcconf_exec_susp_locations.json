{
  "title": "Odbcconf.EXE Suspicious DLL Location",
  "rule_id": "6b65c28e-11f3-46cb-902a-68f2cafaf474",
  "description": "Detects execution of \"odbcconf\" where the path of the DLL being registered is located in a potentially suspicious location.",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1218.008"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_odbcconf_exec_susp_locations.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\odbcconf.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "odbcconf.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            ":\\PerfLogs\\",
            ":\\ProgramData\\",
            ":\\Temp\\",
            ":\\Users\\Public\\",
            ":\\Windows\\Registration\\CRMLog",
            ":\\Windows\\System32\\com\\dmp\\",
            ":\\Windows\\System32\\FxsTmp\\",
            ":\\Windows\\System32\\Microsoft\\Crypto\\RSA\\MachineKeys\\",
            ":\\Windows\\System32\\spool\\drivers\\color\\",
            ":\\Windows\\System32\\spool\\PRINTERS\\",
            ":\\Windows\\System32\\spool\\SERVERS\\",
            ":\\Windows\\System32\\Tasks_Migrated\\",
            ":\\Windows\\System32\\Tasks\\Microsoft\\Windows\\SyncCenter\\",
            ":\\Windows\\SysWOW64\\com\\dmp\\",
            ":\\Windows\\SysWOW64\\FxsTmp\\",
            ":\\Windows\\SysWOW64\\Tasks\\Microsoft\\Windows\\PLA\\System\\",
            ":\\Windows\\SysWOW64\\Tasks\\Microsoft\\Windows\\SyncCenter\\",
            ":\\Windows\\Tasks\\",
            ":\\Windows\\Temp\\",
            ":\\Windows\\Tracing\\",
            "\\AppData\\Local\\Temp\\",
            "\\AppData\\Roaming\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}