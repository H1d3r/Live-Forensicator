{
  "title": "Potential Arbitrary File Download Using Office Application",
  "rule_id": "4ae3e30b-b03f-43aa-87e3-b622f4048eed",
  "description": "Detects potential arbitrary file download using a Microsoft Office application",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1202"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_office_arbitrary_cli_download.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\EXCEL.EXE",
                "\\POWERPNT.EXE",
                "\\WINWORD.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "Excel.exe",
                "POWERPNT.EXE",
                "WinWord.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_http": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "http://",
            "https://"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}