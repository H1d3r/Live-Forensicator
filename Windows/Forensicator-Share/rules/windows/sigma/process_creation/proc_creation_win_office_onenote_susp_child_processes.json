{
  "title": "Suspicious Microsoft OneNote Child Process",
  "rule_id": "c27515df-97a9-4162-8a60-dc0eeb51b775",
  "description": "Detects suspicious child processes of the Microsoft OneNote application. This may indicate an attempt to execute malicious embedded objects from a .one file.",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.t1566",
    "attack.t1566.001",
    "attack.initial-access"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_office_onenote_susp_child_processes.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_parent": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\onenote.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_opt_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "bitsadmin.exe",
                "CertOC.exe",
                "CertUtil.exe",
                "Cmd.Exe",
                "CMSTP.EXE",
                "cscript.exe",
                "curl.exe",
                "HH.exe",
                "IEExec.exe",
                "InstallUtil.exe",
                "javaw.exe",
                "Microsoft.Workflow.Compiler.exe",
                "msdt.exe",
                "MSHTA.EXE",
                "msiexec.exe",
                "Msxsl.exe",
                "odbcconf.exe",
                "pcalua.exe",
                "PowerShell.EXE",
                "RegAsm.exe",
                "RegSvcs.exe",
                "REGSVR32.exe",
                "RUNDLL32.exe",
                "schtasks.exe",
                "ScriptRunner.exe",
                "wmic.exe",
                "WorkFolders.exe",
                "wscript.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\AppVLP.exe",
                "\\bash.exe",
                "\\bitsadmin.exe",
                "\\certoc.exe",
                "\\certutil.exe",
                "\\cmd.exe",
                "\\cmstp.exe",
                "\\control.exe",
                "\\cscript.exe",
                "\\curl.exe",
                "\\forfiles.exe",
                "\\hh.exe",
                "\\ieexec.exe",
                "\\installutil.exe",
                "\\javaw.exe",
                "\\mftrace.exe",
                "\\Microsoft.Workflow.Compiler.exe",
                "\\msbuild.exe",
                "\\msdt.exe",
                "\\mshta.exe",
                "\\msidb.exe",
                "\\msiexec.exe",
                "\\msxsl.exe",
                "\\odbcconf.exe",
                "\\pcalua.exe",
                "\\powershell.exe",
                "\\pwsh.exe",
                "\\regasm.exe",
                "\\regsvcs.exe",
                "\\regsvr32.exe",
                "\\rundll32.exe",
                "\\schtasks.exe",
                "\\scrcons.exe",
                "\\scriptrunner.exe",
                "\\sh.exe",
                "\\svchost.exe",
                "\\verclsid.exe",
                "\\wmic.exe",
                "\\workfolders.exe",
                "\\wscript.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_opt_explorer": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\explorer.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            ".hta",
            ".vb",
            ".wsh",
            ".js",
            ".ps",
            ".scr",
            ".pif",
            ".bat",
            ".cmd"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_opt_paths": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "contains",
          "values": [
            "\\AppData\\",
            "\\Users\\Public\\",
            "\\ProgramData\\",
            "\\Windows\\Tasks\\",
            "\\Windows\\Temp\\",
            "\\Windows\\System32\\Tasks\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_teams": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\AppData\\Local\\Microsoft\\Teams\\current\\Teams.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "endswith",
          "values": [
            "-Embedding"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_onedrive": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "contains",
          "values": [
            "\\AppData\\Local\\Microsoft\\OneDrive\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\FileCoAuth.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "endswith",
          "values": [
            "-Embedding"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection_parent"
      },
      {
        "type": "wildcard_ref",
        "mode": "any",
        "pattern": "selection_opt_*"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_*"
        }
      }
    ]
  }
}