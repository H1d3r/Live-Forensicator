{
  "title": "Suspicious Execution From Outlook Temporary Folder",
  "rule_id": "a018fdc3-46a3-44e5-9afb-2cd4af1d4b39",
  "description": "Detects a suspicious program execution in Outlook temp folder",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.initial-access",
    "attack.t1566.001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_office_outlook_execution_from_temp.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "contains",
          "values": [
            "\\Temporary Internet Files\\Content.Outlook\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}