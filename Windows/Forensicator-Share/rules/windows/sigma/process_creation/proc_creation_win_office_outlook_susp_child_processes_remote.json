{
  "title": "Suspicious Remote Child Process From Outlook",
  "rule_id": "e212d415-0e93-435f-9e1a-f29005bb4723",
  "description": "Detects a suspicious child process spawning from Outlook where the image is located in a remote location (SMB/WebDav shares).",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.defense-evasion",
    "attack.t1059",
    "attack.t1202"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_office_outlook_susp_child_processes_remote.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\outlook.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Image",
          "operator": "startswith",
          "values": [
            "\\\\\\\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}