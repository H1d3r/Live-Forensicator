{
  "title": "Suspicious Binary In User Directory Spawned From Office Application",
  "rule_id": "aa3a6f94-890e-4e22-b634-ffdfd54792cc",
  "description": "Detects an executable in the users directory started from one of the Microsoft Office suite applications (Word, Excel, PowerPoint, Publisher, Visio)",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1204.002",
    "attack.g0046",
    "car.2013-05-002"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_office_spawn_exe_from_users_directory.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\WINWORD.EXE",
            "\\EXCEL.EXE",
            "\\POWERPNT.exe",
            "\\MSPUB.exe",
            "\\VISIO.exe",
            "\\MSACCESS.exe",
            "\\EQNEDT32.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Image",
          "operator": "startswith",
          "values": [
            "C:\\users\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            ".exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\Teams.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "item_ref",
          "name": "filter"
        }
      }
    ]
  }
}