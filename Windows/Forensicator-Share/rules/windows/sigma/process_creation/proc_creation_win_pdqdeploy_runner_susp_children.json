{
  "title": "Potentially Suspicious Execution Of PDQDeployRunner",
  "rule_id": "12b8e9f5-96b2-41e1-9a42-8c6779a5c184",
  "description": "Detects suspicious execution of \"PDQDeployRunner\" which is part of the PDQDeploy service stack that is responsible for executing commands and packages on a remote machines",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.execution"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_pdqdeploy_runner_susp_children.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection_parent": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "contains",
          "values": [
            "\\PDQDeployRunner-"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_child": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\bash.exe",
                "\\certutil.exe",
                "\\cmd.exe",
                "\\csc.exe",
                "\\cscript.exe",
                "\\dllhost.exe",
                "\\mshta.exe",
                "\\msiexec.exe",
                "\\regsvr32.exe",
                "\\rundll32.exe",
                "\\scriptrunner.exe",
                "\\wmic.exe",
                "\\wscript.exe",
                "\\wsl.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "contains",
              "values": [
                ":\\ProgramData\\",
                ":\\Users\\Public\\",
                ":\\Windows\\TEMP\\",
                "\\AppData\\Local\\Temp"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "contains",
              "values": [
                " -decode ",
                " -enc ",
                " -encodedcommand ",
                " -w hidden",
                "DownloadString",
                "FromBase64String",
                "http",
                "iex ",
                "Invoke-"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}