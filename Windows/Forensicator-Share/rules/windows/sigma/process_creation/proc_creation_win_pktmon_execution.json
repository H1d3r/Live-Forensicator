{
  "title": "PktMon.EXE Execution",
  "rule_id": "f956c7c1-0f60-4bc5-b7d7-b39ab3c08908",
  "description": "Detects execution of PktMon, a tool that captures network packets.",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.discovery",
    "attack.credential-access",
    "attack.t1040"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_pktmon_execution.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\pktmon.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "PktMon.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}