{
  "title": "Potential RDP Tunneling Via Plink",
  "rule_id": "f38ce0b9-5e97-4b47-a211-7dc8d8b871da",
  "description": "Execution of plink to perform data exfiltration and tunneling",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.command-and-control",
    "attack.t1572"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_plink_susp_tunneling.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection_a": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\plink.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            ":127.0.0.1:3389"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_b1": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\plink.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            ":3389"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_b2": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " -P 443",
            " -P 22"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "any",
    "children": [
      {
        "type": "item_ref",
        "name": "selection_a"
      },
      {
        "type": "wildcard_ref",
        "mode": "all",
        "pattern": "selection_b*"
      }
    ]
  }
}