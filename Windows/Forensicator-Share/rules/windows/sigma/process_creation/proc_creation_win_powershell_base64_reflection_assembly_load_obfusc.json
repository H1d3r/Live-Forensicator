{
  "title": "Suspicious Encoded And Obfuscated Reflection Assembly Load Function Call",
  "rule_id": "9c0295ce-d60d-40bd-bd74-84673b7592b1",
  "description": "Detects suspicious base64 encoded and obfuscated \"LOAD\" keyword used in .NET \"reflection.assembly\"",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.defense-evasion",
    "attack.t1059.001",
    "attack.t1027"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_powershell_base64_reflection_assembly_load_obfusc.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
