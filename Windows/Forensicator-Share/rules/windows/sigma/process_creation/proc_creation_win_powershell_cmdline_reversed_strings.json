{
  "title": "Potential PowerShell Obfuscation Via Reversed Commands",
  "rule_id": "b6b49cd1-34d6-4ead-b1bf-176e9edba9a4",
  "description": "Detects the presence of reversed PowerShell commands in the CommandLine. This is often used as a method of obfuscation by attackers",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1027",
    "attack.execution",
    "attack.t1059.001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_powershell_cmdline_reversed_strings.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\powershell.exe",
                "\\pwsh.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "PowerShell.EXE",
                "pwsh.dll"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "hctac",
            "kaerb",
            "dnammoc",
            "ekovn",
            "eliFd",
            "rahc",
            "etirw",
            "golon",
            "tninon",
            "eddih",
            "tpircS",
            "ssecorp",
            "llehsrewop",
            "esnopser",
            "daolnwod",
            "tneilCbeW",
            "tneilc",
            "ptth",
            "elifotevas",
            "46esab",
            "htaPpmeTteG",
            "tcejbO",
            "maerts",
            "hcaerof",
            "retupmoc"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_encoded_keyword": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " -EncodedCommand ",
            " -enc "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "wildcard_ref",
        "mode": "all",
        "pattern": "selection_*"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_main_*"
        }
      }
    ]
  }
}