{
  "title": "Potential COM Objects Download Cradles Usage - Process Creation",
  "rule_id": "02b64f1b-3f33-4e67-aede-ef3b0a5a8fcf",
  "description": "Detects usage of COM objects that can be abused to download files in PowerShell by CLSID",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.command-and-control",
    "attack.t1105"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_powershell_download_com_cradles.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection_1": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "[Type]::GetTypeFromCLSID("
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_2": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "0002DF01-0000-0000-C000-000000000046",
            "F6D90F16-9C73-11D3-B32E-00C04F990BB4",
            "F5078F35-C551-11D3-89B9-0000F81FE221",
            "88d96a0a-f192-11d4-a65f-0040963251e5",
            "AFBA6B42-5692-48EA-8141-DC517DCF0EF1",
            "AFB40FFD-B609-40A3-9828-F88BBE11E4E3",
            "88d96a0b-f192-11d4-a65f-0040963251e5",
            "2087c2f4-2cef-4953-a8ab-66779b670495",
            "000209FF-0000-0000-C000-000000000046",
            "00024500-0000-0000-C000-000000000046"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}