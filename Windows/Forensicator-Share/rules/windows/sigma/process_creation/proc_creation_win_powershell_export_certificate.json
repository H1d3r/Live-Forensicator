{
  "title": "Certificate Exported Via PowerShell",
  "rule_id": "9e716b33-63b2-46da-86a4-bd3c3b9b5dfb",
  "description": "Detects calls to cmdlets that are used to export certificates from the local certificate store. Threat actors were seen abusing this to steal private keys from compromised machines.",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.credential-access",
    "attack.execution",
    "attack.t1552.004",
    "attack.t1059.001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_powershell_export_certificate.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "Export-PfxCertificate ",
            "Export-Certificate "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}