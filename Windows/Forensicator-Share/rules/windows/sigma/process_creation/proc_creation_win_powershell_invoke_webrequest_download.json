{
  "title": "Suspicious Invoke-WebRequest Execution",
  "rule_id": "5e3cc4d8-3e68-43db-8656-eaaeefdec9cc",
  "description": "Detects a suspicious call to Invoke-WebRequest cmdlet where the and output is located in a suspicious location",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.command-and-control",
    "attack.t1105"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_powershell_invoke_webrequest_download.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\powershell_ise.exe",
                "\\powershell.exe",
                "\\pwsh.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "powershell_ise.EXE",
                "PowerShell.EXE",
                "pwsh.dll"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_commands": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "curl ",
            "Invoke-WebRequest",
            "iwr ",
            "wget "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_flags": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " -ur",
            " -o"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_susp_locations": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "\\AppData\\",
            "\\Desktop\\",
            "\\Temp\\",
            "\\Users\\Public\\",
            "%AppData%",
            "%Public%",
            "%Temp%",
            "%tmp%",
            ":\\Windows\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}