{
  "title": "MSExchange Transport Agent Installation",
  "rule_id": "83809e84-4475-4b69-bc3e-4aad8568612f",
  "description": "Detects the Installation of a Exchange Transport Agent",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.persistence",
    "attack.t1505.002"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_powershell_msexchange_transport_agent.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "Install-TransportAgent"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}