{
  "title": "Potential PowerShell Obfuscation Via WCHAR/CHAR",
  "rule_id": "e312efd0-35a1-407f-8439-b8d434b438a6",
  "description": "Detects suspicious encoded character syntax often used for defense evasion",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1059.001",
    "attack.defense-evasion",
    "attack.t1027"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_powershell_obfuscation_via_utf8.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "[char]0x",
            "(WCHAR)0x"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}