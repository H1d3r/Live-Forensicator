{
  "title": "Suspicious PowerShell Parameter Substring",
  "rule_id": "36210e0d-5b19-485d-a087-c096088885f0",
  "description": "Detects suspicious PowerShell invocation with a parameter substring",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1059.001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_powershell_susp_parameter_variation.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\powershell.exe",
            "\\pwsh.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " -windowstyle h ",
            " -windowstyl h",
            " -windowsty h",
            " -windowst h",
            " -windows h",
            " -windo h",
