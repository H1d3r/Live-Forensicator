{
  "title": "Suspicious PowerShell Parent Process",
  "rule_id": "754ed792-634f-40ae-b3bc-e0448d33f695",
  "description": "Detects a suspicious or uncommon parent processes of PowerShell",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1059.001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_powershell_susp_parent_process.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_parent": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "ParentImage",
              "operator": "contains",
              "values": [
                "tomcat"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "ParentImage",
              "operator": "endswith",
              "values": [
                "\\amigo.exe",
                "\\browser.exe",
                "\\chrome.exe",
                "\\firefox.exe",
                "\\httpd.exe",
                "\\iexplore.exe",
                "\\jbosssvc.exe",
                "\\microsoftedge.exe",
                "\\microsoftedgecp.exe",
                "\\MicrosoftEdgeSH.exe",
                "\\mshta.exe",
                "\\nginx.exe",
                "\\outlook.exe",
                "\\php-cgi.exe",
                "\\regsvr32.exe",
                "\\rundll32.exe",
                "\\safari.exe",
                "\\services.exe",
                "\\sqlagent.exe",
                "\\sqlserver.exe",
                "\\sqlservr.exe",
                "\\vivaldi.exe",
                "\\w3wp.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_powershell": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\powershell.exe",
                "\\pwsh.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "contains",
              "values": [
                "/c powershell",
                "/c pwsh"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Description",
              "operator": "exact",
              "values": [
                "Windows PowerShell"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Product",
              "operator": "exact",
              "values": [
                "PowerShell Core 6"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "PowerShell.EXE",
                "pwsh.dll"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}