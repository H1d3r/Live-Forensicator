{
  "title": "Potential Provlaunch.EXE Binary Proxy Execution Abuse",
  "rule_id": "7f5d1c9a-3e83-48df-95a7-2b98aae6c13c",
  "description": "Detects child processes of \"provlaunch.exe\" which might indicate potential abuse to proxy execution.",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1218"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_provlaunch_potential_abuse.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\provlaunch.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_covered_children": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\calc.exe",
                "\\cmd.exe",
                "\\cscript.exe",
                "\\mshta.exe",
                "\\notepad.exe",
                "\\powershell.exe",
                "\\pwsh.exe",
                "\\regsvr32.exe",
                "\\rundll32.exe",
                "\\wscript.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "contains",
              "values": [
                ":\\PerfLogs\\",
                ":\\Temp\\",
                ":\\Users\\Public\\",
                "\\AppData\\Temp\\",
                "\\Windows\\System32\\Tasks\\",
                "\\Windows\\Tasks\\",
                "\\Windows\\Temp\\"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_main_*"
        }
      }
    ]
  }
}