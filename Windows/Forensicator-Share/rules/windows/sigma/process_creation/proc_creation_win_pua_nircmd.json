{
  "title": "PUA - NirCmd Execution",
  "rule_id": "4e2ed651-1906-4a59-a78a-18220fca1b22",
  "description": "Detects the use of NirCmd tool for command execution, which could be the result of legitimate administrative activity",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1569.002",
    "attack.s0029"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_pua_nircmd.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_org": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\NirCmd.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "NirCmd.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_cmd": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " execmd ",
            ".exe script ",
            ".exe shexec ",
            " runinteractive "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "combo_exec": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " exec ",
            " exec2 "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "combo_exec_params": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " show ",
            " hide "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "any",
    "children": [
      {
        "type": "wildcard_ref",
        "mode": "any",
        "pattern": "selection_*"
      },
      {
        "type": "wildcard_ref",
        "mode": "all",
        "pattern": "combo_*"
      }
    ]
  }
}