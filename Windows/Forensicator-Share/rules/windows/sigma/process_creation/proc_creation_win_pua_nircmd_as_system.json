{
  "title": "PUA - NirCmd Execution As LOCAL SYSTEM",
  "rule_id": "d9047477-0359-48c9-b8c7-792cedcdc9c4",
  "description": "Detects the use of NirCmd tool for command execution as SYSTEM user",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1569.002",
    "attack.s0029"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_pua_nircmd_as_system.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " runassystem "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}