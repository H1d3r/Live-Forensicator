{
  "title": "PUA - NSudo Execution",
  "rule_id": "771d1eb5-9587-4568-95fb-9ec44153a012",
  "description": "Detects the use of NSudo tool for command execution",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1569.002",
    "attack.s0029"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_pua_nsudo.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\NSudo.exe",
                "\\NSudoLC.exe",
                "\\NSudoLG.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "NSudo.exe",
                "NSudoLC.exe",
                "NSudoLG.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "-U:S ",
            "-U:T ",
            "-U:E ",
            "-P:E ",
            "-M:S ",
            "-M:H ",
            "-U=S ",
            "-U=T ",
            "-U=E ",
            "-P=E ",
            "-M=S ",
            "-M=H ",
            "-ShowWindowMode:Hide"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}