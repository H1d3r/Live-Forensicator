{
  "title": "PUA - Radmin Viewer Utility Execution",
  "rule_id": "5817e76f-4804-41e6-8f1d-5fa0b3ecae2d",
  "description": "Detects the execution of Radmin which can be abused by an adversary to remotely control Windows machines",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.lateral-movement",
    "attack.t1072"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_pua_radmin.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Description",
              "operator": "exact",
              "values": [
                "Radmin Viewer"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Product",
              "operator": "exact",
              "values": [
                "Radmin Viewer"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "Radmin.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}