{
  "title": "PUA - Seatbelt Execution",
  "rule_id": "38646daa-e78f-4ace-9de0-55547b2d30da",
  "description": "Detects the execution of the PUA/Recon tool Seatbelt via PE information of command line parameters",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.discovery",
    "attack.t1526",
    "attack.t1087",
    "attack.t1083"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_pua_seatbelt.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\Seatbelt.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "Seatbelt.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Description",
              "operator": "exact",
              "values": [
                "Seatbelt"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "contains",
              "values": [
                " DpapiMasterKeys",
                " InterestingProcesses",
                " InterestingFiles",
                " CertificateThumbprints",
                " ChromiumBookmarks",
                " ChromiumHistory",
                " ChromiumPresence",
                " CloudCredentials",
                " CredEnum",
                " CredGuard",
                " FirefoxHistory",
                " ProcessCreationEvents"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_group_list": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " -group=misc",
            " -group=remote",
            " -group=chromium",
            " -group=slack",
            " -group=system",
            " -group=user",
            " -group=all"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_group_output": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " -outputfile="
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "any",
    "children": [
      {
        "type": "item_ref",
        "name": "selection_img"
      },
      {
        "type": "wildcard_ref",
        "mode": "all",
        "pattern": "selection_group_*"
      }
    ]
  }
}