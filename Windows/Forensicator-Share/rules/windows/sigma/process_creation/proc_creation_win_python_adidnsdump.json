{
  "title": "PUA - Adidnsdump Execution",
  "rule_id": "26d3f0a2-f514-4a3f-a8a7-e7e48a8d9160",
  "description": "This tool enables enumeration and exporting of all DNS records in the zone for recon purposes of internal networks Python 3 and python.exe must be installed,\nUsee to Query/modify DNS records for Active Directory integrated DNS via LDAP\n",
  "level": "low",
  "status": "test",
  "tags": [
    "attack.discovery",
    "attack.t1018"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_python_adidnsdump.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\python.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "adidnsdump"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}