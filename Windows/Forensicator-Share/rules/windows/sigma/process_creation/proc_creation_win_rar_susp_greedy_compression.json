{
  "title": "Suspicious Greedy Compression Using Rar.EXE",
  "rule_id": "afe52666-401e-4a02-b4ff-5d128990b8cb",
  "description": "Detects RAR usage that creates an archive from a suspicious folder, either a system folder or one of the folders often used by attackers for staging purposes",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1059"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_rar_susp_greedy_compression.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_opt_1": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\rar.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Description",
              "operator": "exact",
              "values": [
                "Command line RAR"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_opt_2": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            ".exe a ",
            " a -m"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_cli_flags": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " -hp",
            " -r "
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_cli_folders": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " ?:\\\\\\*.",
            " ?:\\\\\\\\\\*.",
            " ?:\\$Recycle.bin\\",
            " ?:\\PerfLogs\\",
            " ?:\\Temp",
            " ?:\\Users\\Public\\",
            " ?:\\Windows\\",
            " %public%"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "wildcard_ref",
        "mode": "any",
        "pattern": "selection_opt_*"
      },
      {
        "type": "wildcard_ref",
        "mode": "all",
        "pattern": "selection_cli_*"
      }
    ]
  }
}