{
  "title": "Suspicious RASdial Activity",
  "rule_id": "6bba49bf-7f8c-47d6-a1bb-6b4dece4640e",
  "description": "Detects suspicious process related to rasdial.exe",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.execution",
    "attack.t1059"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_rasdial_execution.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "rasdial.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}