{
  "title": "Dropping Of Password Filter DLL",
  "rule_id": "b7966f4a-b333-455b-8370-8ca53c229762",
  "description": "Detects dropping of dll files in system32 that may be used to retrieve user credentials from LSASS",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.persistence",
    "attack.defense-evasion",
    "attack.credential-access",
    "attack.t1556.002"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_reg_credential_access_via_password_filter.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection_cmdline": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "HKLM\\SYSTEM\\CurrentControlSet\\Control\\Lsa",
            "scecli\\0*",
            "reg add"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection_cmdline"
  }
}