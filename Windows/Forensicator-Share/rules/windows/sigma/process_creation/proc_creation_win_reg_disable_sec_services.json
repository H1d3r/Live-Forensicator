{
  "title": "Security Service Disabled Via Reg.EXE",
  "rule_id": "5e95028c-5229-4214-afae-d653d573d0ec",
  "description": "Detects execution of \"reg.exe\" to disable security services such as Windows Defender.",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1562.001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_reg_disable_sec_services.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection_reg_add": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "reg",
            "add"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_cli_reg_start": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "d 4",
            "v Start"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "\\AppIDSvc",
            "\\MsMpSvc",
            "\\NisSrv",
            "\\SecurityHealthService",
            "\\Sense",
            "\\UsoSvc",
            "\\WdBoot",
            "\\WdFilter",
            "\\WdNisDrv",
            "\\WdNisSvc",
            "\\WinDefend",
            "\\wscsvc",
            "\\wuauserv"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}