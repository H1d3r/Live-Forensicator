{
  "title": "Suspicious Query of MachineGUID",
  "rule_id": "f5240972-3938-4e56-8e4b-e33893176c1f",
  "description": "Use of reg to get MachineGuid information",
  "level": "low",
  "status": "test",
  "tags": [
    "attack.discovery",
    "attack.t1082"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_reg_machineguid.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\reg.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "SOFTWARE\\Microsoft\\Cryptography",
            "/v ",
            "MachineGuid"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}