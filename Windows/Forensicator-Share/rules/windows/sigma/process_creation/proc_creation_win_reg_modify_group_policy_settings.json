{
  "title": "Modify Group Policy Settings",
  "rule_id": "ada4b0c4-758b-46ac-9033-9004613a150d",
  "description": "Detect malicious GPO modifications can be used to implement many other malicious behaviors.",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.privilege-escalation",
    "attack.t1484.001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_reg_modify_group_policy_settings.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_reg": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\reg.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "reg.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_path": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "\\SOFTWARE\\Policies\\Microsoft\\Windows\\System"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_key": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "GroupPolicyRefreshTimeDC",
            "GroupPolicyRefreshTimeOffsetDC",
            "GroupPolicyRefreshTime",
            "GroupPolicyRefreshTimeOffset",
            "EnableSmartScreen",
            "ShellSmartScreenLevel"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}