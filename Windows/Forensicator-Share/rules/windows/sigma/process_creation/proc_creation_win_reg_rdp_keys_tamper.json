{
  "title": "Potential Tampering With RDP Related Registry Keys Via Reg.EXE",
  "rule_id": "0d5675be-bc88-4172-86d3-1e96a4476536",
  "description": "Detects the execution of \"reg.exe\" for enabling/disabling the RDP service on the host by tampering with the 'CurrentControlSet\\Control\\Terminal Server' values",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.persistence",
    "attack.defense-evasion",
    "attack.lateral-movement",
    "attack.t1021.001",
    "attack.t1112"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_reg_rdp_keys_tamper.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_main_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\reg.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "reg.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_main_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " add ",
            "\\CurrentControlSet\\Control\\Terminal Server",
            "REG_DWORD",
            " /f"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_values_1": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "Licensing Core",
            "EnableConcurrentSessions"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_values_2": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "AllowTSConnections",
            "fDenyTSConnections",
            "fEnableWinStation",
            "fSingleSessionPerUser",
            "IdleWinStationPoolCount",
            "MaxInstanceCount",
            "SecurityLayer",
            "TSAdvertise",
            "TSAppCompat",
            "TSEnabled",
            "TSUserEnabled",
            "WinStations\\RDP-Tcp"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_values_tls": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "SecurityLayer",
            "02"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "wildcard_ref",
        "mode": "all",
        "pattern": "selection_main_*"
      },
      {
        "type": "wildcard_ref",
        "mode": "any",
        "pattern": "selection_values_*"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_main_*"
        }
      }
    ]
  }
}