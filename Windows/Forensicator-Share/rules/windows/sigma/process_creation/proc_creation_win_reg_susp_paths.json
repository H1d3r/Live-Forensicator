{
  "title": "Reg Add Suspicious Paths",
  "rule_id": "b7e2a8d4-74bb-4b78-adc9-3f92af2d4829",
  "description": "Detects when an adversary uses the reg.exe utility to add or modify new keys or subkeys",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.persistence",
    "attack.defense-evasion",
    "attack.t1112",
    "attack.t1562.001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_reg_susp_paths.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_reg": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\reg.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "reg.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_path": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "\\AppDataLow\\Software\\Microsoft\\",
            "\\Policies\\Microsoft\\Windows\\OOBE",
            "\\Policies\\Microsoft\\Windows NT\\CurrentVersion\\Winlogon",
            "\\SOFTWARE\\Microsoft\\Windows NT\\Currentversion\\Winlogon",
            "\\CurrentControlSet\\Control\\SecurityProviders\\WDigest",
            "\\Microsoft\\Windows Defender\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}