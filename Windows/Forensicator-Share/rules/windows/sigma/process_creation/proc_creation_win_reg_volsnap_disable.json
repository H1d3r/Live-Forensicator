{
  "title": "Disabled Volume Snapshots",
  "rule_id": "dee4af55-1f22-4e1d-a9d2-4bdc7ecb472a",
  "description": "Detects commands that temporarily turn off Volume Snapshots",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1562.001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_reg_volsnap_disable.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "\\Services\\VSS\\Diag",
            "/d Disabled"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}