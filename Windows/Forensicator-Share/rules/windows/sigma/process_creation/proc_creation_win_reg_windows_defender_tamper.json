{
  "title": "Suspicious Windows Defender Registry Key Tampering Via Reg.EXE",
  "rule_id": "452bce90-6fb0-43cc-97a5-affc283139b3",
  "description": "Detects the usage of \"reg.exe\" to tamper with different Windows Defender registry keys in order to disable some important features related to protection and detection\n",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1562.001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_reg_windows_defender_tamper.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_root_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\reg.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "reg.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_root_path": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "SOFTWARE\\Microsoft\\Windows Defender\\",
            "SOFTWARE\\Policies\\Microsoft\\Windows Defender Security Center",
            "SOFTWARE\\Policies\\Microsoft\\Windows Defender\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_dword_0": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " add ",
            "d 0"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "DisallowExploitProtectionOverride",
            "EnableControlledFolderAccess",
            "MpEnablePus",
            "PUAProtection",
            "SpynetReporting",
            "SubmitSamplesConsent",
            "TamperProtection"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_dword_1": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " add ",
            "d 1"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "DisableAccess",
            "DisableAntiSpyware",
            "DisableAntiSpywareRealtimeProtection",
            "DisableAntiVirus",
            "DisableAntiVirusSignatures",
            "DisableArchiveScanning",
            "DisableBehaviorMonitoring",
            "DisableBlockAtFirstSeen",
            "DisableCloudProtection",
            "DisableConfig",
            "DisableEnhancedNotifications",
            "DisableIntrusionPreventionSystem",
            "DisableIOAVProtection",
            "DisableNetworkProtection",
            "DisableOnAccessProtection",
            "DisablePrivacyMode",
            "DisableRealtimeMonitoring",
            "DisableRoutinelyTakingAction",
            "DisableScanOnRealtimeEnable",
            "DisableScriptScanning",
            "DisableSecurityCenter",
            "Notification_Suppress",
            "SignatureDisableUpdateOnStartupWithoutEngine"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "wildcard_ref",
        "mode": "all",
        "pattern": "selection_root_*"
      },
      {
        "type": "wildcard_ref",
        "mode": "any",
        "pattern": "selection_dword_*"
      }
    ]
  }
}