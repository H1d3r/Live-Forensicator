{
  "title": "Potentially Suspicious Execution Of Regasm/Regsvcs With Uncommon Extension",
  "rule_id": "e9f8f8cc-07cc-4e81-b724-f387db9175e4",
  "description": "Detects potentially suspicious execution of the Regasm/Regsvcs utilities with an uncommon extension.",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1218.009"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_regasm_regsvcs_uncommon_extension_execution.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\Regsvcs.exe",
                "\\Regasm.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "RegSvcs.exe",
                "RegAsm.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_extension": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            ".dat",
            ".gif",
            ".jpeg",
            ".jpg",
            ".png",
            ".txt"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}