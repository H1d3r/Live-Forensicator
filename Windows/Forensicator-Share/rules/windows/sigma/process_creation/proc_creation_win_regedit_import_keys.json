{
  "title": "Imports Registry Key From a File",
  "rule_id": "73bba97f-a82d-42ce-b315-9182e76c57b1",
  "description": "Detects the import of the specified file to the registry with regedit.exe.",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.persistence",
    "attack.t1112",
    "attack.defense-evasion"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_regedit_import_keys.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\regedit.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "REGEDIT.EXE"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " /i ",
            " /s ",
            ".reg"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_1": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " -e ",
            " -a ",
            " -c "
          ],
          "match": "any",
          "windash": true,
          "ignore_case": true
        }
      ]
    },
    "filter_2": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "re",
          "values": [
            ":[^ \\\\]"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": false
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "wildcard_ref",
        "mode": "all",
        "pattern": "selection_*"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "all",
          "pattern": "filter_*"
        }
      }
    ]
  }
}