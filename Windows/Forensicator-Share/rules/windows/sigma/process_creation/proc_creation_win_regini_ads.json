{
  "title": "Suspicious Registry Modification From ADS Via Regini.EXE",
  "rule_id": "77946e79-97f1-45a2-84b4-f37b5c0d8682",
  "description": "Detects the import of an alternate data stream with regini.exe, regini.exe can be used to modify registry keys.",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.persistence",
    "attack.t1112",
    "attack.defense-evasion"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_regini_ads.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\regini.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "REGINI.EXE"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_re": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "re",
          "values": [
            ":[^ \\\\]"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": false
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}