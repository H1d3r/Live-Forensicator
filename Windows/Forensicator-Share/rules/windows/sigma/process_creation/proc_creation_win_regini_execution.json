{
  "title": "Registry Modification Via Regini.EXE",
  "rule_id": "5f60740a-f57b-4e76-82a1-15b6ff2cb134",
  "description": "Detects the execution of regini.exe which can be used to modify registry keys, the changes are imported from one or more text files.",
  "level": "low",
  "status": "test",
  "tags": [
    "attack.persistence",
    "attack.t1112",
    "attack.defense-evasion"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_regini_execution.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\regini.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "REGINI.EXE"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "filter": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "re",
          "values": [
            ":[^ \\\\]"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": false
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "item_ref",
          "name": "filter"
        }
      }
    ]
  }
}