{
  "title": "DLL Execution Via Register-cimprovider.exe",
  "rule_id": "a2910908-e86f-4687-aeba-76a5f996e652",
  "description": "Detects using register-cimprovider.exe to execute arbitrary dll file.",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.privilege-escalation",
    "attack.persistence",
    "attack.defense-evasion",
    "attack.t1574"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_registry_cimprovider_dll_load.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\register-cimprovider.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "-path",
            "dll"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}