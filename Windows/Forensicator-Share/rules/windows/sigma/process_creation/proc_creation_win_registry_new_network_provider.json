{
  "title": "Potential Credential Dumping Attempt Using New NetworkProvider - CLI",
  "rule_id": "baef1ec6-2ca9-47a3-97cc-4cf2bda10b77",
  "description": "Detects when an attacker tries to add a new network provider in order to dump clear text credentials, similar to how the NPPSpy tool does it",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.credential-access",
    "attack.t1003"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_registry_new_network_provider.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "\\System\\CurrentControlSet\\Services\\",
            "\\NetworkProvider"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}