{
  "title": "Potentially Suspicious Regsvr32 HTTP IP Pattern",
  "rule_id": "2dd2c217-bf68-437a-b57c-fe9fd01d5de8",
  "description": "Detects regsvr32 execution to download and install DLLs located remotely where the address is an IP address.",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1218.010"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_regsvr32_http_ip_pattern.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\regsvr32.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "REGSVR32.EXE"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_ip": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " /i:http://1",
            " /i:http://2",
            " /i:http://3",
            " /i:http://4",
            " /i:http://5",
            " /i:http://6",
            " /i:http://7",
            " /i:http://8",
            " /i:http://9",
            " /i:https://1",
            " /i:https://2",
            " /i:https://3",
            " /i:https://4",
            " /i:https://5",
            " /i:https://6",
            " /i:https://7",
            " /i:https://8",
            " /i:https://9",
            " -i:http://1",
            " -i:http://2",
            " -i:http://3",
            " -i:http://4",
            " -i:http://5",
            " -i:http://6",
            " -i:http://7",
            " -i:http://8",
            " -i:http://9",
            " -i:https://1",
            " -i:https://2",
            " -i:https://3",
            " -i:https://4",
            " -i:https://5",
            " -i:https://6",
            " -i:https://7",
            " -i:https://8",
            " -i:https://9"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}