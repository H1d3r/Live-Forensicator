{
  "title": "Regsvr32 Execution From Highly Suspicious Location",
  "rule_id": "327ff235-94eb-4f06-b9de-aaee571324be",
  "description": "Detects execution of regsvr32 where the DLL is located in a highly suspicious locations",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1218.010"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_regsvr32_susp_exec_path_2.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\regsvr32.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "REGSVR32.EXE"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_path_1": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            ":\\PerfLogs\\",
            ":\\Temp\\",
            "\\Windows\\Registration\\CRMLog",
            "\\Windows\\System32\\com\\dmp\\",
            "\\Windows\\System32\\FxsTmp\\",
            "\\Windows\\System32\\Microsoft\\Crypto\\RSA\\MachineKeys\\",
            "\\Windows\\System32\\spool\\drivers\\color\\",
            "\\Windows\\System32\\spool\\PRINTERS\\",
            "\\Windows\\System32\\spool\\SERVERS\\",
            "\\Windows\\System32\\Tasks_Migrated\\",
            "\\Windows\\System32\\Tasks\\Microsoft\\Windows\\SyncCenter\\",
            "\\Windows\\SysWOW64\\com\\dmp\\",
            "\\Windows\\SysWOW64\\FxsTmp\\",
            "\\Windows\\SysWOW64\\Tasks\\Microsoft\\Windows\\PLA\\System\\",
            "\\Windows\\SysWOW64\\Tasks\\Microsoft\\Windows\\SyncCenter\\",
            "\\Windows\\Tasks\\",
            "\\Windows\\Tracing\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_path_2": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " \"C:\\",
            " C:\\",
            " 'C:\\",
            "D:\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_exclude_known_dirs": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "C:\\Program Files (x86)\\",
            "C:\\Program Files\\",
            "C:\\ProgramData\\",
            "C:\\Users\\",
            " C:\\Windows\\",
            " \"C:\\Windows\\",
            " 'C:\\Windows\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_empty": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "exact",
          "values": [
            ""
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_null": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "is_null",
          "values": [],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection_img"
      },
      {
        "type": "any",
        "children": [
          {
            "type": "item_ref",
            "name": "selection_path_1"
          },
          {
            "type": "all",
            "children": [
              {
                "type": "item_ref",
                "name": "selection_path_2"
              },
              {
                "type": "not",
                "child": {
                  "type": "item_ref",
                  "name": "selection_exclude_known_dirs"
                }
              }
            ]
          }
        ]
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_main_*"
        }
      }
    ]
  }
}