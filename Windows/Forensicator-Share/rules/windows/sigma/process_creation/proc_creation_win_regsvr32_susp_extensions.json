{
  "title": "Regsvr32 DLL Execution With Suspicious File Extension",
  "rule_id": "089fc3d2-71e8-4763-a8a5-c97fbb0a403e",
  "description": "Detects the execution of REGSVR32.exe with DLL files masquerading as other files",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1218.010"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_regsvr32_susp_extensions.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\regsvr32.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "REGSVR32.EXE"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "endswith",
          "values": [
            ".bin",
            ".bmp",
            ".cr2",
            ".dat",
            ".eps",
            ".gif",
            ".ico",
            ".jpeg",
            ".jpg",
            ".log",
            ".nef",
            ".orf",
            ".png",
            ".raw",
            ".rtf",
            ".sr2",
            ".temp",
            ".tif",
            ".tiff",
            ".tmp",
            ".txt"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}