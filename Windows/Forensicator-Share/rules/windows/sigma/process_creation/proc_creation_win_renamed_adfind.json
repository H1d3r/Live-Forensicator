{
  "title": "Renamed AdFind Execution",
  "rule_id": "df55196f-f105-44d3-a675-e9dfb6cc2f2b",
  "description": "Detects the use of a renamed Adfind.exe. AdFind continues to be seen across majority of breaches. It is used to domain trust discovery to plan out subsequent steps in the attack chain.",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.discovery",
    "attack.t1018",
    "attack.t1087.002",
    "attack.t1482",
    "attack.t1069.002"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_renamed_adfind.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_1": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "domainlist",
            "trustdmp",
            "dcmodes",
            "adinfo",
            " dclist ",
            "computer_pwdnotreqd",
            "objectcategory=",
            "-subnets -f",
            "name=\"Domain Admins\"",
            "-sc u:",
            "domainncs",
            "dompol",
            " oudmp ",
            "subnetdmp",
            "gpodmp",
            "fspdmp",
            "users_noexpire",
            "computers_active",
            "computers_pwdnotreqd"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_2": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Hashes",
          "operator": "contains",
          "values": [
            "IMPHASH=BCA5675746D13A1F246E2DA3C2217492",
            "IMPHASH=53E117A96057EAF19C41380D0E87F1C2",
            "IMPHASH=d144de8117df2beceaba2201ad304764",
            "IMPHASH=12ce1c0f3f5837ecc18a3782408fa975",
            "IMPHASH=4fbf3f084fbbb2470b80b2013134df35",
            "IMPHASH=49b639b4acbecc49d72a01f357aa4930",
            "IMPHASH=680dad9e300346e05a85023965867201",
            "IMPHASH=21aa085d54992511b9f115355e468782"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_3": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "OriginalFileName",
          "operator": "exact",
          "values": [
            "AdFind.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\AdFind.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "wildcard_ref",
        "mode": "any",
        "pattern": "selection*"
      },
      {
        "type": "not",
        "child": {
          "type": "item_ref",
          "name": "filter"
        }
      }
    ]
  }
}