{
  "title": "Renamed AutoHotkey.EXE Execution",
  "rule_id": "0f16d9cf-0616-45c8-8fad-becc11b5a41c",
  "description": "Detects execution of a renamed autohotkey.exe binary based on PE metadata fields",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_renamed_autohotkey.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Product",
              "operator": "contains",
              "values": [
                "AutoHotkey"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Description",
              "operator": "contains",
              "values": [
                "AutoHotkey"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "AutoHotkey.exe",
                "AutoHotkey.rc"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "filter": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\AutoHotkey.exe",
                "\\AutoHotkey32.exe",
                "\\AutoHotkey32_UIA.exe",
                "\\AutoHotkey64.exe",
                "\\AutoHotkey64_UIA.exe",
                "\\AutoHotkeyA32.exe",
                "\\AutoHotkeyA32_UIA.exe",
                "\\AutoHotkeyU32.exe",
                "\\AutoHotkeyU32_UIA.exe",
                "\\AutoHotkeyU64.exe",
                "\\AutoHotkeyU64_UIA.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "contains",
              "values": [
                "\\AutoHotkey"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "item_ref",
          "name": "filter"
        }
      }
    ]
  }
}