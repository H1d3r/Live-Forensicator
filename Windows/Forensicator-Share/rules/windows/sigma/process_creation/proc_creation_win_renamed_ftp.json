{
  "title": "Renamed FTP.EXE Execution",
  "rule_id": "277a4393-446c-449a-b0ed-7fdc7795244c",
  "description": "Detects the execution of a renamed \"ftp.exe\" binary based on the PE metadata fields",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1059",
    "attack.defense-evasion",
    "attack.t1202"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_renamed_ftp.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_original": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "OriginalFileName",
          "operator": "exact",
          "values": [
            "ftp.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_img": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\ftp.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection_original"
      },
      {
        "type": "not",
        "child": {
          "type": "item_ref",
          "name": "filter_img"
        }
      }
    ]
  }
}