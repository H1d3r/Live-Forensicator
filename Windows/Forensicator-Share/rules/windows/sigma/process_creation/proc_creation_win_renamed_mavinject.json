{
  "title": "Renamed Mavinject.EXE Execution",
  "rule_id": "e6474a1b-5390-49cd-ab41-8d88655f7394",
  "description": "Detects the execution of a renamed version of the \"Mavinject\" process. Which can be abused to perform process injection using the \"/INJECTRUNNING\" flag",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.privilege-escalation",
    "attack.t1055.001",
    "attack.t1218.013"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_renamed_mavinject.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "OriginalFileName",
          "operator": "exact",
          "values": [
            "mavinject32.exe",
            "mavinject64.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\mavinject32.exe",
            "\\mavinject64.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "item_ref",
          "name": "filter"
        }
      }
    ]
  }
}