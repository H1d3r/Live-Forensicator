{
  "title": "Renamed Msdt.EXE Execution",
  "rule_id": "bd1c6866-65fc-44b2-be51-5588fcff82b9",
  "description": "Detects the execution of a renamed \"Msdt.exe\" binary",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1036.003"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_renamed_msdt.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "OriginalFileName",
          "operator": "exact",
          "values": [
            "msdt.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\msdt.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "item_ref",
          "name": "filter"
        }
      }
    ]
  }
}