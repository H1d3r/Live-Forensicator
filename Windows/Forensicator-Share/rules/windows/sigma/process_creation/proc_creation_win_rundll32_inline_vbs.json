{
  "title": "Suspicious Rundll32 Invoking Inline VBScript",
  "rule_id": "1cc50f3f-1fc8-4acf-b2e9-6f172e1fdebd",
  "description": "Detects suspicious process related to rundll32 based on command line that invokes inline VBScript as seen being used by UNC2452",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.privilege-escalation",
    "attack.defense-evasion",
    "attack.t1055"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_rundll32_inline_vbs.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "rundll32.exe",
            "Execute",
            "RegRead",
            "window.close"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}