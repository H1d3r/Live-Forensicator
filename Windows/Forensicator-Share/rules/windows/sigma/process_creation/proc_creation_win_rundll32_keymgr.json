{
  "title": "Suspicious Key Manager Access",
  "rule_id": "a4694263-59a8-4608-a3a0-6f8d3a51664c",
  "description": "Detects the invocation of the Stored User Names and Passwords dialogue (Key Manager)",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.credential-access",
    "attack.t1555.004"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_rundll32_keymgr.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\rundll32.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "RUNDLL32.EXE"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "keymgr",
            "KRShowKeyMgr"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}