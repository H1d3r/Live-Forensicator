{
  "title": "Suspicious Control Panel DLL Load",
  "rule_id": "d7eb979b-c2b5-4a6f-a3a7-c87ce6763819",
  "description": "Detects suspicious Rundll32 execution from control.exe as used by Equation Group and Exploit Kits",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1218.011"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_rundll32_susp_control_dll_load.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_parent": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\System32\\control.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\rundll32.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "RUNDLL32.EXE"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "filter": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "Shell32.dll"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "wildcard_ref",
        "mode": "all",
        "pattern": "selection_*"
      },
      {
        "type": "not",
        "child": {
          "type": "item_ref",
          "name": "filter"
        }
      }
    ]
  }
}