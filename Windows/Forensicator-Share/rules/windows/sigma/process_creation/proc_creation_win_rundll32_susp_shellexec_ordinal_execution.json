{
  "title": "Suspicious ShellExec_RunDLL Call Via Ordinal",
  "rule_id": "8823e85d-31d8-473e-b7f4-92da070f0fc6",
  "description": "Detects suspicious call to the \"ShellExec_RunDLL\" exported function of SHELL32.DLL through the ordinal number to launch other commands.\nAdversary might only use the ordinal number in order to bypass existing detection that alert on usage of ShellExec_RunDLL on CommandLine.\n",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1218.011"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_rundll32_susp_shellexec_ordinal_execution.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection_parent_img": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentCommandLine",
          "operator": "contains",
          "values": [
            "SHELL32.DLL"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_parent_ordinal": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentCommandLine",
          "operator": "contains",
          "values": [
            "#568",
            "#570",
            "#572",
            "#576"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_susp_cli_parent": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "ParentCommandLine",
              "operator": "contains",
              "values": [
                "comspec",
                "iex",
                "Invoke-",
                "msiexec",
                "odbcconf",
                "regsvr32"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "ParentCommandLine",
              "operator": "contains",
              "values": [
                "\\Desktop\\",
                "\\ProgramData\\",
                "\\Temp\\",
                "\\Users\\Public\\"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_susp_child_img": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\bash.exe",
            "\\bitsadmin.exe",
            "\\cmd.exe",
            "\\cscript.exe",
            "\\curl.exe",
            "\\mshta.exe",
            "\\msiexec.exe",
            "\\msxsl.exe",
            "\\odbcconf.exe",
            "\\powershell.exe",
            "\\pwsh.exe",
            "\\regsvr32.exe",
            "\\schtasks.exe",
            "\\wmic.exe",
            "\\wscript.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "wildcard_ref",
        "mode": "all",
        "pattern": "selection_parent_*"
      },
      {
        "type": "wildcard_ref",
        "mode": "any",
        "pattern": "selection_susp_*"
      }
    ]
  }
}