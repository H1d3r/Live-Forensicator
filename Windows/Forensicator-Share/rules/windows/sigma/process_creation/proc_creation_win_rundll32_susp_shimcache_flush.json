{
  "title": "ShimCache Flush",
  "rule_id": "b0524451-19af-4efa-a46f-562a977f792e",
  "description": "Detects actions that clear the local ShimCache and remove forensic evidence",
  "level": "high",
  "status": "stable",
  "tags": [
    "attack.persistence",
    "attack.defense-evasion",
    "attack.t1112"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_rundll32_susp_shimcache_flush.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection1a": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "rundll32",
            "apphelp.dll"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection1b": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "ShimFlushCache",
            "#250"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection2a": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "rundll32",
            "kernel32.dll"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection2b": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "BaseFlushAppcompatCache",
            "#46"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "any",
    "children": [
      {
        "type": "all",
        "children": [
          {
            "type": "item_ref",
            "name": "selection1a"
          },
          {
            "type": "item_ref",
            "name": "selection1b"
          }
        ]
      },
      {
        "type": "all",
        "children": [
          {
            "type": "item_ref",
            "name": "selection2a"
          },
          {
            "type": "item_ref",
            "name": "selection2b"
          }
        ]
      }
    ]
  }
}