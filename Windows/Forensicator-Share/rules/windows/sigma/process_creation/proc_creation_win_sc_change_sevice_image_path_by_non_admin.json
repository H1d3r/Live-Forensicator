{
  "title": "Possible Privilege Escalation via Weak Service Permissions",
  "rule_id": "d937b75f-a665-4480-88a5-2f20e9f9b22a",
  "description": "Detection of sc.exe utility spawning by user with Medium integrity level to change service ImagePath or FailureCommand",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.persistence",
    "attack.defense-evasion",
    "attack.privilege-escalation",
    "attack.t1574.011"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_sc_change_sevice_image_path_by_non_admin.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "scbynonadmin": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\sc.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "IntegrityLevel",
          "operator": "exact",
          "values": [
            "Medium",
            "S-1-16-8192"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_binpath": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "config",
            "binPath"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_failure": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "failure",
            "command"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "scbynonadmin"
      },
      {
        "type": "wildcard_ref",
        "mode": "any",
        "pattern": "selection_*"
      }
    ]
  }
}