{
  "title": "Potential Persistence Attempt Via Existing Service Tampering",
  "rule_id": "38879043-7e1e-47a9-8d46-6bec88e201df",
  "description": "Detects the modification of an existing service in order to execute an arbitrary payload when the service is started or killed as a potential method for persistence.",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.privilege-escalation",
    "attack.defense-evasion",
    "attack.persistence",
    "attack.t1543.003",
    "attack.t1574.011"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_sc_service_tamper_for_persistence.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection_sc": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "contains",
              "values": [
                "sc ",
                "config ",
                "binpath="
              ],
              "match": "all",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "contains",
              "values": [
                "sc ",
                "failure",
                "command="
              ],
              "match": "all",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_reg_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "contains",
              "values": [
                "reg ",
                "add ",
                "FailureCommand"
              ],
              "match": "all",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "contains",
              "values": [
                "reg ",
                "add ",
                "ImagePath"
              ],
              "match": "all",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_reg_ext": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            ".sh",
            ".exe",
            ".dll",
            ".bin$",
            ".bat",
            ".cmd",
            ".js",
            ".msh$",
            ".reg$",
            ".scr",
            ".ps",
            ".vb",
            ".jar",
            ".pl"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "any",
    "children": [
      {
        "type": "item_ref",
        "name": "selection_sc"
      },
      {
        "type": "wildcard_ref",
        "mode": "all",
        "pattern": "selection_reg_*"
      }
    ]
  }
}