{
  "title": "Delete Important Scheduled Task",
  "rule_id": "dbc1f800-0fe0-4bc0-9c66-292c2abe3f78",
  "description": "Detects when adversaries stop services or processes by deleting their respective scheduled tasks in order to conduct data destructive activities",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.impact",
    "attack.t1489"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_schtasks_delete.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\schtasks.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "/delete",
            "/tn"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "\\Windows\\BitLocker",
            "\\Windows\\ExploitGuard",
            "\\Windows\\SystemRestore\\SR",
            "\\Windows\\UpdateOrchestrator\\",
            "\\Windows\\Windows Defender\\",
            "\\Windows\\WindowsBackup\\",
            "\\Windows\\WindowsUpdate\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}