{
  "title": "Script Event Consumer Spawning Process",
  "rule_id": "f6d1dd2f-b8ce-40ca-bc23-062efb686b34",
  "description": "Detects a suspicious child process of Script Event Consumer (scrcons.exe).",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1047"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_scrcons_susp_child_process.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\scrcons.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\svchost.exe",
            "\\dllhost.exe",
            "\\powershell.exe",
            "\\pwsh.exe",
            "\\wscript.exe",
            "\\cscript.exe",
            "\\schtasks.exe",
            "\\regsvr32.exe",
            "\\mshta.exe",
            "\\rundll32.exe",
            "\\msiexec.exe",
            "\\msbuild.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}