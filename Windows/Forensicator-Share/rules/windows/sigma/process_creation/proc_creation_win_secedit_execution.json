{
  "title": "Potential Suspicious Activity Using SeCEdit",
  "rule_id": "c2c76b77-32be-4d1f-82c9-7e544bdfe0eb",
  "description": "Detects potential suspicious behaviour using secedit.exe. Such as exporting or modifying the security policy",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.collection",
    "attack.discovery",
    "attack.persistence",
    "attack.defense-evasion",
    "attack.credential-access",
    "attack.privilege-escalation",
    "attack.t1562.002",
    "attack.t1547.001",
    "attack.t1505.005",
    "attack.t1556.002",
    "attack.t1562",
    "attack.t1574.007",
    "attack.t1564.002",
    "attack.t1546.008",
    "attack.t1546.007",
    "attack.t1547.014",
    "attack.t1547.010",
    "attack.t1547.002",
    "attack.t1557",
    "attack.t1082"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_secedit_execution.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\secedit.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "SeCEdit"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_flags_discovery": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "/export",
            "/cfg"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_flags_configure": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "/configure",
            "/db"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection_img"
      },
      {
        "type": "wildcard_ref",
        "mode": "any",
        "pattern": "selection_flags_*"
      }
    ]
  }
}