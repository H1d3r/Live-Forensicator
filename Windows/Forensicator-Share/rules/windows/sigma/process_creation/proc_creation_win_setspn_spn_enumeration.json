{
  "title": "Potential SPN Enumeration Via Setspn.EXE",
  "rule_id": "1eeed653-dbc8-4187-ad0c-eeebb20e6599",
  "description": "Detects service principal name (SPN) enumeration used for Kerberoasting",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.credential-access",
    "attack.t1558.003"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_setspn_spn_enumeration.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_pe": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\setspn.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "setspn.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Description",
              "operator": "contains",
              "values": [
                "Query or reset the computer",
                "SPN attribute"
              ],
              "match": "all",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " -q ",
            " /q "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}