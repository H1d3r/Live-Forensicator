{
  "title": "Suspicious Execution of Shutdown",
  "rule_id": "34ebb878-1b15-4895-b352-ca2eeb99b274",
  "description": "Use of the commandline to shutdown or reboot windows",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.impact",
    "attack.t1529"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_shutdown_execution.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\shutdown.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "/r ",
            "/s "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}