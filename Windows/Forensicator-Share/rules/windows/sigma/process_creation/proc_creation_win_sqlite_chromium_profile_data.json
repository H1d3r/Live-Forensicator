{
  "title": "SQLite Chromium Profile Data DB Access",
  "rule_id": "24c77512-782b-448a-8950-eddb0785fc71",
  "description": "Detect usage of the \"sqlite\" binary to query databases in Chromium-based browsers for potential data stealing.",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.credential-access",
    "attack.t1539",
    "attack.t1555.003",
    "attack.collection",
    "attack.t1005"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_sqlite_chromium_profile_data.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_sql": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Product",
              "operator": "exact",
              "values": [
                "SQLite"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\sqlite.exe",
                "\\sqlite3.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_chromium": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "\\User Data\\",
            "\\Opera Software\\",
            "\\ChromiumViewer\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_data": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "Login Data",
            "Cookies",
            "Web Data",
            "History",
            "Bookmarks"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}