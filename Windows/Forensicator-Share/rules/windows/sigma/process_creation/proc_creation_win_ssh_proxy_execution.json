{
  "title": "Program Executed Using Proxy/Local Command Via SSH.EXE",
  "rule_id": "7d6d30b8-5b91-4b90-a891-46cccaf29598",
  "description": "Detect usage of the \"ssh.exe\" binary as a proxy to launch other programs.",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1218"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_ssh_proxy_execution.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_parent": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "exact",
          "values": [
            "C:\\Windows\\System32\\OpenSSH\\sshd.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_cli_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\ssh.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Product",
              "operator": "exact",
              "values": [
                "OpenSSH for Windows"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Hashes",
              "operator": "contains",
              "values": [
                "IMPHASH=55b4964d29aad5438b9e950052dbbbc0",
                "IMPHASH=334d66c33503ccbf647c15b47c27eef4",
                "IMPHASH=27b0da080ef92afb37983d30d839141e",
                "IMPHASH=977eb4c263d384e47daa0712d34713ab",
                "IMPHASH=3eaadce9ae43d5a918bb082065815c3b",
                "IMPHASH=980fe6cf0d996ab1eedf877222e722aa",
                "IMPHASH=5f959422308ac3d721010d66647e100e",
                "IMPHASH=a49aaa3d03d1cd9c8dc7fca60f7f480b",
                "IMPHASH=dd335f759b6d5d6a8382b71dd9d65791"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_cli_flags": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "contains",
              "values": [
                "ProxyCommand="
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "contains",
              "values": [
                "PermitLocalCommand=yes",
                " LocalCommand"
              ],
              "match": "all",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    }
  },
  "condition": {
    "type": "any",
    "children": [
      {
        "type": "item_ref",
        "name": "selection_parent"
      },
      {
        "type": "wildcard_ref",
        "mode": "all",
        "pattern": "selection_cli_*"
      }
    ]
  }
}