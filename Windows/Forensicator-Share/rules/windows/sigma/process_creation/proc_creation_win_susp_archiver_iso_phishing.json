{
  "title": "Phishing Pattern ISO in Archive",
  "rule_id": "fcdf69e5-a3d3-452a-9724-26f2308bf2b1",
  "description": "Detects cases in which an ISO files is opend within an archiver like 7Zip or Winrar, which is a sign of phishing as threat actors put small ISO files in archives as email attachments to bypass certain filters and protective measures (mark of web)",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.initial-access",
    "attack.t1566"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_susp_archiver_iso_phishing.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\Winrar.exe",
            "\\7zFM.exe",
            "\\peazip.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\isoburn.exe",
            "\\PowerISO.exe",
            "\\ImgBurn.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}