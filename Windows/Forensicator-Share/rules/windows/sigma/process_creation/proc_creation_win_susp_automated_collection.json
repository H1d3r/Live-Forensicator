{
  "title": "Automated Collection Command Prompt",
  "rule_id": "f576a613-2392-4067-9d1a-9345fb58d8d1",
  "description": "Once established within a system or network, an adversary may use automated techniques for collecting internal data.",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.collection",
    "attack.t1119",
    "attack.credential-access",
    "attack.t1552.001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_susp_automated_collection.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_ext": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            ".doc",
            ".docx",
            ".xls",
            ".xlsx",
            ".ppt",
            ".pptx",
            ".rtf",
            ".pdf",
            ".txt"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_other_dir": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "dir ",
            " /b ",
            " /s "
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_other_findstr": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "OriginalFileName",
          "operator": "exact",
          "values": [
            "FINDSTR.EXE"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " /e ",
            " /si "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection_ext"
      },
      {
        "type": "wildcard_ref",
        "mode": "any",
        "pattern": "selection_other_*"
      }
    ]
  }
}