        }
      ]
    },
    "filter_optional_edge_update": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "contains",
          "values": [
            "\\AppData\\Local\\Microsoft\\EdgeUpdate\\Install\\{"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Image",
