{
  "title": "Potential Commandline Obfuscation Using Escape Characters",
  "rule_id": "f0cdd048-82dc-4f7a-8a7a-b87a52b6d0fd",
  "description": "Detects potential commandline obfuscation using known escape characters",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1140"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_susp_cli_obfuscation_escape_char.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "h^t^t^p",
            "h\"t\"t\"p"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}