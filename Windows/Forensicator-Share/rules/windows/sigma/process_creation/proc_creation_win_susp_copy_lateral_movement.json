{
  "title": "Copy From Or To Admin Share Or Sysvol Folder",
  "rule_id": "855bc8b5-2ae8-402e-a9ed-b889e6df1900",
  "description": "Detects a copy command or a copy utility execution to or from an Admin share or remote",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.lateral-movement",
    "attack.collection",
    "attack.exfiltration",
    "attack.t1039",
    "attack.t1048",
    "attack.t1021.002"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_susp_copy_lateral_movement.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_target": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "\\\\\\\\*\\\\*$",
            "\\Sysvol\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_other_tools": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\robocopy.exe",
                "\\xcopy.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "robocopy.exe",
                "XCOPY.EXE"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_cmd_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\cmd.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "Cmd.Exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_cmd_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "copy"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_pwsh_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "contains",
              "values": [
                "\\powershell_ise.exe",
                "\\powershell.exe",
                "\\pwsh.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "powershell_ise.exe",
                "PowerShell.EXE",
                "pwsh.dll"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_pwsh_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "copy-item",
            "copy ",
            "cpi ",
            " cp ",
            "move ",
            " move-item",
            " mi ",
            " mv "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection_target"
      },
      {
        "type": "any",
        "children": [
          {
            "type": "item_ref",
            "name": "selection_other_tools"
          },
          {
            "type": "wildcard_ref",
            "mode": "all",
            "pattern": "selection_cmd_*"
          },
          {
            "type": "wildcard_ref",
            "mode": "all",
            "pattern": "selection_pwsh_*"
          }
        ]
      }
    ]
  }
}