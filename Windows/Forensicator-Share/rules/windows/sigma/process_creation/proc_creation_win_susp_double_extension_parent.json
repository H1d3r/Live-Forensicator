{
  "title": "Suspicious Parent Double Extension File Execution",
  "rule_id": "5e6a80c8-2d45-4633-9ef4-fa2671a39c5c",
  "description": "Detect execution of suspicious double extension files in ParentCommandLine",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1036.007"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_susp_double_extension_parent.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "ParentImage",
              "operator": "endswith",
              "values": [
                ".doc.lnk",
                ".docx.lnk",
                ".xls.lnk",
                ".xlsx.lnk",
                ".ppt.lnk",
                ".pptx.lnk",
                ".rtf.lnk",
                ".pdf.lnk",
                ".txt.lnk",
                ".doc.js",
                ".docx.js",
                ".xls.js",
                ".xlsx.js",
                ".ppt.js",
                ".pptx.js",
                ".rtf.js",
                ".pdf.js",
                ".txt.js"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "ParentCommandLine",
              "operator": "contains",
              "values": [
                ".doc.lnk",
                ".docx.lnk",
                ".xls.lnk",
                ".xlsx.lnk",
                ".ppt.lnk",
                ".pptx.lnk",
                ".rtf.lnk",
                ".pdf.lnk",
                ".txt.lnk",
                ".doc.js",
                ".docx.js",
                ".xls.js",
                ".xlsx.js",
                ".ppt.js",
                ".pptx.js",
                ".rtf.js",
                ".pdf.js",
                ".txt.js"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}