{
  "title": "Suspicious Eventlog Clearing or Configuration Change Activity",
  "rule_id": "cc36992a-4671-4f21-a91d-6c2b72a2edf5",
  "description": "Detects the clearing or configuration tampering of EventLog using utilities such as \"wevtutil\", \"powershell\" and \"wmic\".\nThis technique were seen used by threat actors and ransomware strains in order to evade defenses.\n",
  "level": "high",
  "status": "stable",
  "tags": [
    "attack.defense-evasion",
    "attack.t1070.001",
    "attack.t1562.002",
    "car.2016-04-002"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_susp_eventlog_clear.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_wevtutil_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\wevtutil.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "wevtutil.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_wevtutil_cmd": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "clear-log ",
            " cl ",
            "set-log ",
            " sl ",
            "lfn:"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_other_ps_img": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\powershell.exe",
            "\\powershell_ise.exe",
            "\\pwsh.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_other_ps_cmd": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "contains",
              "values": [
                "Clear-EventLog ",
                "Remove-EventLog ",
                "Limit-EventLog ",
                "Clear-WinEvent "
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "contains",
              "values": [
                "Eventing.Reader.EventLogSession",
                "ClearLog"
              ],
              "match": "all",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "contains",
              "values": [
                "Diagnostics.EventLog",
                "Clear"
              ],
              "match": "all",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_other_wmi": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\powershell.exe",
            "\\powershell_ise.exe",
            "\\pwsh.exe",
            "\\wmic.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "ClearEventLog"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_msiexec": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "exact",
          "values": [
            "C:\\Windows\\SysWOW64\\msiexec.exe",
            "C:\\Windows\\System32\\msiexec.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " sl "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "any",
    "children": [
      {
        "type": "wildcard_ref",
        "mode": "all",
        "pattern": "selection_wevtutil_*"
      },
      {
        "type": "wildcard_ref",
        "mode": "all",
        "pattern": "selection_other_ps_*"
      },
      {
        "type": "all",
        "children": [
          {
            "type": "item_ref",
            "name": "selection_other_wmi"
          },
          {
            "type": "not",
            "child": {
              "type": "wildcard_ref",
              "mode": "any",
              "pattern": "filter_main_*"
            }
          }
        ]
      }
    ]
  }
}