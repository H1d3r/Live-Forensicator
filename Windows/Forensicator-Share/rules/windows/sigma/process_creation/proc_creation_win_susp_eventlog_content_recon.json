{
  "title": "Potentially Suspicious EventLog Recon Activity Using Log Query Utilities",
  "rule_id": "beaa66d6-aa1b-4e3c-80f5-e0145369bfaf",
  "description": "Detects execution of different log query utilities and commands to search and dump the content of specific event logs or look for specific event IDs.\nThis technique is used by threat actors in order to extract sensitive information from events logs such as usernames, IP addresses, hostnames, etc.\n",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.credential-access",
    "attack.discovery",
    "attack.t1552",
    "attack.t1087"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_susp_eventlog_content_recon.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_wmi": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "Select",
            "Win32_NTLogEvent"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_wevtutil_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\wevtutil.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "wevtutil.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_wevtutil_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " qe ",
            " query-events "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_wmic_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\wmic.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "wmic.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_wmic_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " ntevent"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_cmdlet": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "Get-WinEvent ",
            "get-eventlog "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_logs_name": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "Microsoft-Windows-PowerShell",
            "Microsoft-Windows-Security-Auditing",
            "Microsoft-Windows-TerminalServices-LocalSessionManager",
            "Microsoft-Windows-TerminalServices-RemoteConnectionManager",
            "Microsoft-Windows-Windows Defender",
            "PowerShellCore",
            "Security",
            "Windows PowerShell"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_logs_eid": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "-InstanceId 462?",
            ".eventid -eq 462?",
            ".ID -eq 462?",
            "EventCode=?462?",
            "EventIdentifier=?462?",
            "System[EventID=462?]",
            "-InstanceId 4778",
            ".eventid -eq 4778",
            ".ID -eq 4778",
            "EventCode=?4778?",
            "EventIdentifier=?4778?",
            "System[EventID=4778]",
            "-InstanceId 25",
            ".eventid -eq 25",
            ".ID -eq 25",
            "EventCode=?25?",
            "EventIdentifier=?25?",
            "System[EventID=25]",
            "-InstanceId 1149",
            ".eventid -eq 1149",
            ".ID -eq 1149",
            "EventCode=?1149?",
            "EventIdentifier=?1149?",
            "System[EventID=1149]",
            "-InstanceId 21",
            ".eventid -eq 21",
            ".ID -eq 21",
            "EventCode=?21?",
            "EventIdentifier=?21?",
            "System[EventID=21]",
            "-InstanceId 22",
            ".eventid -eq 22",
            ".ID -eq 22",
            "EventCode=?22?",
            "EventIdentifier=?22?",
            "System[EventID=22]"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "wildcard_ref",
        "mode": "any",
        "pattern": "selection_logs_*"
      },
      {
        "type": "any",
        "children": [
          {
            "type": "item_ref",
            "name": "selection_wmi"
          },
          {
            "type": "wildcard_ref",
            "mode": "all",
            "pattern": "selection_wevtutil_*"
          },
          {
            "type": "wildcard_ref",
            "mode": "all",
            "pattern": "selection_wmic_*"
          },
          {
            "type": "item_ref",
            "name": "selection_cmdlet"
          }
        ]
      }
    ]
  }
}