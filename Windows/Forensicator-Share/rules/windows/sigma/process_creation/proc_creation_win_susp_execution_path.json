{
  "title": "Process Execution From A Potentially Suspicious Folder",
  "rule_id": "3dfd06d2-eaf4-4532-9555-68aca59f57c4",
  "description": "Detects a potentially suspicious execution from an uncommon folder.",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1036"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_susp_execution_path.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "contains",
          "values": [
            ":\\Perflogs\\",
            ":\\Users\\All Users\\",
            ":\\Users\\Default\\",
            ":\\Users\\NetworkService\\",
            ":\\Windows\\addins\\",
            ":\\Windows\\debug\\",
            ":\\Windows\\Fonts\\",
            ":\\Windows\\Help\\",
            ":\\Windows\\IME\\",
            ":\\Windows\\Media\\",
            ":\\Windows\\repair\\",
            ":\\Windows\\security\\",
            ":\\Windows\\System32\\Tasks\\",
            ":\\Windows\\Tasks\\",
            "$Recycle.bin",
            "\\config\\systemprofile\\",
            "\\Intel\\Logs\\",
            "\\RSA\\MachineKeys\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_optional_ibm": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "startswith",
          "values": [
            "C:\\Users\\Public\\IBM\\ClientSolutions\\Start_Programs\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_optional_citrix": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "startswith",
          "values": [
            "C:\\Windows\\SysWOW64\\config\\systemprofile\\Citrix\\UpdaterBinaries\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\CitrixReceiverUpdater.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_optional_*"
        }
      }
    ]
  }
}