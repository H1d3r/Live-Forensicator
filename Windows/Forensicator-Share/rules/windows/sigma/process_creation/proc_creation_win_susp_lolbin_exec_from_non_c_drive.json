{
  "title": "LOLBIN Execution From Abnormal Drive",
  "rule_id": "d4ca7c59-e9e4-42d8-bf57-91a776efcb87",
  "description": "Detects LOLBINs executing from an abnormal or uncommon drive such as a mounted ISO.",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_susp_lolbin_exec_from_non_c_drive.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\calc.exe",
                "\\certutil.exe",
                "\\cmstp.exe",
                "\\cscript.exe",
                "\\installutil.exe",
                "\\mshta.exe",
                "\\regsvr32.exe",
                "\\rundll32.exe",
                "\\wscript.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "CALC.EXE",
                "CertUtil.exe",
                "CMSTP.EXE",
                "cscript.exe",
                "installutil.exe",
                "MSHTA.EXE",
                "REGSVR32.EXE",
                "RUNDLL32.EXE",
                "wscript.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "filter_main_currentdirectory": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CurrentDirectory",
          "operator": "contains",
          "values": [
            "C:\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_empty": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CurrentDirectory",
          "operator": "exact",
          "values": [
            ""
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_null": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CurrentDirectory",
          "operator": "is_null",
          "values": [],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_main_*"
        }
      }
    ]
  }
}