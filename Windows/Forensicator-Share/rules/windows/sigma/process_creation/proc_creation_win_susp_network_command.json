{
  "title": "Suspicious Network Command",
  "rule_id": "a29c1813-ab1f-4dde-b489-330b952e91ae",
  "description": "Adversaries may look for details about the network configuration and settings of systems they access or through information discovery of remote systems",
  "level": "low",
  "status": "test",
  "tags": [
    "attack.discovery",
    "attack.t1016"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_susp_network_command.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "re",
          "values": [
            "ipconfig\\s+/all",
            "netsh\\s+interface show interface",
            "arp\\s+-a",
            "nbtstat\\s+-n",
            "net\\s+config",
            "route\\s+print"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": false
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}