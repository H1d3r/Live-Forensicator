{
  "title": "Non-privileged Usage of Reg or Powershell",
  "rule_id": "8f02c935-effe-45b3-8fc9-ef8696a9e41d",
  "description": "Search for usage of reg or Powershell by non-privileged users to modify service configuration in registry",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.persistence",
    "attack.defense-evasion",
    "attack.t1112"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_susp_non_priv_reg_or_ps.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_cli": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "contains",
              "values": [
                "reg ",
                "add"
              ],
              "match": "all",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "contains",
              "values": [
                "powershell",
                "set-itemproperty",
                " sp ",
                "new-itemproperty"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_data": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "IntegrityLevel",
          "operator": "exact",
          "values": [
            "Medium",
            "S-1-16-8192"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "ControlSet",
            "Services"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "ImagePath",
            "FailureCommand",
            "ServiceDLL"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}