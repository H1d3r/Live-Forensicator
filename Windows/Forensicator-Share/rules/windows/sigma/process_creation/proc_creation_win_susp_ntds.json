{
  "title": "Suspicious Process Patterns NTDS.DIT Exfil",
  "rule_id": "8bc64091-6875-4881-aaf9-7bd25b5dda08",
  "description": "Detects suspicious process patterns used in NTDS.DIT exfiltration",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.credential-access",
    "attack.t1003.003"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_susp_ntds.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection_tool": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\NTDSDump.exe",
                "\\NTDSDumpEx.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "contains",
              "values": [
                "ntds.dit",
                "system.hiv"
              ],
              "match": "all",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "contains",
              "values": [
                "NTDSgrab.ps1"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_oneliner_1": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "ac i ntds",
            "create full"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_onliner_2": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "/c copy ",
            "\\windows\\ntds\\ntds.dit"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_onliner_3": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "activate instance ntds",
            "create full"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_powershell": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "powershell",
            "ntds.dit"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "set1_selection_ntds_dit": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "ntds.dit"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "set1_selection_image_folder": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "ParentImage",
              "operator": "contains",
              "values": [
                "\\apache",
                "\\tomcat",
                "\\AppData\\",
                "\\Temp\\",
                "\\Public\\",
                "\\PerfLogs\\"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "contains",
              "values": [
                "\\apache",
                "\\tomcat",
                "\\AppData\\",
                "\\Temp\\",
                "\\Public\\",
                "\\PerfLogs\\"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    }
  },
  "condition": {
    "type": "any",
    "children": [
      {
        "type": "wildcard_ref",
        "mode": "any",
        "pattern": "selection*"
      },
      {
        "type": "wildcard_ref",
        "mode": "all",
        "pattern": "set1*"
      }
    ]
  }
}