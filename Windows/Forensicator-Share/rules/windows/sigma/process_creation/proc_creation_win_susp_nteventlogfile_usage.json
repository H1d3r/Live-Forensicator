{
  "title": "Potentially Suspicious Call To Win32_NTEventlogFile Class",
  "rule_id": "caf201a9-c2ce-4a26-9c3a-2b9525413711",
  "description": "Detects usage of the WMI class \"Win32_NTEventlogFile\" in a potentially suspicious way (delete, backup, change permissions, etc.) from a PowerShell script",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_susp_nteventlogfile_usage.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection_class": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "Win32_NTEventlogFile"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_function": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            ".BackupEventlog(",
            ".ChangeSecurityPermissions(",
            ".ChangeSecurityPermissionsEx(",
            ".ClearEventLog(",
            ".Delete(",
            ".DeleteEx(",
            ".Rename(",
            ".TakeOwnerShip(",
            ".TakeOwnerShipEx("
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}