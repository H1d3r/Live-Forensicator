{
  "title": "Use NTFS Short Name in Image",
  "rule_id": "3ef5605c-9eb9-47b0-9a71-b727e6aa5c3b",
  "description": "Detect use of the Windows 8.3 short name. Which could be used as a method to avoid Image based detection",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1564.004"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_susp_ntfs_short_name_use_image.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "contains",
          "values": [
            "~1.bat",
            "~1.dll",
            "~1.exe",
            "~1.hta",
            "~1.js",
            "~1.msi",
            "~1.ps1",
            "~1.tmp",
            "~1.vbe",
            "~1.vbs",
            "~2.bat",
            "~2.dll",
            "~2.exe",
            "~2.hta",
            "~2.js",
            "~2.msi",
            "~2.ps1",
            "~2.tmp",
            "~2.vbe",
            "~2.vbs"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_generic_parent": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "exact",
          "values": [
            "C:\\Windows\\explorer.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_optional_webex": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\WebEx\\WebexHost.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_optional_thor": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\thor\\thor64.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_optional_winzip": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "exact",
          "values": [
            "C:\\PROGRA~1\\WinZip\\WZPREL~1.EXE"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_optional_vcred": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\VCREDI~1.EXE"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_main_*"
        }
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_optional_*"
        }
      }
    ]
  }
}