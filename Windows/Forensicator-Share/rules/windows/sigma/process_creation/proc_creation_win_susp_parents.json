{
  "title": "Suspicious Process Parents",
  "rule_id": "cbec226f-63d9-4eca-9f52-dfb6652f24df",
  "description": "Detects suspicious parent processes that should not have any children or should only have a single possible child program",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1036"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_susp_parents.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\minesweeper.exe",
            "\\winver.exe",
            "\\bitsadmin.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_special": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\csrss.exe",
            "\\certutil.exe",
            "\\eventvwr.exe",
            "\\calc.exe",
            "\\notepad.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_special": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\WerFault.exe",
            "\\wermgr.exe",
            "\\conhost.exe",
            "\\mmc.exe",
            "\\win32calc.exe",
            "\\notepad.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_null": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "is_null",
          "values": [],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "any",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "all",
        "children": [
          {
            "type": "item_ref",
            "name": "selection_special"
          },
          {
            "type": "not",
            "child": {
              "type": "wildcard_ref",
              "mode": "any",
              "pattern": "filter_*"
            }
          }
        ]
      }
    ]
  }
}