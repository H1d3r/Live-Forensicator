{
  "title": "Suspicious RunAs-Like Flag Combination",
  "rule_id": "50d66fb0-03f8-4da0-8add-84e77d12a020",
  "description": "Detects suspicious command line flags that let the user set a target user and command as e.g. seen in PsExec-like tools",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.privilege-escalation"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_susp_privilege_escalation_cli_patterns.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection_user": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " -u system ",
            " --user system ",
            " -u NT",
            " -u \"NT",
            " -u 'NT",
            " --system ",
            " -u administrator "
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_command": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " -c cmd",
            " -c \"cmd",
            " -c powershell",
            " -c \"powershell",
            " --command cmd",
            " --command powershell",
            " -c whoami",
            " -c wscript",
            " -c cscript"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection*"
  }
}