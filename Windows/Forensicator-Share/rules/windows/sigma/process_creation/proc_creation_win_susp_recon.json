{
  "title": "Recon Information for Export with Command Prompt",
  "rule_id": "aa2efee7-34dd-446e-8a37-40790a66efd7",
  "description": "Once established within a system or network, an adversary may use automated techniques for collecting internal data.",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.collection",
    "attack.t1119"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_susp_recon.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_image": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\tree.com",
                "\\WMIC.exe",
                "\\doskey.exe",
                "\\sc.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "wmic.exe",
                "DOSKEY.EXE",
                "sc.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_redirect": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentCommandLine",
          "operator": "contains",
          "values": [
            " > %TEMP%\\",
            " > %TMP%\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection*"
  }
}