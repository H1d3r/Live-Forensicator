{
  "title": "Suspicious Service Binary Directory",
  "rule_id": "883faa95-175a-4e22-8181-e5761aeb373c",
  "description": "Detects a service binary running in a suspicious directory",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1202"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_susp_service_dir.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "contains",
          "values": [
            "\\Users\\Public\\",
            "\\$Recycle.bin",
            "\\Users\\All Users\\",
            "\\Users\\Default\\",
            "\\Users\\Contacts\\",
            "\\Users\\Searches\\",
            "C:\\Perflogs\\",
            "\\config\\systemprofile\\",
            "\\Windows\\Fonts\\",
            "\\Windows\\IME\\",
            "\\Windows\\addins\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\services.exe",
            "\\svchost.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}