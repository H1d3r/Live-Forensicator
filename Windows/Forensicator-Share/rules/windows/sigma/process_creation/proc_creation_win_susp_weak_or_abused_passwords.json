{
  "title": "Weak or Abused Passwords In CLI",
  "rule_id": "91edcfb1-2529-4ac2-9ecc-7617f895c7e4",
  "description": "Detects weak passwords or often abused passwords (seen used by threat actors) via the CLI.\nAn example would be a threat actor creating a new user via the net command and providing the password inline\n",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.execution"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_susp_weak_or_abused_passwords.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "123456789",
            "123123qwE",
            "Asd123.aaaa",
            "Decryptme",
            "P@ssw0rd!",
            "Pass8080",
            "password123",
            "test@202"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}