{
  "title": "WhoAmI as Parameter",
  "rule_id": "e9142d84-fbe0-401d-ac50-3e519fb00c89",
  "description": "Detects a suspicious process command line that uses whoami as first parameter (as e.g. used by EfsPotato)",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.discovery",
    "attack.t1033",
    "car.2016-03-001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_susp_whoami_as_param.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            ".exe whoami"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}