{
  "title": "PsExec/PAExec Escalation to LOCAL SYSTEM",
  "rule_id": "8834e2f7-6b4b-4f09-8906-d2276470ee23",
  "description": "Detects suspicious commandline flags used by PsExec and PAExec to escalate a command line to LOCAL_SYSTEM rights",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.resource-development",
    "attack.t1587.001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_sysinternals_psexec_paexec_escalate_system.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection_sys": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " -s cmd",
            " -s -i cmd",
            " -i -s cmd",
            " -s pwsh",
            " -s -i pwsh",
            " -i -s pwsh",
            " -s powershell",
            " -s -i powershell",
            " -i -s powershell"
          ],
          "match": "any",
          "windash": true,
          "ignore_case": true
        }
      ]
    },
    "selection_other": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "psexec",
            "paexec",
            "accepteula"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}