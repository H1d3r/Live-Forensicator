{
  "title": "Potential File Overwrite Via Sysinternals SDelete",
  "rule_id": "a4824fca-976f-4964-b334-0621379e84c4",
  "description": "Detects the use of SDelete to erase a file not the free space",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.impact",
    "attack.t1485"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_sysinternals_sdelete.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "OriginalFileName",
          "operator": "exact",
          "values": [
            "sdelete.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " -h",
            " -c",
            " -z",
            " /\\?"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "item_ref",
          "name": "filter"
        }
      }
    ]
  }
}