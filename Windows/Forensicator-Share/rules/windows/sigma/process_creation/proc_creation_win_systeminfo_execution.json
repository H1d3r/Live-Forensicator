{
  "title": "Suspicious Execution of Systeminfo",
  "rule_id": "0ef56343-059e-4cb6-adc1-4c3c967c5e46",
  "description": "Detects usage of the \"systeminfo\" command to retrieve information",
  "level": "low",
  "status": "test",
  "tags": [
    "attack.discovery",
    "attack.t1082"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_systeminfo_execution.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\systeminfo.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "sysinfo.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}