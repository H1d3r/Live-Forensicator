{
  "title": "Suspicious RDP Redirect Using TSCON",
  "rule_id": "f72aa3e8-49f9-4c7d-bd74-f8ab84ff9bbb",
  "description": "Detects a suspicious RDP session redirect using tscon.exe",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.lateral-movement",
    "attack.t1563.002",
    "attack.t1021.001",
    "car.2013-07-002"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_tscon_rdp_redirect.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " /dest:rdp-tcp#"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}