{
  "title": "CMSTP UAC Bypass via COM Object Access",
  "rule_id": "4b60e6f2-bf39-47b4-b4ea-398e33cfe253",
  "description": "Detects UAC Bypass Attempt Using Microsoft Connection Manager Profile Installer Autoelevate-capable COM Objects (e.g. UACMe ID of 41, 43, 58 or 65)",
  "level": "high",
  "status": "stable",
  "tags": [
    "attack.execution",
    "attack.defense-evasion",
    "attack.privilege-escalation",
    "attack.t1548.002",
    "attack.t1218.003",
    "attack.g0069",
    "car.2019-04-001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_uac_bypass_cmstp_com_object_access.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\DllHost.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "ParentCommandLine",
          "operator": "contains",
          "values": [
            " /Processid:{3E5FC7F9-9A51-4367-9063-A120244FBEC7}",
            " /Processid:{3E000D72-A845-4CD9-BD83-80C07C3B881F}",
            " /Processid:{BD54C901-076B-434E-B6C7-17C531F4AB41}",
            " /Processid:{D2E7041B-2927-42FB-8E9F-7CE93B6DC937}",
            " /Processid:{E9495B87-D950-4AB5-87A5-FF6D70BF3E90}"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "IntegrityLevel",
          "operator": "exact",
          "values": [
            "High",
            "System",
            "S-1-16-16384",
            "S-1-16-12288"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}