{
  "title": "UAC Bypass Using Consent and Comctl32 - Process",
  "rule_id": "1ca6bd18-0ba0-44ca-851c-92ed89a61085",
  "description": "Detects the pattern of UAC Bypass using consent.exe and comctl32.dll (UACMe 22)",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.privilege-escalation",
    "attack.t1548.002"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_uac_bypass_consent_comctl32.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\consent.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\werfault.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "IntegrityLevel",
          "operator": "exact",
          "values": [
            "High",
            "System",
            "S-1-16-16384",
            "S-1-16-12288"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}