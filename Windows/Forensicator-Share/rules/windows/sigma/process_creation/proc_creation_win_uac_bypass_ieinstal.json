{
  "title": "UAC Bypass Using IEInstal - Process",
  "rule_id": "80fc36aa-945e-4181-89f2-2f907ab6775d",
  "description": "Detects the pattern of UAC Bypass using IEInstal.exe (UACMe 64)",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.privilege-escalation",
    "attack.t1548.002"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_uac_bypass_ieinstal.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "IntegrityLevel",
          "operator": "exact",
          "values": [
            "High",
            "System",
            "S-1-16-16384",
            "S-1-16-12288"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\ieinstal.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Image",
          "operator": "contains",
          "values": [
            "\\AppData\\Local\\Temp\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "consent.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}