{
  "title": "UAC Bypass Using MSConfig Token Modification - Process",
  "rule_id": "ad92e3f9-7eb6-460e-96b1-582b0ccbb980",
  "description": "Detects the pattern of UAC Bypass using a msconfig GUI hack (UACMe 55)",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.privilege-escalation",
    "attack.t1548.002"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_uac_bypass_msconfig_gui.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "IntegrityLevel",
          "operator": "exact",
          "values": [
            "High",
            "System",
            "S-1-16-16384",
            "S-1-16-12288"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\AppData\\Local\\Temp\\pkgmgr.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "exact",
          "values": [
            "\"C:\\Windows\\system32\\msconfig.exe\" -5"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}