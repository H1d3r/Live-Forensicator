{
  "title": "Suspicious UltraVNC Execution",
  "rule_id": "871b9555-69ca-4993-99d3-35a59f9f3599",
  "description": "Detects suspicious UltraVNC command line flag combination that indicate a auto reconnect upon execution, e.g. startup (as seen being used by Gamaredon threat group)",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.lateral-movement",
    "attack.g0047",
    "attack.t1021.005"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_ultravnc_susp_execution.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "-autoreconnect ",
            "-connect ",
            "-id:"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}