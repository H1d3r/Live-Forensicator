{
  "title": "Visual Studio Code Tunnel Service Installation",
  "rule_id": "30bf1789-379d-4fdc-900f-55cd0a90a801",
  "description": "Detects the installation of VsCode tunnel (code-tunnel) as a service.",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.command-and-control",
    "attack.t1071.001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_vscode_tunnel_service_install.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "tunnel ",
            "service",
            "internal-run",
            "tunnel-service.log"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}