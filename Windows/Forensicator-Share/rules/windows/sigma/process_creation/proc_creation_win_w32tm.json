{
  "title": "Use of W32tm as Timer",
  "rule_id": "6da2c9f5-7c53-401b-aacb-92c040ce1215",
  "description": "When configured with suitable command line arguments, w32tm can act as a delay mechanism",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.discovery",
    "attack.t1124"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_w32tm.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_w32tm": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\w32tm.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "w32time.dll"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_cmd": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "/stripchart",
            "/computer:",
            "/period:",
            "/dataonly",
            "/samples:"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}