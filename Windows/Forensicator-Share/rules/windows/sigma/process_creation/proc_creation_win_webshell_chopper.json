{
  "title": "Chopper Webshell Process Pattern",
  "rule_id": "fa3c117a-bc0d-416e-a31b-0c0e80653efb",
  "description": "Detects patterns found in process executions cause by China Chopper like tiny (ASPX) webshells",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.persistence",
    "attack.discovery",
    "attack.t1505.003",
    "attack.t1018",
    "attack.t1033",
    "attack.t1087"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_webshell_chopper.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection_origin": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\w3wp.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "ParentImage",
              "operator": "endswith",
              "values": [
                "\\w3wp.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_cmdline": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "&ipconfig&echo",
            "&quser&echo",
            "&whoami&echo",
            "&c:&echo",
            "&cd&echo",
            "&dir&echo",
            "&echo [E]",
            "&echo [S]"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}