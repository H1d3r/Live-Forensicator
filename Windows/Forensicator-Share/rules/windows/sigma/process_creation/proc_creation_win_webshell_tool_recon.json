{
  "title": "Webshell Tool Reconnaissance Activity",
  "rule_id": "f64e5c19-879c-4bae-b471-6d84c8339677",
  "description": "Detects processes spawned from web servers (PHP, Tomcat, IIS, etc.) that perform reconnaissance looking for the existence of popular scripting tools (perl, python, wget) on the system via the help commands\n",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.persistence",
    "attack.t1505.003"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_webshell_tool_recon.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection_webserver_image": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\caddy.exe",
            "\\httpd.exe",
            "\\nginx.exe",
            "\\php-cgi.exe",
            "\\w3wp.exe",
            "\\ws_tomcatservice.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_webserver_characteristics_tomcat1": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\java.exe",
            "\\javaw.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "contains",
          "values": [
            "-tomcat-",
            "\\tomcat"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_webserver_characteristics_tomcat2": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\java.exe",
            "\\javaw.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "CATALINA_HOME",
            "catalina.jar"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_recon": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "perl --help",
            "perl -h",
            "python --help",
            "python -h",
            "python3 --help",
            "python3 -h",
            "wget --help"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "wildcard_ref",
        "mode": "any",
        "pattern": "selection_webserver_*"
      },
      {
        "type": "item_ref",
        "name": "selection_recon"
      }
    ]
  }
}