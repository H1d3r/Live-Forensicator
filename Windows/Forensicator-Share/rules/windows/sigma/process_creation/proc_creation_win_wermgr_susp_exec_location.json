{
  "title": "Suspicious Execution Location Of Wermgr.EXE",
  "rule_id": "5394fcc7-aeb2-43b5-9a09-cac9fc5edcd5",
  "description": "Detects suspicious Windows Error Reporting manager (wermgr.exe) execution location.",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.execution"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_wermgr_susp_exec_location.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\wermgr.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_legit_location": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "startswith",
          "values": [
            "C:\\Windows\\System32\\",
            "C:\\Windows\\SysWOW64\\",
            "C:\\Windows\\WinSxS\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_main_*"
        }
      }
    ]
  }
}