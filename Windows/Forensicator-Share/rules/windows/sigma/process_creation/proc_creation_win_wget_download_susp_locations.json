{
  "title": "Suspicious File Download From IP Via Wget.EXE - Paths",
  "rule_id": "40aa399c-7b02-4715-8e5f-73572b493f33",
  "description": "Detects potentially suspicious file downloads directly from IP addresses and stored in suspicious locations using Wget.exe",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.execution"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_wget_download_susp_locations.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\wget.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "wget.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_ip": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "re",
          "values": [
            "://[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": false
        }
      ]
    },
    "selection_http": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "http"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_flag": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "re",
              "values": [
                "\\s-O\\s"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": false
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "contains",
              "values": [
                "--output-document"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_paths": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "contains",
              "values": [
                ":\\PerfLogs\\",
                ":\\Temp\\",
                ":\\Users\\Public\\",
                ":\\Windows\\Help\\",
                ":\\Windows\\Temp\\",
                "\\Temporary Internet"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "contains",
              "values": [
                ":\\Users\\",
                "\\Favorites\\"
              ],
              "match": "all",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "contains",
              "values": [
                ":\\Users\\",
                "\\Favourites\\"
              ],
              "match": "all",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "contains",
              "values": [
                ":\\Users\\",
                "\\Contacts\\"
              ],
              "match": "all",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "CommandLine",
              "operator": "contains",
              "values": [
                ":\\Users\\",
                "\\Pictures\\"
              ],
              "match": "all",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}