{
  "title": "Enumerate All Information With Whoami.EXE",
  "rule_id": "c248c896-e412-4279-8c15-1c558067b6fa",
  "description": "Detects the execution of \"whoami.exe\" with the \"/all\" flag",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.discovery",
    "attack.t1033",
    "car.2016-03-001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_whoami_all_execution.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_main_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\whoami.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "whoami.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_main_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " -all"
          ],
          "match": "any",
          "windash": true,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_main_*"
  }
}