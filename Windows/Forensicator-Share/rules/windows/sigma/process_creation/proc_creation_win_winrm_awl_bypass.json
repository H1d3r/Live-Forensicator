{
  "title": "AWL Bypass with Winrm.vbs and Malicious WsmPty.xsl/WsmTxt.xsl",
  "rule_id": "074e0ded-6ced-4ebd-8b4d-53f55908119d",
  "description": "Detects execution of attacker-controlled WsmPty.xsl or WsmTxt.xsl via winrm.vbs and copied cscript.exe (can be renamed)",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1216"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_winrm_awl_bypass.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "contains_format_pretty_arg": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "format:pretty",
            "format:\"pretty\"",
            "format:\"text\"",
            "format:text"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "image_from_system_folder": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "startswith",
          "values": [
            "C:\\Windows\\System32\\",
            "C:\\Windows\\SysWOW64\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "contains_winrm": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "winrm"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "contains_winrm"
      },
      {
        "type": "item_ref",
        "name": "contains_format_pretty_arg"
      },
      {
        "type": "not",
        "child": {
          "type": "item_ref",
          "name": "image_from_system_folder"
        }
      }
    ]
  }
}