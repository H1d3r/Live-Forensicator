{
  "title": "Potential Unquoted Service Path Reconnaissance Via Wmic.EXE",
  "rule_id": "68bcd73b-37ef-49cb-95fc-edc809730be6",
  "description": "Detects known WMI recon method to look for unquoted service paths using wmic. Often used by pentester and attacker enumeration scripts",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1047"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_wmic_recon_unquoted_service_search.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "wmic.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\WMIC.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            " service get ",
            "name,displayname,pathname,startmode"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection*"
  }
}