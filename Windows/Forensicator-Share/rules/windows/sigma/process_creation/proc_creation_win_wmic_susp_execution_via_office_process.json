{
  "title": "Suspicious WMIC Execution Via Office Process",
  "rule_id": "e1693bc8-7168-4eab-8718-cdcaa68a1738",
  "description": "Office application called wmic to proxye execution through a LOLBIN process. This is often used to break suspicious parent-child chain (Office app spawns LOLBin).",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.t1204.002",
    "attack.t1047",
    "attack.t1218.010",
    "attack.execution",
    "attack.defense-evasion"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_wmic_susp_execution_via_office_process.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection_parent": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "ParentImage",
          "operator": "endswith",
          "values": [
            "\\WINWORD.EXE",
            "\\EXCEL.EXE",
            "\\POWERPNT.exe",
            "\\MSPUB.exe",
            "\\VISIO.exe",
            "\\MSACCESS.EXE",
            "\\EQNEDT32.EXE",
            "\\ONENOTE.EXE",
            "\\wordpad.exe",
            "\\wordview.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_wmic_img": {
      "type": "any",
      "children": [
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "Image",
              "operator": "endswith",
              "values": [
                "\\wbem\\WMIC.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        },
        {
          "type": "all",
          "children": [
            {
              "type": "field",
              "field": "OriginalFileName",
              "operator": "exact",
              "values": [
                "wmic.exe"
              ],
              "match": "any",
              "windash": false,
              "ignore_case": true
            }
          ]
        }
      ]
    },
    "selection_wmic_cli": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "process",
            "create",
            "call"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "regsvr32",
            "rundll32",
            "msiexec",
            "mshta",
            "verclsid",
            "wscript",
            "cscript"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "wildcard_ref",
    "mode": "all",
    "pattern": "selection_*"
  }
}