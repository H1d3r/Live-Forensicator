{
  "title": "Suspicious Process Created Via Wmic.EXE",
  "rule_id": "3c89a1e8-0fba-449e-8f1b-8409d6267ec8",
  "description": "Detects WMIC executing \"process call create\" with suspicious calls to processes such as \"rundll32\", \"regsrv32\", etc.",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.t1047"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_wmic_susp_process_creation.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "process ",
            "call ",
            "create "
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "rundll32",
            "bitsadmin",
            "regsvr32",
            "cmd.exe /c ",
            "cmd.exe /k ",
            "cmd.exe /r ",
            "cmd /c ",
            "cmd /k ",
            "cmd /r ",
            "powershell",
            "pwsh",
            "certutil",
            "cscript",
            "wscript",
            "mshta",
            "\\Users\\Public\\",
            "\\Windows\\Temp\\",
            "\\AppData\\Local\\",
            "%temp%",
            "%tmp%",
            "%ProgramData%",
            "%appdata%",
            "%comspec%",
            "%localappdata%"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}