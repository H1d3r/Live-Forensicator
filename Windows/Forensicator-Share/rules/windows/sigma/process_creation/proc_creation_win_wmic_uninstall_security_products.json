{
  "title": "Potential Tampering With Security Products Via WMIC",
  "rule_id": "847d5ff3-8a31-4737-a970-aeae8fe21765",
  "description": "Detects uninstallation or termination of security products using the WMIC utility",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.defense-evasion",
    "attack.t1562.001"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_wmic_uninstall_security_products.yml",
  "sources": [
    "security_process_creation",
    "sysmon_process_creation"
  ],
  "items": {
    "selection_cli_1": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "wmic",
            "product where ",
            "call",
            "uninstall",
            "/nointeractive"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_cli_2": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "wmic",
            "caption like "
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "call delete",
            "call terminate"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_cli_3": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "process ",
            "where ",
            "delete"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_product": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "CommandLine",
          "operator": "contains",
          "values": [
            "%carbon%",
            "%cylance%",
            "%endpoint%",
            "%eset%",
            "%malware%",
            "%Sophos%",
            "%symantec%",
            "Antivirus",
            "AVG ",
            "Carbon Black",
            "CarbonBlack",
            "Cb Defense Sensor 64-bit",
            "Crowdstrike Sensor",
            "Cylance ",
            "Dell Threat Defense",
            "DLP Endpoint",
            "Endpoint Detection",
            "Endpoint Protection",
            "Endpoint Security",
            "Endpoint Sensor",
            "ESET File Security",
            "LogRhythm System Monitor Service",
            "Malwarebytes",
            "McAfee Agent",
            "Microsoft Security Client",
            "Sophos Anti-Virus",
            "Sophos AutoUpdate",
            "Sophos Credential Store",
            "Sophos Management Console",
            "Sophos Management Database",
            "Sophos Management Server",
            "Sophos Remote Management System",
            "Sophos Update Manager",
            "Threat Protection",
            "VirusScan",
            "Webroot SecureAnywhere",
            "Windows Defender"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "wildcard_ref",
        "mode": "any",
        "pattern": "selection_cli_*"
      },
      {
        "type": "item_ref",
        "name": "selection_product"
      }
    ]
  }
}