{
  "title": "Windows Binary Executed From WSL",
  "rule_id": "ed825c86-c009-4014-b413-b76003e33d35",
  "description": "Detects the execution of Windows binaries from within a WSL instance.\nThis could be used to masquerade parent-child relationships\n",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.execution",
    "attack.defense-evasion",
    "attack.t1202"
  ],
  "category": "process_creation",
  "rule_file": "rules/windows/process_creation/proc_creation_win_wsl_windows_binaries_execution.yml",
  "sources": [
    "sysmon_process_creation"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "re",
          "values": [
            "[a-zA-Z]:\\\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": false
        },
        {
          "type": "field",
          "field": "CurrentDirectory",
          "operator": "contains",
          "values": [
            "\\\\\\\\wsl.localhost"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}