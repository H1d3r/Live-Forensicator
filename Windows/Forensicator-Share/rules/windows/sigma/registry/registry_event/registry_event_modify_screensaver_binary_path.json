{
  "title": "Path To Screensaver Binary Modified",
  "rule_id": "67a6c006-3fbe-46a7-9074-2ba3b82c3000",
  "description": "Detects value modification of registry key containing path to binary used as screensaver.",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.persistence",
    "attack.privilege-escalation",
    "attack.t1546.002"
  ],
  "category": "registry_event",
  "rule_file": "rules/windows/registry/registry_event/registry_event_modify_screensaver_binary_path.yml",
  "sources": [
    "sysmon_registry_event"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "TargetObject",
          "operator": "endswith",
          "values": [
            "\\Control Panel\\Desktop\\SCRNSAVE.EXE"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "endswith",
          "values": [
            "\\rundll32.exe",
            "\\explorer.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "item_ref",
          "name": "filter"
        }
      }
    ]
  }
}