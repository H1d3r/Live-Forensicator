{
  "title": "NetNTLM Downgrade Attack - Registry",
  "rule_id": "d67572a0-e2ec-45d6-b8db-c100d14b8ef2",
  "description": "Detects NetNTLM downgrade attack",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.persistence",
    "attack.defense-evasion",
    "attack.t1562.001",
    "attack.t1112"
  ],
  "category": "registry_event",
  "rule_file": "rules/windows/registry/registry_event/registry_event_net_ntlm_downgrade.yml",
  "sources": [
    "sysmon_registry_event"
  ],
  "items": {
    "selection_regkey": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "TargetObject",
          "operator": "contains",
          "values": [
            "SYSTEM\\",
            "ControlSet",
            "\\Control\\Lsa"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_value_lmcompatibilitylevel": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "TargetObject",
          "operator": "endswith",
          "values": [
            "\\lmcompatibilitylevel"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Details",
          "operator": "exact",
          "values": [
            "DWORD (0x00000000)",
            "DWORD (0x00000001)",
            "DWORD (0x00000002)"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_value_ntlmminclientsec": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "TargetObject",
          "operator": "endswith",
          "values": [
            "\\NtlmMinClientSec"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Details",
          "operator": "exact",
          "values": [
            "DWORD (0x00000000)",
            "DWORD (0x00000010)",
            "DWORD (0x00000020)",
            "DWORD (0x00000030)"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection_value_restrictsendingntlmtraffic": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "TargetObject",
          "operator": "endswith",
          "values": [
            "\\RestrictSendingNTLMTraffic"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection_regkey"
      },
      {
        "type": "wildcard_ref",
        "mode": "any",
        "pattern": "selection_value_*"
      }
    ]
  }
}