{
  "title": "RedMimicry Winnti Playbook Registry Manipulation",
  "rule_id": "5b175490-b652-4b02-b1de-5b5b4083c5f8",
  "description": "Detects actions caused by the RedMimicry Winnti playbook",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.persistence",
    "attack.defense-evasion",
    "attack.t1112"
  ],
  "category": "registry_event",
  "rule_file": "rules/windows/registry/registry_event/registry_event_redmimicry_winnti_reg.yml",
  "sources": [
    "sysmon_registry_event"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "TargetObject",
          "operator": "contains",
          "values": [
            "HKLM\\SOFTWARE\\Microsoft\\HTMLHelp\\data"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}