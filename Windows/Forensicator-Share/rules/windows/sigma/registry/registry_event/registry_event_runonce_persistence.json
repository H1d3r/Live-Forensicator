{
  "title": "Run Once Task Configuration in Registry",
  "rule_id": "c74d7efc-8826-45d9-b8bb-f04fac9e4eff",
  "description": "Rule to detect the configuration of Run Once registry key. Configured payload can be run by runonce.exe /AlternateShellStartup",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.persistence",
    "attack.defense-evasion",
    "attack.t1112"
  ],
  "category": "registry_event",
  "rule_file": "rules/windows/registry/registry_event/registry_event_runonce_persistence.yml",
  "sources": [
    "sysmon_registry_event"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "TargetObject",
          "operator": "contains",
          "values": [
            "\\Microsoft\\Active Setup\\Installed Components"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "TargetObject",
          "operator": "endswith",
          "values": [
            "\\StubPath"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_optional_chrome": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Details",
          "operator": "contains",
          "values": [
            "C:\\Program Files\\Google\\Chrome\\Application\\",
            "\\Installer\\chrmstp.exe\" --configure-user-settings --verbose-logging --system-level"
          ],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_optional_edge": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Details",
          "operator": "contains",
          "values": [
            "C:\\Program Files (x86)\\Microsoft\\Edge\\Application\\",
            "C:\\Program Files\\Microsoft\\Edge\\Application\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Details",
          "operator": "endswith",
          "values": [
            "\\Installer\\setup.exe\" --configure-user-settings --verbose-logging --system-level --msedge --channel=stable"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_optional_*"
        }
      }
    ]
  }
}