{
  "title": "Shell Open Registry Keys Manipulation",
  "rule_id": "152f3630-77c1-4284-bcc0-4cc68ab2f6e7",
  "description": "Detects the shell open key manipulation (exefile and ms-settings) used for persistence and the pattern of UAC Bypass using fodhelper.exe, computerdefaults.exe, slui.exe via registry keys (e.g. UACMe 33 or 62)",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.persistence",
    "attack.defense-evasion",
    "attack.privilege-escalation",
    "attack.t1548.002",
    "attack.t1546.001"
  ],
  "category": "registry_event",
  "rule_file": "rules/windows/registry/registry_event/registry_event_shell_open_keys_manipulation.yml",
  "sources": [
    "sysmon_registry_event"
  ],
  "items": {
    "selection1": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "EventType",
          "operator": "exact",
          "values": [
            "SetValue"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "TargetObject",
          "operator": "endswith",
          "values": [
            "Classes\\ms-settings\\shell\\open\\command\\SymbolicLinkValue"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Details",
          "operator": "contains",
          "values": [
            "\\Software\\Classes\\{"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection2": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "TargetObject",
          "operator": "endswith",
          "values": [
            "Classes\\ms-settings\\shell\\open\\command\\DelegateExecute"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "selection3": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "EventType",
          "operator": "exact",
          "values": [
            "SetValue"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "TargetObject",
          "operator": "endswith",
          "values": [
            "Classes\\ms-settings\\shell\\open\\command\\(Default)",
            "Classes\\exefile\\shell\\open\\command\\(Default)"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_sel3": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Details",
          "operator": "exact",
          "values": [
            "(Empty)"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "any",
    "children": [
      {
        "type": "item_ref",
        "name": "selection1"
      },
      {
        "type": "item_ref",
        "name": "selection2"
      },
      {
        "type": "all",
        "children": [
          {
            "type": "item_ref",
            "name": "selection3"
          },
          {
            "type": "not",
            "child": {
              "type": "item_ref",
              "name": "filter_sel3"
            }
          }
        ]
      }
    ]
  }
}