{
  "title": "Security Support Provider (SSP) Added to LSA Configuration",
  "rule_id": "eeb30123-9fbd-4ee8-aaa0-2e545bbed6dc",
  "description": "Detects the addition of a SSP to the registry. Upon a reboot or API call, SSP DLLs gain access to encrypted and plaintext passwords stored in Windows.\n",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.privilege-escalation",
    "attack.persistence",
    "attack.t1547.005"
  ],
  "category": "registry_event",
  "rule_file": "rules/windows/registry/registry_event/registry_event_ssp_added_lsa_config.yml",
  "sources": [
    "sysmon_registry_event"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "TargetObject",
          "operator": "endswith",
          "values": [
            "\\Control\\Lsa\\Security Packages",
            "\\Control\\Lsa\\OSConfig\\Security Packages"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_msiexec": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "exact",
          "values": [
            "C:\\Windows\\system32\\msiexec.exe",
            "C:\\Windows\\syswow64\\MsiExec.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_main_image_null": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "is_null",
          "values": [],
          "match": "all",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_main_*"
        }
      }
    ]
  }
}