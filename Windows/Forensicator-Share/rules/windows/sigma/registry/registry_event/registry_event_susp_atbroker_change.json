{
  "title": "Atbroker Registry Change",
  "rule_id": "9577edbb-851f-4243-8c91-1d5b50c1a39b",
  "description": "Detects creation/modification of Assistive Technology applications and persistence with usage of 'at'",
  "level": "medium",
  "status": "test",
  "tags": [
    "attack.privilege-escalation",
    "attack.defense-evasion",
    "attack.t1218",
    "attack.persistence",
    "attack.t1547"
  ],
  "category": "registry_event",
  "rule_file": "rules/windows/registry/registry_event/registry_event_susp_atbroker_change.yml",
  "sources": [
    "sysmon_registry_event"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "TargetObject",
          "operator": "contains",
          "values": [
            "Software\\Microsoft\\Windows NT\\CurrentVersion\\Accessibility\\ATs",
            "Software\\Microsoft\\Windows NT\\CurrentVersion\\Accessibility\\Configuration"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_atbroker": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "exact",
          "values": [
            "C:\\Windows\\system32\\atbroker.exe"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "TargetObject",
          "operator": "contains",
          "values": [
            "\\Microsoft\\Windows NT\\CurrentVersion\\Accessibility\\Configuration"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "Details",
          "operator": "exact",
          "values": [
            "(Empty)"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    },
    "filter_uninstallers": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "startswith",
          "values": [
            "C:\\Windows\\Installer\\MSI"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "TargetObject",
          "operator": "contains",
          "values": [
            "Software\\Microsoft\\Windows NT\\CurrentVersion\\Accessibility\\ATs"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "all",
    "children": [
      {
        "type": "item_ref",
        "name": "selection"
      },
      {
        "type": "not",
        "child": {
          "type": "wildcard_ref",
          "mode": "any",
          "pattern": "filter_*"
        }
      }
    ]
  }
}