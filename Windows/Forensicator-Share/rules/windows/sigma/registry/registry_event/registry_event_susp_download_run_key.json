{
  "title": "Suspicious Run Key from Download",
  "rule_id": "9c5037d1-c568-49b3-88c7-9846a5bdc2be",
  "description": "Detects the suspicious RUN keys created by software located in Download or temporary Outlook/Internet Explorer directories",
  "level": "high",
  "status": "test",
  "tags": [
    "attack.privilege-escalation",
    "attack.persistence",
    "attack.t1547.001"
  ],
  "category": "registry_event",
  "rule_file": "rules/windows/registry/registry_event/registry_event_susp_download_run_key.yml",
  "sources": [
    "sysmon_registry_event"
  ],
  "items": {
    "selection": {
      "type": "all",
      "children": [
        {
          "type": "field",
          "field": "Image",
          "operator": "contains",
          "values": [
            "\\AppData\\Local\\Packages\\Microsoft.Outlook_",
            "\\AppData\\Local\\Microsoft\\Olk\\Attachments\\",
            "\\Downloads\\",
            "\\Temporary Internet Files\\Content.Outlook\\",
            "\\Local Settings\\Temporary Internet Files\\"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        },
        {
          "type": "field",
          "field": "TargetObject",
          "operator": "contains",
          "values": [
            "\\Software\\Microsoft\\Windows\\CurrentVersion\\Run",
            "\\Software\\WOW6432Node\\Microsoft\\Windows\\CurrentVersion\\Run",
            "\\Software\\Microsoft\\Windows\\CurrentVersion\\Policies\\Explorer\\Run"
          ],
          "match": "any",
          "windash": false,
          "ignore_case": true
        }
      ]
    }
  },
  "condition": {
    "type": "item_ref",
    "name": "selection"
  }
}